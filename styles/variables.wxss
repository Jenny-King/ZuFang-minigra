:root,
page {
  --color-primary: #1677ff;
  --color-success: #52c41a;
  --color-warning: #ff4d4f;
  --color-bg: #f7f8fa;
  --color-card: #ffffff;
  --color-text-main: #1f1f1f;
  --color-text-secondary: #666666;
  --color-border: #e8e8e8;

  --radius-card: 8rpx;
  --radius-control: 4rpx;

  --font-title: 32rpx;
  --font-body: 28rpx;
  --font-meta: 24rpx;

  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 40rpx;
}
