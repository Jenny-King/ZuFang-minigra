<view class="container history-page {{titleHighlight ? 'highlight' : ''}}" bindtap="onPageTap">
  <view wx:if="{{!loading && list.length > 0}}" class="page-toolbar" catchtap="noop">
    <button class="clear-btn" size="mini" bindtap="onClearTap">清空历史</button>
  </view>

  <view wx:if="{{errorText}}" class="error-box">{{errorText}}</view>
  <view wx:if="{{!loading && list.length === 0}}" class="empty-tip">暂无浏览历史</view>

  <view class="history-list">
    <view
      class="listing-card {{openActionHistoryId === item.historyId ? 'swiped' : ''}}"
      wx:for="{{list}}"
      wx:key="historyId"
      data-history-id="{{item.historyId}}"
      bindtouchstart="onCardTouchStart"
      bindtouchend="onCardTouchEnd"
      catchtap="noop"
    >
      <view class="card-inner">
        <view class="listing-body">
          <image
            class="cover"
            src="{{item.displayImage}}"
            mode="aspectFill"
            data-house-id="{{item.houseId}}"
            bindtap="onGoDetailTap"
          />

          <view class="main" data-house-id="{{item.houseId}}" bindtap="onGoDetailTap">
            <view class="title text-ellipsis">{{item.displayTitle}}</view>
            <view class="meta">{{item.displayType}}</view>
            <view class="address">{{item.displayAddress}}</view>
            <view class="footer">
              <text class="price">{{item.displayPrice}}</text>
              <text class="time">浏览于 {{item.displayViewTime}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="swipe-actions">
        <view
          class="swipe-btn swipe-delete"
          data-history-id="{{item.historyId}}"
          bindtap="onRemoveTap"
        >
          <text class="swipe-btn-char">删</text>
          <text class="swipe-btn-char">除</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-tip">加载中...</view>
  <view wx:if="{{!loading && list.length > 0 && !hasMore}}" class="loading-tip">没有更多了</view>
</view>
