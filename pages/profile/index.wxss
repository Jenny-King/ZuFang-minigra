@import "../../styles/variables.wxss";

.profile-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  background: var(--color-background-muted);
}

.profile-loading {
  margin: var(--space-md);
  padding: var(--card-padding);
  background: var(--color-background-card);
  border-radius: var(--radius-md);
}

/* Hero */
.hero {
  padding-top: 88rpx;
  background: var(--gradient-brand);
  position: relative;
  overflow: visible;
  flex-shrink: 0;
  padding-bottom: 88rpx;
}
.hero::before {
  content: '';
  position: absolute;
  width: 520rpx;
  height: 520rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  top: -160rpx;
  right: -120rpx;
  pointer-events: none;
}
.hero::after {
  content: '';
  position: absolute;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.04);
  bottom: -100rpx;
  left: -40rpx;
  pointer-events: none;
}
.hero-main {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 44rpx 40rpx 28rpx;
  position: relative;
  z-index: 1;
}
.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}
.avatar {
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.18);
  background: linear-gradient(135deg, #93c5fd, #3b82f6);
}
.hero-info {
  flex: 1;
  min-width: 0;
}
.hero-name {
  font-size: var(--font-xl);
  font-weight: var(--weight-heavy);
  color: var(--color-text-inverse);
  letter-spacing: 0.6rpx;
}
.hero-phone {
  font-size: var(--font-label);
  color: rgba(255, 255, 255, 0.7);
  margin-top: 6rpx;
}
.badges {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 40rpx 36rpx;
  position: relative;
  z-index: 1;
  flex-wrap: wrap;
}
.badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 18rpx;
  border-radius: var(--radius-pill);
  font-size: var(--font-caption);
  font-weight: var(--weight-bold);
  border: 2rpx solid transparent;
}
.badge-role {
  background: rgba(255, 255, 255, 0.18);
  color: var(--color-text-inverse);
  border-color: rgba(255, 255, 255, 0.28);
}
.badge-warn {
  background: var(--color-warning-bg);
  color: #92400e;
  border-color: #fde68a;
}
.badge-muted {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.55);
  border-color: rgba(255, 255, 255, 0.15);
}

/* Stats 3-col overlap */
.stats-card {
  margin: -72rpx 32rpx 24rpx;
  background: var(--color-background-card);
  border-radius: var(--radius-md);
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.10);
  display: flex;
  overflow: hidden;
  position: relative;
  z-index: 5;
}
.stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 12rpx;
  position: relative;
}
.stat:active {
  background: var(--color-background-subtle);
}
.stat + .stat::before {
  content: '';
  position: absolute;
  left: 0;
  top: 18%;
  bottom: 18%;
  width: 2rpx;
  background: var(--color-border);
}
.stat-num {
  font-size: var(--font-xl);
  font-weight: var(--weight-heavy);
  color: var(--color-text-1);
}
.stat-label {
  font-size: var(--font-caption);
  color: var(--color-text-2);
  margin-top: 8rpx;
  font-weight: var(--weight-medium);
}
.stat-badge {
  position: absolute;
  top: 24rpx;
  right: 50%;
  transform: translateX(48rpx);
  min-width: 28rpx;
  padding: 0 8rpx;
  height: 28rpx;
  line-height: 28rpx;
  border-radius: var(--radius-pill);
  background: var(--color-danger);
  color: var(--color-text-inverse);
  font-size: 16rpx;
  font-weight: var(--weight-heavy);
}

/* Scroll area */
.page-scroll {
  flex: 1;
  padding-bottom: 32rpx;
}

/* Sections */
.section {
  margin: 0 32rpx 24rpx;
  background: var(--color-background-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 32rpx 20rpx;
  border-bottom: 2rpx solid var(--color-border);
}
.section-header-title {
  font-size: var(--font-label);
  font-weight: var(--weight-bold);
  color: var(--color-text-2);
}
.section-header-action {
  font-size: var(--font-label);
  color: var(--color-primary);
}

/* Appointments Empty State */
.appt-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 44rpx 32rpx 40rpx;
  gap: 16rpx;
}
.appt-empty-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-sm);
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}
.appt-empty-icon-text {
  font-size: var(--font-xl);
  color: var(--color-primary);
  font-weight: var(--weight-bold);
}
.appt-empty-text {
  font-size: var(--font-label);
  color: var(--color-text-3);
}
.appt-empty-btn {
  margin-top: 8rpx;
  padding: 14rpx 44rpx;
  border-radius: var(--radius-pill);
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: var(--font-label);
  font-weight: var(--weight-bold);
  border: none;
  line-height: normal;
}
.appt-empty-btn::after {
  border: none;
}

/* Menu */
.menu-item {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 28rpx 32rpx;
  position: relative;
}
.menu-item:active {
  background: var(--color-background-subtle);
}
.menu-item + .menu-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 108rpx;
  right: 0;
  height: 2rpx;
  background: var(--color-border);
}
.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.menu-icon.bg-blue {
  background: linear-gradient(135deg, #3b82f6, #1d4ed8);
}
.menu-icon.bg-purple {
  background: linear-gradient(135deg, #8b5cf6, #6d28d9);
}
.menu-icon.bg-orange {
  background: linear-gradient(135deg, #f59e0b, #d97706);
}
.menu-icon-text {
  font-size: var(--font-title-sm);
  font-weight: var(--weight-bold);
  color: var(--color-text-inverse);
}
.menu-text {
  flex: 1;
}
.menu-title {
  font-size: var(--font-title-sm);
  font-weight: var(--weight-bold);
  color: var(--color-text-1);
}
.menu-sub {
  font-size: var(--font-caption);
  color: var(--color-text-3);
  margin-top: 4rpx;
}
.menu-tag {
  font-size: var(--font-caption);
  font-weight: var(--weight-bold);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-pill);
  background: var(--color-success-bg);
  color: var(--color-success);
  margin-right: 8rpx;
}
.menu-arrow {
  font-size: var(--font-title-sm);
  color: var(--color-text-3);
  font-family: monospace;
}

/* Account Pill Switcher */
.acct-switcher {
  width: 100%;
}
.acct-inline-container {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 32rpx;
}
.acct-pill {
  display: inline-flex;
  align-items: center;
  gap: 14rpx;
  padding: 12rpx 24rpx 12rpx 12rpx;
  border-radius: 48rpx;
  border: 3rpx solid var(--color-border);
  background: var(--color-background-card);
  flex-shrink: 0;
}
.acct-pill.active {
  background: var(--color-primary-bg);
  border-color: #93c5fd;
}
.acct-pill-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  overflow: hidden;
  background: linear-gradient(135deg, #60a5fa, #2563eb);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-weight: bold;
}
.acct-pill.active .acct-pill-avatar {
  background: linear-gradient(135deg, #3b82f6, #1d4ed8);
}
.acct-pill-name {
  font-size: var(--font-label);
  font-weight: var(--weight-bold);
  color: var(--color-text-2);
  max-width: 144rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.acct-pill.active .acct-pill-name {
  color: var(--color-primary);
}
.acct-pill-check {
  font-size: var(--font-label);
  font-weight: var(--weight-heavy);
  color: var(--color-primary);
}
.acct-add-pill {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  border-radius: 48rpx;
  border: 3rpx dashed var(--color-border-strong);
  background: var(--color-background-card);
  font-size: var(--font-label);
  color: var(--color-text-3);
  flex-shrink: 0;
}
.acct-add-icon {
  font-size: var(--font-lg);
  font-weight: bold;
  height: 32rpx;
  line-height: 28rpx;
}

/* Logout */
.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 16rpx 32rpx 48rpx;
  height: 96rpx;
  background: var(--color-background-card);
  border: 3rpx solid #fecaca !important;
  border-radius: var(--radius-md);
  color: var(--color-danger);
  font-size: var(--font-title-sm);
  font-weight: var(--weight-bold);
  line-height: normal;
}
.logout-btn::after {
  display: none;
}
.logout-btn:active {
  background: #fef2f2;
}

/* Guest Card */
.guest-card {
  margin: 32rpx;
  padding: var(--space-xl) var(--space-lg);
  border-radius: var(--radius-md);
  background: var(--color-background-card);
  box-shadow: var(--shadow-card);
}
.guest-title {
  color: var(--color-text-1);
  font-size: var(--font-xl);
  font-weight: var(--weight-heavy);
}
.guest-subtitle {
  margin-top: var(--space-xs);
  color: var(--color-text-2);
  font-size: var(--font-sm);
}
.auth-actions {
  display: flex;
  gap: var(--space-xs);
  margin-top: var(--space-md);
}
.auth-btn {
  margin: 0;
  border-radius: var(--radius-pill);
  background: var(--color-background-subtle);
  color: var(--color-text-1);
}
.auth-btn.primary {
  background: var(--color-primary);
  color: var(--color-text-inverse);
}

/* Account Switcher Mask */
.account-switcher-mask {
  position: fixed;
  inset: 0;
  z-index: 99;
  display: flex;
  align-items: flex-end;
  background: var(--overlay-bg);
}

.account-switcher-panel {
  width: 100%;
  padding: var(--space-xl) var(--space-lg) calc(var(--space-lg) + env(safe-area-inset-bottom));
  border-radius: var(--radius-panel) var(--radius-panel) 0 0;
  background: var(--color-background-page);
  box-shadow: var(--shadow-float);
}

.account-switcher-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: var(--space-lg);
}

.account-switcher-title {
  color: var(--color-text-1);
  font-size: var(--font-xl);
  font-weight: var(--weight-heavy);
}

.account-switcher-subtitle {
  margin-top: var(--space-2xs);
  color: var(--color-text-2);
  font-size: var(--font-caption);
}

.tap-area {
  min-width: 88rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.account-switcher-close {
  color: var(--color-text-2);
  font-size: var(--font-xl);
}

.account-card-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.account-card {
  position: relative;
  display: flex;
  align-items: center;
  padding: var(--space-md);
  border: var(--line-width-hairline) solid transparent;
  border-radius: var(--radius-lg);
  background: var(--color-background-card);
}

.account-card.active {
  background: var(--color-primary-bg);
  border: var(--line-width-hairline) solid var(--color-primary);
}

.account-card-remove {
  position: absolute;
  top: var(--space-sm);
  right: var(--space-sm);
  padding: var(--space-2xs) var(--space-xs);
  border-radius: var(--radius-pill);
  background: var(--color-danger-bg);
  color: var(--color-danger);
  font-size: var(--font-xs);
}

.account-card-main {
  flex: 1;
  min-width: 0;
  margin-left: var(--space-sm);
}

.account-card-title-row {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.account-card-name {
  max-width: 320rpx;
  color: var(--color-text-1);
  font-size: var(--font-title-sm);
  font-weight: var(--weight-bold);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.account-card-role {
  padding: var(--space-3xs) var(--space-xs);
  border-radius: var(--radius-pill);
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: var(--font-xs);
}

.account-card-subline {
  margin-top: var(--space-2xs);
  color: var(--color-text-2);
  font-size: var(--font-caption);
}

.account-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2xs);
  margin-top: var(--space-sm);
}

.account-card-tag {
  padding: var(--space-2xs) var(--space-xs);
  border-radius: var(--radius-pill);
  background: var(--color-background-subtle);
  color: var(--color-text-2);
  font-size: var(--font-xs);
}

.account-card-tag.active {
  background: var(--color-primary);
  color: var(--color-text-inverse);
}

.account-switcher-actions {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-lg);
}

.account-switcher-btn {
  flex: 1;
  height: var(--button-height);
  line-height: var(--button-height);
  margin: 0;
  border-radius: var(--radius-lg);
  background: var(--color-background-card);
  color: var(--color-text-1);
  border: var(--line-width-thin) solid var(--color-border-strong);
  font-size: var(--font-md);
}

.account-switcher-btn.primary {
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-color: var(--color-primary);
}
