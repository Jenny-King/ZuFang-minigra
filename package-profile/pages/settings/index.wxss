.settings-page {
  min-height: 100vh;
  padding-bottom: 28rpx;
}

.settings-hero {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(160deg, #1f4fd7 0%, #2f64f5 100%);
  color: #ffffff;
  box-shadow: 0 20rpx 40rpx rgba(31, 79, 215, 0.18);
}

.settings-title {
  font-size: 38rpx;
  font-weight: 700;
}

.settings-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.settings-summary {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.summary-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.14);
}

.section-title {
  margin: 22rpx 6rpx 16rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #4c5668;
}

.settings-card {
  padding: 0 22rpx;
  border-radius: 28rpx;
  overflow: hidden;
}

.settings-item,
.toggle-item {
  display: flex;
  align-items: center;
  min-height: 112rpx;
  padding: 22rpx 4rpx;
  border-bottom: 2rpx solid #f1f3f7;
}

.settings-card .toggle-item:last-child,
.settings-card .settings-item:last-child {
  border-bottom: none;
}

.settings-main {
  flex: 1;
  min-width: 0;
}

.settings-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.settings-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8a90a0;
}

.settings-arrow {
  margin-left: 14rpx;
  font-size: 28rpx;
  color: #c4c7ce;
}

.settings-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #2f64f5;
  background: #edf3ff;
}

.danger-btn {
  margin-top: 28rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #fff1f0;
  color: #ff4d4f;
  border: 2rpx solid #ffd0d0;
  font-size: 28rpx;
}
