/* CSS 变量通过 styleIsolation:shared 从 page 继承 */

.lazy-image {
  display: block;
  position: relative;
  overflow: hidden;
  width: 100%;
  background: var(--color-background-subtle);
}

.lazy-image__skeleton {
  position: absolute;
  inset: 0;
  z-index: 1;
  background: linear-gradient(
    90deg,
    var(--skeleton-base-color) 0%,
    var(--skeleton-highlight-color) 50%,
    var(--skeleton-base-color) 100%
  );
  background-size: 400% 100%;
  animation: skeleton-shimmer calc(var(--duration-normal) * 4) var(--easing-standard) infinite;
}

.lazy-image__img,
.lazy-image__placeholder {
  width: 100%;
  height: 100%;
}

.lazy-image__img {
  display: block;
  opacity: 0;
  transition: opacity var(--duration-fast) var(--easing-standard);
}

.lazy-image__img--loaded {
  opacity: 1;
}

.lazy-image__placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-background-muted);
}

.lazy-image__placeholder-frame {
  position: relative;
  width: 120rpx;
  height: 96rpx;
  border-radius: var(--radius-md);
  border: var(--line-width-thin) solid var(--color-border-strong);
  background: var(--color-background-card);
  overflow: hidden;
}

.lazy-image__placeholder-mountain {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  bottom: 14rpx;
  height: 34rpx;
  border-radius: var(--radius-pill) var(--radius-pill) 0 0;
  background: var(--color-text-3);
}

.lazy-image__placeholder-sun {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: var(--radius-pill);
  background: var(--color-primary);
}

.lazy-image--radius-xs {
  border-radius: var(--radius-xs);
}

.lazy-image--radius-sm {
  border-radius: var(--radius-sm);
}

.lazy-image--radius-md {
  border-radius: var(--radius-md);
}

.lazy-image--radius-lg {
  border-radius: var(--radius-lg);
}

.lazy-image--radius-xl {
  border-radius: var(--radius-xl);
}

.lazy-image--radius-2xl {
  border-radius: var(--radius-2xl);
}

.lazy-image--radius-panel {
  border-radius: var(--radius-panel);
}

.lazy-image--radius-pill {
  border-radius: var(--radius-pill);
}

.lazy-image--height-76 {
  height: 76rpx;
}

.lazy-image--height-80 {
  height: 80rpx;
}

.lazy-image--height-88 {
  height: 88rpx;
}

.lazy-image--height-92 {
  height: 92rpx;
}

.lazy-image--height-96 {
  height: 96rpx;
}

.lazy-image--height-108 {
  height: 108rpx;
}

.lazy-image--height-120 {
  height: 120rpx;
}

.lazy-image--height-140 {
  height: 140rpx;
}

.lazy-image--height-148 {
  height: 148rpx;
}

.lazy-image--height-160 {
  height: 160rpx;
}

.lazy-image--height-180 {
  height: 180rpx;
}

.lazy-image--height-190 {
  height: 190rpx;
}

.lazy-image--height-200 {
  height: 200rpx;
}

.lazy-image--height-220 {
  height: 220rpx;
}

.lazy-image--height-240 {
  height: 240rpx;
}

.lazy-image--height-260 {
  height: 260rpx;
}

.lazy-image--height-308 {
  height: 308rpx;
}

.lazy-image--height-340 {
  height: 340rpx;
}

.lazy-image--height-440 {
  height: 440rpx;
}

@keyframes skeleton-shimmer {
  0% {
    background-position: 100% 0;
  }

  100% {
    background-position: -100% 0;
  }
}

@media (prefers-reduced-motion: reduce) {
  .lazy-image__skeleton,
  .lazy-image__img {
    animation: none;
    transition: none;
  }
}
