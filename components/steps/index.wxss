@import "../../styles/variables.wxss";

.steps {
  width: 100%;
}

.steps__track,
.steps__labels {
  display: flex;
  align-items: flex-start;
  width: 100%;
}

.steps__track-item,
.steps__label {
  flex: 1;
}

.steps__track-item {
  display: flex;
  align-items: center;
}

.steps__node {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-pill);
  flex-shrink: 0;
  transition: transform var(--duration-normal) var(--easing-standard), box-shadow var(--duration-normal) var(--easing-standard), background var(--duration-normal) var(--easing-standard);
}

.steps__node--completed {
  background: linear-gradient(180deg, #4c88ff 0%, var(--color-primary) 100%);
  box-shadow: 0 8rpx 18rpx rgba(60, 123, 253, 0.14);
}

.steps__node--current {
  background: linear-gradient(180deg, #4c88ff 0%, var(--color-primary) 100%);
  box-shadow: 0 12rpx 24rpx rgba(60, 123, 253, 0.2);
  transform: scale(1.06);
}

.steps__node--pending {
  background: #eef2f7;
}

.steps__node-text {
  font-size: var(--font-caption);
  font-weight: var(--weight-bold);
  line-height: 1;
}

.steps__node-text--completed,
.steps__node-text--current {
  color: var(--color-text-inverse);
}

.steps__node-text--pending {
  color: var(--color-text-3);
}

.steps__line {
  position: relative;
  flex: 1;
  height: 8rpx;
  margin: 0 10rpx;
  overflow: hidden;
}

.steps__line-base,
.steps__line-fill {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  border-radius: var(--radius-pill);
}

.steps__line-base {
  width: 100%;
  background: var(--color-border);
}

.steps__line-fill {
  width: 0;
  background: var(--color-primary);
  transition: width var(--duration-normal) var(--easing-standard);
}

.steps__line-fill--completed {
  width: 100%;
}

.steps__labels {
  margin-top: var(--space-sm);
}

.steps__label {
  text-align: center;
  font-size: var(--font-sm);
  line-height: var(--lh-tight);
}

.steps__label--completed {
  color: var(--color-text-1);
}

.steps__label--current {
  color: var(--color-primary);
  font-weight: var(--weight-bold);
}

.steps__label--pending {
  color: var(--color-text-3);
}
