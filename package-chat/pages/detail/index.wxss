@import "../../../styles/variables.wxss";

.chat-detail-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f7f8fa;
}

.error-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  margin: var(--space-sm) var(--page-padding) 0;
  padding: var(--space-sm);
  border-radius: var(--radius-sm);
  background: var(--color-danger-bg);
}

.error-box__text {
  color: var(--color-danger);
  font-size: var(--font-sm);
}

.error-box__retry {
  min-height: var(--control-height-sm);
  margin: 0;
  padding: 0 var(--space-md);
  border-radius: var(--radius-pill);
  background: var(--color-background-card);
  color: var(--color-danger);
  font-size: var(--font-caption);
}

.error-box__retry::after {
  border: none;
}

.house-card {
  display: flex;
  align-items: flex-start;
  gap: var(--space-md);
  margin: var(--space-sm) var(--page-padding) 0;
  padding: 24rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.house-card__image {
  width: 148rpx;
  height: 148rpx;
  flex-shrink: 0;
  border-radius: 16rpx;
  background: var(--color-background-subtle);
}

.house-card__content {
  flex: 1;
  min-width: 0;
  padding-top: 4rpx;
}

.house-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-sm);
}

.house-card__title {
  flex: 1;
  min-width: 0;
  color: var(--color-text-1);
  font-size: var(--font-title-sm);
  font-weight: var(--weight-bold);
  line-height: 1.45;
}

.house-card__price {
  flex-shrink: 0;
  padding-top: 2rpx;
  color: var(--color-price-highlight);
  font-size: var(--font-label);
  font-weight: var(--weight-bold);
}

.house-card__meta {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-2);
  font-size: var(--font-caption);
  line-height: 1.6;
}

.house-card__footer {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: var(--space-sm);
}

.house-card__action {
  color: #b2b2b2;
  font-size: var(--font-xs);
  font-weight: var(--weight-regular);
}

.house-card__arrow {
  color: #b2b2b2;
  font-size: var(--font-xs);
}

.message-scroll {
  flex: 1;
  box-sizing: border-box;
  padding: 28rpx var(--page-padding) 24rpx;
}

.time-divider {
  margin: 28rpx auto 32rpx;
  color: #b2b2b2;
  font-size: var(--font-sm);
  text-align: center;
}

.message-row {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.message-row.self {
  justify-content: flex-end;
}

.message-row.other {
  justify-content: flex-start;
}

.message-stack {
  display: flex;
  flex-direction: column;
  max-width: 64%;
  align-items: flex-start;
}

.message-row.self .message-stack {
  align-items: flex-end;
}

.message-avatar {
  flex: none;
  width: 80rpx;
  height: 80rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: var(--color-background-card);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.bubble {
  width: auto;
  max-width: 100%;
  padding: 16rpx 24rpx;
  border-radius: 20rpx 20rpx 20rpx 4rpx;
  background: #ffffff;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.message-row.self .bubble {
  border-radius: 20rpx 20rpx 4rpx 20rpx;
  background: var(--color-primary);
  box-shadow: 0 2px 8px rgba(37, 99, 235, 0.16);
}

.bubble.image-bubble {
  padding: 8rpx;
  background: transparent;
  box-shadow: none;
}

.message-row.self .bubble.image-bubble {
  background: transparent;
}

.image-message {
  overflow: hidden;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.image-message__img {
  width: 280rpx;
}

.content {
  display: block;
  color: var(--color-text-1);
  font-size: var(--font-md);
  line-height: var(--lh-snug);
  word-break: break-all;
}

.message-row.self .content {
  color: var(--color-text-inverse);
}

.input-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 2rpx solid #f2f2f2;
  box-shadow: none;
}

.composer-shell {
  flex: 1 1 80%;
  min-width: 0;
  display: flex;
  align-items: center;
}

.msg-input {
  flex: 1;
  min-height: 80rpx;
  padding: 0 28rpx;
  border: none;
  border-radius: 40rpx;
  background: #f5f5f5;
  font-size: var(--font-md);
  color: #333333;
  line-height: 80rpx;
}

.plus-btn {
  flex: 0 0 20%;
  width: 20%;
  min-width: 112rpx;
  max-width: 144rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
  padding: 0;
  border-radius: 40rpx;
  background: transparent;
  color: #9ca3af;
  font-size: 40rpx;
  font-weight: var(--weight-regular);
  box-shadow: none;
}

.send-btn {
  flex: 0 0 20%;
  width: 20%;
  min-width: 112rpx;
  max-width: 144rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
  padding: 0;
  border-radius: 40rpx;
  background: #3c7bfd;
  color: var(--color-text-inverse);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  box-shadow: 0 6rpx 16rpx rgba(60, 123, 253, 0.22);
}

.msg-input__placeholder {
  color: #b2b2b2;
}

.plus-btn::after,
.send-btn::after {
  border: none;
}

.plus-btn[disabled],
.send-btn[disabled] {
  opacity: 0.7;
}

/* ---- 预约气泡 ---- */
.booking-bubble {
  width: 380rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #eef4ff 0%, #f0f7ff 100%);
  box-shadow: 0 2px 8px rgba(37, 99, 235, 0.08);
}

.message-row.self .booking-bubble {
  background: linear-gradient(135deg, #e0ecff 0%, #d6e8ff 100%);
}

.booking-bubble__header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.booking-bubble__icon {
  font-size: 28rpx;
}

.booking-bubble__label {
  flex: 1;
  color: var(--color-primary);
  font-size: var(--font-sm);
  font-weight: var(--weight-bold);
}

.booking-bubble__status {
  padding: 2rpx 12rpx;
  border-radius: var(--radius-pill);
  font-size: var(--font-xxs);
  font-weight: var(--weight-medium);
}

.booking-bubble__status.pending {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}

.booking-bubble__status.confirmed {
  background: var(--color-success-bg);
  color: var(--color-success);
}

.booking-bubble__status.rejected {
  background: var(--color-danger-bg);
  color: var(--color-danger);
}

.booking-bubble__status.rescheduled {
  background: var(--color-info-bg);
  color: var(--color-info);
}

.booking-bubble__status.cancelled {
  background: var(--color-background-subtle);
  color: var(--color-text-3);
}

.booking-bubble__info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.booking-bubble__house {
  color: var(--color-text-1);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
}

.booking-bubble__time {
  color: var(--color-text-2);
  font-size: var(--font-caption);
}

/* ---- 快捷功能栏 ---- */
.quick-actions-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 24rpx;
  background: #ffffff;
  border-top: 2rpx solid #f2f2f2;
}

.quick-action-item {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-pill);
  background: var(--color-primary-bg);
  transition: all var(--duration-fast) var(--easing-standard);
}

.quick-action-item:active {
  transform: scale(0.96);
}

.quick-action-icon {
  font-size: 24rpx;
}

.quick-action-text {
  color: var(--color-primary);
  font-size: var(--font-caption);
  font-weight: var(--weight-medium);
}
