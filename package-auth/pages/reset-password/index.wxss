.auth-page {
  background: var(--color-background-card);
  min-height: 100vh;
  display: block;
  padding: 48rpx 48rpx; /* 全屏边距 */
  box-sizing: border-box;
}

view, text, input, button {
  box-sizing: border-box;
}

.phone-shell {
  width: 100%;
}

.card {
  background: transparent;
  border-radius: 0;
  box-shadow: none;
  padding: 0;
}

.title {
  margin: 0;
  font-size: 60rpx;
  line-height: 1.2;
  font-weight: 700;
  text-align: center;
}

.subtitle {
  margin: 20rpx 0 48rpx;
  text-align: center;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--color-text-3);
}

.form-group {
  margin-bottom: 36rpx;
}

.label {
  display: block;
  margin-bottom: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-1);
}

.field-wrap {
  position: relative;
}

.input {
  width: 100%;
  height: 100rpx;
  border: 2rpx solid transparent;
  background: var(--color-background-muted);
  border-radius: var(--radius-lg);
  padding: 0 28rpx;
  font-size: 30rpx;
  color: var(--color-text-1);
  transition: 0.2s ease;
}

.input-placeholder {
  color: var(--color-text-3);
}

.input:focus {
  border-color: rgba(59, 130, 246, 0.5);
  background: #fff;
}

.input.has-action {
  padding-right: 220rpx; /* 严格对应 preview 110px */
}

.input.has-eye {
  padding-right: 104rpx;
}

.inline-action,
.eye-btn {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: transparent;
  font-size: 28rpx; /* 14px */
  margin: 0;
  padding: 0;
  line-height: normal;
  border: none;
}

.inline-action::after, .eye-btn::after {
  display: none;
}

.inline-action {
  right: 24rpx; /* 12px */
  color: var(--color-primary);
  font-weight: 600;
  padding: 8rpx 12rpx; /* 4px 6px */
}

.inline-action.disabled {
  color: #aab4c3; /* 严格对应 preview 的 disabled 颜色 */
  background: transparent;
}

.eye-btn {
  right: 20rpx;
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
  color: var(--color-text-3);
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hint,
.error {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.4;
}

.hint {
  color: var(--color-text-3);
}

.error {
  color: var(--color-danger);
  min-height: 36rpx;
}

.strength {
  display: inline-flex;
  gap: 12rpx;
  align-items: center;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-3);
}

.bars {
  display: inline-flex;
  gap: 8rpx;
}

.bar {
  width: 48rpx;
  height: 12rpx;
  border-radius: 99rpx;
  background: var(--color-border);
  transition: 0.2s ease;
}

.bar.active {
  background: var(--color-success);
}

.submit-btn {
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  margin-top: 16rpx;
  background: var(--color-primary-bg);
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
  transition: 0.2s ease;
  text-align: center;
  padding: 0;
}

.submit-btn::after {
  display: none;
}

.submit-btn.enabled {
  background: linear-gradient(135deg, #4f8cff, #2f6df6);
  box-shadow: 0 12rpx 24rpx rgba(59, 130, 246, 0.18);
}

.submit-btn.loading {
  opacity: 0.9;
}

.success-box {
  margin-top: 32rpx;
  padding: 24rpx 28rpx;
  border-radius: 28rpx;
  background: var(--color-success-bg);
  color: var(--color-success);
  font-size: 28rpx;
  line-height: 1.6;
  border: 2rpx solid rgba(22, 163, 74, 0.18);
}

.divider {
  height: 2rpx;
  background: var(--color-border);
  margin: 40rpx 0 0;
  display: none; /* 全屏卡片底部链接通常不要分割线 */
}

.footer-link {
  margin-top: 28rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--color-primary);
}
