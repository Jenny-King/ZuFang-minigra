<view class="container auth-page">
  <view class="phone-shell">
    <view class="card">
      <view class="title">重置密码</view>
      <view class="subtitle">请输入绑定手机号并设置新密码</view>

      <view class="form-group">
        <text class="label">手机号</text>
        <view class="field-wrap">
          <input
            class="input"
            type="number"
            maxlength="11"
            placeholder="请输入 11 位手机号"
            placeholder-class="input-placeholder"
            value="{{phone}}"
            bindinput="onPhoneInput"
          />
        </view>
        <view class="error" wx:if="{{phoneError}}">{{phoneError}}</view>
      </view>

      <view class="form-group">
        <text class="label">验证码</text>
        <view class="field-wrap">
          <input
            class="input has-action"
            type="number"
            maxlength="6"
            placeholder="请输入 6 位验证码"
            placeholder-class="input-placeholder"
            value="{{code}}"
            bindinput="onCodeInput"
          />
          <view
            class="inline-action {{(cdRunning || sendingCode) ? 'disabled' : ''}}"
            catchtap="{{(cdRunning || sendingCode) ? '' : 'onSendCodeTap'}}"
          >
            {{sendingCode ? '发送中...' : (cdRunning ? cdSecs + 's 后重发' : '获取验证码')}}
          </view>
        </view>
        <view class="error" wx:if="{{codeError}}">{{codeError}}</view>
      </view>

      <view class="form-group">
        <text class="label">新密码</text>
        <view class="field-wrap">
          <input
            class="input has-eye"
            password="{{!showPassword}}"
            placeholder="8-20 位，建议字母+数字"
            placeholder-class="input-placeholder"
            value="{{newPassword}}"
            bindinput="onPasswordInput"
          />
          <view class="eye-btn" data-target="password" bindtap="onToggleEye">
            {{showPassword ? '🙈' : '👁'}}
          </view>
        </view>
        <view class="hint" wx:if="{{!passwordError}}">密码需为 8-20 位，并包含字母和数字</view>
        <view class="strength" wx:if="{{!passwordError}}">
          <text>强度</text>
          <view class="bars">
            <view class="bar {{passwordStrength >= 1 ? 'active' : ''}}"></view>
            <view class="bar {{passwordStrength >= 2 ? 'active' : ''}}"></view>
            <view class="bar {{passwordStrength >= 3 ? 'active' : ''}}"></view>
          </view>
          <text class="strength-text">{{passwordStrengthText}}</text>
        </view>
        <view class="error" wx:if="{{passwordError}}">{{passwordError}}</view>
      </view>

      <view class="form-group">
        <text class="label">确认新密码</text>
        <view class="field-wrap">
          <input
            class="input has-eye"
            password="{{!showConfirmPassword}}"
            placeholder="请再次输入新密码"
            placeholder-class="input-placeholder"
            value="{{confirmPassword}}"
            bindinput="onConfirmPasswordInput"
          />
          <view class="eye-btn" data-target="confirmPassword" bindtap="onToggleEye">
            {{showConfirmPassword ? '🙈' : '👁'}}
          </view>
        </view>
        <view class="error" wx:if="{{confirmPasswordError}}">{{confirmPasswordError}}</view>
      </view>

      <button
        class="submit-btn {{isFormValid ? 'enabled' : ''}} {{submitLoading ? 'loading' : ''}}"
        disabled="{{!isFormValid || submitLoading}}"
        bindtap="onSubmitTap"
      >
        {{submitLoading ? '提交中...' : '重置密码'}}
      </button>



      <view class="success-box" wx:if="{{submitSuccess}}">
        密码重置成功，请使用新密码重新登录。
      </view>

      <view class="divider"></view>
      <view class="footer-link" bindtap="onBackTap">返回登录</view>
    </view>
  </view>
</view>
