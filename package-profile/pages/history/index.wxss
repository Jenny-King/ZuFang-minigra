.history-page {
  min-height: 100vh;
}

.page-title-bar {
  margin-bottom: 14rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 2rpx solid #eef1f5;
  transition: all 0.2s ease;
}

.page-title-bar.active {
  background: #eaf3ff;
  border-color: #5c8dff;
  box-shadow: 0 18rpx 36rpx rgba(22, 119, 255, 0.16);
}

.page-title-main {
  flex: 1;
  min-width: 0;
}

.page-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.page-title-bar.active .page-title {
  color: #1677ff;
}

.page-subtitle {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #7f8793;
}

.clear-btn {
  margin: 0;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 6rpx;
  background: #fff1f0;
  color: #ff4d4f;
  font-size: 22rpx;
}

.error-box {
  padding: 20rpx;
  margin-bottom: 20rpx;
  border-radius: 8rpx;
  color: #ff4d4f;
  background: #fff1f0;
  font-size: 24rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx;
}

.cover {
  width: 180rpx;
  height: 140rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}

.main {
  flex: 1;
  min-width: 0;
}

.title {
  font-size: 28rpx;
  color: #1f1f1f;
  font-weight: 500;
}

.meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #666666;
}

.footer {
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price {
  color: #ff4d4f;
  font-size: 28rpx;
  font-weight: 600;
}

.time {
  color: #999999;
  font-size: 22rpx;
}

.remove-btn {
  margin: 0;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 6rpx;
  background: #f5f5f5;
  color: #666666;
  font-size: 22rpx;
}

.loading-tip {
  text-align: center;
  color: #999999;
  font-size: 24rpx;
  padding: 22rpx 0;
}
