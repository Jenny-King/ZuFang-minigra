<view class="chat-detail-page">
  <view wx:if="{{errorText}}" class="error-box">
    <text class="error-box__text">{{errorText}}</text>
    <button class="error-box__retry" bindtap="loadMessages">重试</button>
  </view>

  <view wx:if="{{houseCard}}" class="house-card card" bindtap="onHouseCardTap">
    <image
      class="house-card__image"
      src="{{houseCard.imageUrl}}"
      mode="aspectFill"
      lazy-load="{{false}}"
    />
    <view class="house-card__content">
      <view class="house-card__header">
        <text class="house-card__title text-ellipsis">{{houseCard.title}}</text>
        <text class="house-card__price">{{houseCard.priceText}}</text>
      </view>
      <text class="house-card__meta text-ellipsis">{{houseCard.metaText}}</text>
      <view class="house-card__footer">
        <text class="house-card__action">查看房源详情</text>
        <text class="house-card__arrow">></text>
      </view>
    </view>
  </view>

  <scroll-view
    class="message-scroll"
    scroll-y
    scroll-with-animation
    scroll-into-view="{{scrollToViewId}}"
  >
    <skeleton wx:if="{{loading && !messageList.length}}" type="list-item" count="{{4}}" />

    <empty-state
      wx:elif="{{!loading && messageList.length === 0}}"
      title="暂无消息"
      subtitle="发一条开始聊天吧"
    />

    <block wx:else>
      <view
        wx:for="{{messageList}}"
        wx:key="_viewId"
        id="{{item._viewId}}"
      >
        <view wx:if="{{item.showTime}}" class="time-divider">{{item.timeLabel}}</view>
        <view class="message-row {{item.isSelf ? 'self' : 'other'}}">
          <image
            wx:if="{{!item.isSelf}}"
            class="message-avatar"
            src="{{targetUserAvatar}}"
            mode="aspectFill"
            lazy-load="{{false}}"
          />
          <view class="message-stack">
            <view class="bubble {{item.isImage ? 'image-bubble' : ''}}">
              <view wx:if="{{item.isImage}}" class="image-message" data-url="{{item.content}}" bindtap="onPreviewMessageImage">
                <lazy-image
                  class="image-message__img"
                  src="{{item.content}}"
                  mode="aspectFit"
                  radius="var(--radius-sm)"
                  width="280rpx"
                  height="220rpx"
                />
              </view>
              <view wx:elif="{{item.isBooking}}" class="booking-bubble">
                <view class="booking-bubble__header">
                  <text class="booking-bubble__icon">📅</text>
                  <text class="booking-bubble__label">预约看房</text>
                  <text class="booking-bubble__status {{item.bookingData.status}}">{{item.bookingData.statusText}}</text>
                </view>
                <view class="booking-bubble__info">
                  <text class="booking-bubble__house text-ellipsis">{{item.bookingData.houseTitle}}</text>
                  <text class="booking-bubble__time">{{item.bookingData.date}}  {{item.bookingData.timeSlotLabel}}</text>
                </view>
              </view>
              <text wx:else class="content">{{item.content}}</text>
            </view>
          </view>
          <image
            wx:if="{{item.isSelf}}"
            class="message-avatar"
            src="{{currentUserAvatar}}"
            mode="aspectFill"
            lazy-load="{{false}}"
          />
        </view>
      </view>
    </block>
  </scroll-view>

  <!-- 快捷功能栏 -->
  <view class="quick-actions-bar">
    <view class="quick-action-item" bindtap="onQuickBookingTap">
      <text class="quick-action-icon">📅</text>
      <text class="quick-action-text">预约看房</text>
    </view>
  </view>

  <view class="input-bar">
    <view class="composer-shell">
      <input
        class="msg-input"
        value="{{inputValue}}"
        placeholder="想了解什么，问问房东吧..."
        placeholder-class="msg-input__placeholder"
        bindinput="onInputChange"
        confirm-type="send"
        bindconfirm="onSendTap"
      />
    </view>
    <button
      wx:if="{{canSend}}"
      class="send-btn"
      loading="{{sending}}"
      disabled="{{sending || uploadingImage}}"
      bindtap="onSendTap"
    >发送</button>
    <button
      wx:else
      class="plus-btn"
      loading="{{uploadingImage}}"
      disabled="{{sending || uploadingImage}}"
      bindtap="onChooseImageTap"
    >+</button>
  </view>
</view>
