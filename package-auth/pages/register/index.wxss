@import "../../styles/auth-form.wxss";

.role-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.role-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 180rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #f7f8fa;
  color: var(--color-text-1);
  font-size: 28rpx;
  font-weight: var(--weight-medium);
}

.role-item.active {
  background: rgba(60, 123, 253, 0.1);
  color: var(--color-primary);
}
