@import "../../styles/variables.wxss";

.home-page {
  min-height: 100vh;
  background: var(--color-background-page);
}

.home-top-bar {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 110;
  padding: 0 var(--page-padding) 20rpx;
  background: var(--color-background-card);
  border-bottom: var(--line-width-hairline) solid var(--color-border);
}

.home-top-bar-dropdown-open {
  box-shadow: none;
}

.home-scroll {
  height: 100vh;
}

.home-content {
  padding: 0 var(--page-padding) calc(var(--space-3xl) + env(safe-area-inset-bottom));
}

.topbar {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding-top: var(--space-xs);
  padding-bottom: var(--space-xs);
}

.city-pill {
  display: flex;
  align-items: center;
  gap: var(--space-2xs);
  padding: 0 var(--space-md);
  height: var(--control-height-md);
  border-radius: var(--radius-pill);
  background: var(--color-background-page);
  border: var(--line-width-thin) solid var(--color-border);
  flex-shrink: 0;
  transition: all var(--duration-fast);
}

.city-pill:active {
  background: var(--color-primary-bg);
  border-color: var(--color-primary);
}

.city-dot {
  width: 14rpx;
  height: 14rpx;
  flex-shrink: 0;
  border-radius: var(--radius-pill);
  background: var(--color-success);
}

.city-name {
  max-width: 132rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: var(--font-label);
  font-weight: var(--weight-bold);
  color: var(--color-text-1);
}

.city-chev,
.filter-chip-arrow {
  color: var(--color-text-3);
  font-size: var(--font-xs);
}

.search-bar {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: var(--space-2xs);
  padding: 0 var(--space-md);
  height: var(--control-height-md);
  border-radius: var(--radius-pill);
  background: var(--color-background-page);
  border: var(--line-width-thin) solid var(--color-border);
}

.search-icon {
  flex-shrink: 0;
  color: var(--color-text-3);
  font-size: var(--font-lg);
  line-height: 1;
}

.search-input {
  flex: 1;
  height: var(--control-height-md);
  min-height: var(--control-height-md);
  line-height: var(--control-height-md);
  padding: 0;
  font-size: var(--font-label);
  color: var(--color-text-1);
}

.search-placeholder {
  color: var(--color-text-3);
  font-size: var(--font-label);
  line-height: var(--control-height-md);
}

.filter-bar {
  width: 100%;
  margin-top: 16rpx;
}

.filter-bar-track {
  display: flex;
  align-items: center;
  min-width: 100%;
  padding: 6rpx 0 4rpx;
  box-sizing: border-box;
  white-space: nowrap;
}

.filter-bar-main {
  display: flex;
  align-items: center;
  flex: 0 0 auto;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2xs);
  min-height: 56rpx;
  margin-right: var(--space-xs);
  padding: 0 22rpx;
  border: var(--line-width-thin) solid var(--color-border);
  border-radius: var(--radius-pill);
  background: var(--color-background-subtle);
  color: var(--color-text-2);
  font-size: var(--font-sm-plus);
  font-weight: var(--weight-medium);
  box-shadow: none;
}

.filter-chip-filter {
  margin-right: 0;
  margin-left: auto;
  padding: 0 24rpx;
  flex-shrink: 0;
}

.filter-chip-icon {
  width: 26rpx;
  height: 26rpx;
  flex-shrink: 0;
  background-color: currentColor;
  -webkit-mask-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M4 6H20M7 12H17M10 18H14' stroke='black' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  -webkit-mask-size: contain;
  -webkit-mask-repeat: no-repeat;
  -webkit-mask-position: center;
}

.filter-chip-active {
  border-color: var(--color-primary);
  background: var(--color-primary);
  color: var(--color-text-inverse);
}

.filter-chip-active .filter-chip-arrow {
  color: var(--color-text-inverse);
}

.filter-dropdown-layer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  background: transparent;
}

.filter-dropdown-mask {
  position: absolute;
  inset: 0;
  opacity: 0;
  background: var(--overlay-bg);
  transition: opacity 0.22s ease;
}

.filter-dropdown-mask-visible {
  opacity: 1;
}

.filter-dropdown-panel {
  position: relative;
  width: 100%;
  padding: 0;
  transform: translateY(-20rpx);
  opacity: 0;
  transition:
    transform 0.22s ease,
    opacity 0.22s ease;
}

.filter-dropdown-panel-entered {
  transform: translateY(0);
  opacity: 1;
}

.filter-dropdown-sheet {
  width: 100%;
  overflow: hidden;
  border-radius: 0 0 28rpx 28rpx;
  background: var(--color-background-card);
  box-shadow: var(--shadow-card-raised);
}

.filter-dropdown-content {
  max-height: 580rpx;
  overflow: hidden;
}

.filter-dropdown-section {
  padding: 28rpx var(--space-lg) 24rpx;
}

.filter-dropdown-title {
  margin-bottom: var(--space-md);
  color: var(--color-text-1);
  font-size: var(--font-sm);
  font-weight: var(--weight-heavy);
}

.filter-option-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.price-range-form {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.price-input-box {
  flex: 1;
  display: flex;
  align-items: center;
  min-height: 84rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  background: var(--color-background-subtle);
  box-sizing: border-box;
  box-shadow: inset 0 0 0 2rpx transparent;
}

.price-input-box-filled {
  background: var(--color-primary-bg);
  box-shadow: inset 0 0 0 var(--line-width-thin) var(--color-primary);
}

.price-input {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  padding: 0;
  color: var(--color-text-1);
  font-size: var(--font-sm);
  font-weight: var(--weight-bold);
}

.price-input-unit {
  flex-shrink: 0;
  margin-left: var(--space-xs);
  color: var(--color-text-3);
  font-size: var(--font-xs);
}

.price-range-divider {
  flex-shrink: 0;
  color: var(--color-text-3);
  font-size: var(--font-sm);
  font-weight: var(--weight-bold);
}

.price-range-hint {
  margin-top: 14rpx;
  color: var(--color-text-3);
  font-size: var(--font-xs);
  line-height: var(--lh-normal);
}

.filter-option-tag {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: calc((100% - 32rpx) / 3);
  min-height: 76rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  border-radius: 20rpx;
  background: var(--color-background-subtle);
  color: var(--color-text-2);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  text-overflow: ellipsis;
  white-space: nowrap;
  transition:
    background 0.18s ease,
    color 0.18s ease,
    border-color 0.18s ease;
}

.filter-option-tag-active {
  border-color: var(--color-primary);
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

.filter-option-tag-text {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-dropdown-actions {
  display: flex;
  gap: 16rpx;
  padding: 20rpx var(--space-lg) calc(24rpx + env(safe-area-inset-bottom));
  border-top: var(--line-width-thin) solid var(--color-border);
  background: var(--color-background-card);
}

.dropdown-action-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 84rpx;
  margin: 0;
  border-radius: 22rpx;
  font-size: var(--font-sm);
  font-weight: var(--weight-heavy);
}

.dropdown-action-btn::after {
  border: none;
}

.dropdown-action-btn-secondary {
  flex: 4;
  background: var(--color-background-subtle);
  color: var(--color-text-2);
  box-shadow: none;
}

.dropdown-action-btn-primary {
  flex: 6;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  box-shadow: var(--shadow-primary-soft);
}

.error-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  padding: var(--card-padding);
  margin-top: var(--space-lg);
  border-radius: var(--radius-lg);
  background: var(--color-danger-bg);
}

.error-box__text {
  flex: 1;
  color: var(--color-danger);
  font-size: var(--font-sm);
  line-height: var(--lh-normal);
}

.error-box__retry {
  min-width: 120rpx;
  min-height: var(--control-height-sm);
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 var(--space-md);
  border-radius: var(--radius-pill);
  background: var(--color-background-card);
  color: var(--color-danger);
  font-size: var(--font-caption);
  font-weight: var(--weight-bold);
}

.error-box__retry::after {
  border: none;
}

.content-section {
  margin-top: var(--space-lg);
}

.latest-section {
  margin-top: var(--space-sm);
}

.section-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-2xs) 0 var(--space-lg);
}

.section-heading-title {
  color: var(--color-text-1);
  font-size: var(--font-title-xs);
  font-weight: var(--weight-heavy);
}

.section-heading-link,
.section-heading-count {
  color: var(--color-text-3);
  font-size: var(--font-sm);
}

.section-heading-link {
  padding: 0;
  background: transparent;
  box-shadow: none;
}

.featured-row {
  display: flex;
  align-items: flex-start;
  width: 100%;
  white-space: nowrap;
  padding-right: var(--space-xs);
  padding-bottom: var(--space-2xs);
}

.featured-card {
  display: inline-block;
  align-self: flex-start;
  width: var(--card-width-featured);
  margin-right: var(--space-md);
  border-radius: var(--radius-xl);
  overflow: hidden;
  background: var(--color-background-card);
  box-shadow: var(--shadow-card-raised);
  vertical-align: top;
  transform: scale(1);
  transition: transform var(--duration-fast);
}

.card-active {
  transform: scale(0.98) !important;
  opacity: 0.95;
}

.featured-thumb-wrap,
.latest-card-thumb-wrap {
  position: relative;
  overflow: hidden;
}

.featured-thumb-wrap {
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  background: var(--color-background-subtle);
}

.featured-thumb,
.latest-card-thumb {
  display: block;
  width: 100%;
}

.featured-thumb-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background: var(--gradient-image-featured-overlay);
}
.featured-badge {
  position: absolute;
  left: var(--space-md);
  top: var(--space-md);
  z-index: 2;
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 var(--space-sm);
  border-radius: var(--radius-pill);
  border: 1rpx solid var(--color-glass-border-light);
  color: var(--color-text-inverse);
  font-size: var(--font-caption);
  font-weight: var(--weight-heavy);
  line-height: 1;
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
}

.featured-badge-red {
  background: var(--color-featured-badge-hot);
}

.featured-badge-blue {
  background: var(--color-featured-badge-metro);
}

.featured-badge-green {
  background: var(--color-featured-badge-quality);
}

.featured-body {
  padding: 18rpx var(--space-md) var(--space-md);
}

.featured-price,
.latest-card-price {
  display: flex;
  align-items: flex-end;
  gap: var(--space-2xs);
}

.featured-price {
  margin-bottom: 8rpx;
}

.featured-price-main {
  color: var(--color-price-highlight);
  font-size: var(--font-price-lg);
  font-weight: var(--weight-heavy);
  letter-spacing: -1rpx;
}

.latest-card-price-main {
  color: var(--color-price-highlight);
  font-size: var(--font-price-md);
  font-weight: var(--weight-heavy);
  letter-spacing: -1rpx;
}

.featured-price-unit,
.latest-card-price-unit {
  padding-bottom: var(--space-3xs);
  color: var(--color-text-3);
  font-size: var(--font-xs-plus);
}

.featured-title {
  margin-top: 0;
  margin-bottom: 10rpx;
  min-height: var(--featured-card-title-min-height);
  color: var(--color-text-1);
  font-size: var(--font-sm-plus);
  font-weight: var(--weight-medium);
  line-height: 1.4;
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.featured-meta {
  display: flex;
  align-items: center;
  gap: var(--space-2xs);
  flex-wrap: wrap;
}

.featured-meta {
  margin-top: 0;
}

.featured-meta-item {
  color: var(--color-text-3);
  font-size: var(--font-caption);
  line-height: var(--lh-normal);
}

.featured-meta-dot,
.latest-card-meta-dot {
  width: 4rpx;
  height: 4rpx;
  border-radius: var(--radius-pill);
  background: var(--color-border-strong);
  flex-shrink: 0;
}

.divider {
  height: 8rpx;
  margin-top: var(--space-lg);
  border-radius: var(--radius-pill);
  background: var(--color-background-muted);
}

.latest-heading {
  padding-top: var(--space-2xs);
}

.sort-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 0 var(--space-sm);
}

.sort-tab {
  padding: 10rpx 28rpx;
  border-radius: var(--radius-pill);
  text-align: center;
  color: var(--color-text-2);
  font-size: var(--font-sm-plus);
  font-weight: var(--weight-medium);
  border: var(--line-width-thin) solid var(--color-border);
  background: var(--color-background-card);
}

.sort-tab-active {
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-color: var(--color-primary);
  font-weight: var(--weight-heavy);
  box-shadow: var(--shadow-primary-soft);
}

.latest-list {
  margin-top: 20rpx;
}

.latest-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx;
  margin-bottom: var(--space-lg);
  border-radius: var(--radius-2xl);
  background: var(--color-background-card);
  box-shadow: var(--shadow-card-raised);
  transform: scale(1);
  transition: transform var(--duration-fast);
}

.latest-card-thumb-wrap {
  width: var(--listing-card-thumb-width);
  height: var(--listing-card-thumb-height);
  flex-shrink: 0;
  overflow: hidden;
  border-radius: var(--radius-lg);
  background: var(--color-background-subtle);
}

.latest-card-body {
  flex: 1;
  min-width: 0;
  min-height: var(--listing-card-thumb-height);
  display: flex;
  flex-direction: column;
}

.latest-card-title {
  color: var(--color-text-1);
  font-size: var(--font-title-sm);
  font-weight: var(--weight-bold);
  line-height: var(--lh-snug);
}

.latest-card-meta {
  display: flex;
  align-items: center;
  gap: var(--space-2xs);
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.latest-card-meta-item {
  color: var(--color-text-2);
  font-size: var(--font-sm);
  line-height: var(--lh-normal);
}

.latest-card-address {
  margin-top: 8rpx;
  color: var(--color-text-3);
  font-size: var(--font-sm);
  line-height: var(--lh-normal);
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.latest-card-footer {
  margin-top: auto;
  padding-top: var(--space-md);
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 10rpx 14rpx;
}

.latest-card-time {
  color: var(--color-text-3);
  font-size: var(--font-caption);
  line-height: var(--lh-normal);
}

.loading-tip {
  padding: var(--space-lg) 0;
  color: var(--color-text-3);
  font-size: var(--font-caption);
  text-align: center;
}
