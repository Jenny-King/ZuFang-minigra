.publish-page {
  min-height: 100vh;
}

.form-card {
  padding: 24rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 20rpx;
}

.label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 26rpx;
  color: #333333;
}

.helper-text {
  font-size: 22rpx;
  color: #999999;
}

.input {
  height: 72rpx;
  border: 2rpx solid #ececec;
  border-radius: 8rpx;
  padding: 0 18rpx;
  font-size: 28rpx;
  background: #ffffff;
}

.textarea {
  width: 100%;
  min-height: 180rpx;
  border: 2rpx solid #ececec;
  border-radius: 8rpx;
  padding: 18rpx;
  font-size: 28rpx;
  background: #ffffff;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  background: #f5f5f5;
}

.remove-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  background: #ff4d4f;
  color: #ffffff;
  font-size: 20rpx;
  text-align: center;
  line-height: 36rpx;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #999999;
}

.submit-btn {
  margin-top: 30rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #1677ff;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 30rpx;
}