@import "../../styles/variables.wxss";

.chat-page {
  min-height: 100vh;
  background: #f8f8f8;
}

.error-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  padding: var(--card-padding);
  margin-bottom: var(--space-lg);
  border-radius: var(--radius-sm);
  background: var(--color-danger-bg);
}

.error-box__text {
  color: var(--color-danger);
  font-size: var(--font-sm);
}

.error-box__retry {
  min-height: var(--control-height-sm);
  margin: 0;
  padding: 0 var(--space-md);
  border-radius: var(--radius-pill);
  background: var(--color-background-card);
  color: var(--color-danger);
  font-size: var(--font-caption);
}

.error-box__retry::after {
  border: none;
}

.chat-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.chat-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-md);
  padding: 30rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.avatar {
  width: var(--avatar-size-lg);
  flex-shrink: 0;
}

.content {
  flex: 1;
  min-width: 0;
}

.top-row,
.bottom-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.top-row {
  margin-bottom: 10rpx;
}

.house-row {
  display: flex;
  gap: var(--space-sm);
  align-items: center;
  padding: 12rpx 0 14rpx;
}

.house-cover {
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
  border-radius: 8rpx;
  background: var(--color-background-subtle);
}

.house-content {
  flex: 1;
  min-width: 0;
}

.house-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-xs);
}

.house-title {
  flex: 1;
  min-width: 0;
  color: var(--color-text-1);
  font-size: 24rpx;
  font-weight: var(--weight-medium);
}

.house-price {
  flex-shrink: 0;
  color: var(--color-primary);
  font-size: var(--font-caption);
}

.house-meta {
  display: block;
  margin-top: var(--space-2xs);
  color: var(--color-text-3);
  font-size: var(--font-caption);
}

.name {
  flex: 1;
  min-width: 0;
  color: var(--color-text-1);
  font-size: 32rpx;
  font-weight: var(--weight-medium);
}

.time {
  margin-left: var(--space-xs);
  color: #999999;
  font-size: 24rpx;
}

.message {
  flex: 1;
  min-width: 0;
  color: var(--color-text-2);
  font-size: 24rpx;
}

.badge {
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 var(--space-2xs);
  margin-left: var(--space-xs);
  border-radius: var(--radius-pill);
  background: var(--color-danger);
  color: var(--color-text-inverse);
  font-size: var(--font-caption);
  text-align: center;
}
