.favorites-page {
  min-height: 100vh;
  padding-bottom: var(--radius-2xl);
}

.favorites-page.highlight .listing-card {
  box-shadow: var(--shadow-focus), var(--shadow-card-raised);
}

.error-box {
  padding: var(--space-md);
  margin-bottom: var(--space-md);
  border-radius: var(--radius-sm);
  color: var(--color-danger);
  background: var(--color-danger-bg);
  font-size: var(--font-sm);
}

.fav-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.listing-card {
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-2xl);
  background: var(--color-background-card);
  box-shadow: var(--shadow-card-raised);
}

.card-inner {
  position: relative;
  z-index: 2;
  background: var(--color-background-card);
  transition: transform var(--duration-normal) var(--easing-standard);
}

.listing-card.swiped .card-inner {
  transform: translateX(-104rpx);
}

.listing-body {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx;
}

.cover {
  display: block;
  flex: 0 0 var(--image-thumb-collection-width);
  width: var(--image-thumb-collection-width);
  height: var(--image-thumb-collection-height);
  border-radius: var(--radius-lg);
  background: var(--color-background-subtle);
}

.main {
  flex: 1;
  min-width: 0;
  min-height: var(--image-thumb-collection-height);
  display: flex;
  flex-direction: column;
}

.title {
  font-size: var(--font-title-sm);
  color: var(--color-text-1);
  font-weight: var(--weight-bold);
  line-height: var(--lh-snug);
}

.meta {
  margin-top: 10rpx;
  font-size: var(--font-sm);
  color: var(--color-text-2);
}

.address {
  margin-top: 8rpx;
  font-size: var(--font-sm);
  line-height: var(--lh-normal);
  color: var(--color-text-3);
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.footer {
  margin-top: auto;
  padding-top: var(--space-md);
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 10rpx 14rpx;
}

.price {
  color: var(--color-price-highlight);
  font-size: var(--font-price-md);
  font-weight: var(--weight-heavy);
  line-height: 1;
  white-space: nowrap;
}

.time {
  color: var(--color-text-3);
  font-size: var(--font-caption);
  line-height: var(--lh-normal);
}

.swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: stretch;
  width: 88rpx;
  z-index: 1;
}

.swipe-btn {
  flex: 0 0 88rpx;
  width: 88rpx;
  height: auto;
  align-self: stretch;
  margin: 0;
  padding: 0;
  border-radius: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--color-text-inverse);
  text-align: center;
  box-sizing: border-box;
}

.swipe-btn-char {
  display: block;
  font-size: var(--font-md);
  font-weight: var(--weight-medium);
  line-height: 1;
  color: inherit;
}

.swipe-btn-char + .swipe-btn-char {
  margin-top: 8rpx;
}

.swipe-delete {
  background: var(--color-danger);
}

.loading-tip {
  text-align: center;
  color: var(--color-text-3);
  font-size: var(--font-sm);
  padding: 22rpx 0;
}
