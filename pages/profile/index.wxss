.profile-page {
  min-height: 100vh;
  padding-bottom: 24rpx;
  background: #f5f5f7;
}

.hero-card {
  padding: 28rpx 0 0;
  margin-bottom: 24rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(160deg, #2f64f5 0%, #1f4fd7 100%);
  color: #ffffff;
  box-shadow: 0 24rpx 48rpx rgba(31, 79, 215, 0.24);
}

.hero-top {
  padding: 0 28rpx;
}

.hero-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.hero-avatar-wrap {
  position: relative;
  width: 108rpx;
  height: 108rpx;
  flex-shrink: 0;
}

.hero-avatar {
  width: 100%;
  height: 100%;
  border-radius: 54rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.34);
  background: rgba(255, 255, 255, 0.12);
}

.avatar-mask {
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  bottom: 8rpx;
  height: 34rpx;
  line-height: 34rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 18rpx;
  color: #ffffff;
  background: rgba(17, 25, 67, 0.45);
}

.hero-content {
  flex: 1;
  min-width: 0;
}

.hero-name {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.2;
  color: #ffffff;
}

.hero-subline {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.72);
}

.hero-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 18rpx 28rpx 16rpx;
}

.badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1;
  color: #ffffff;
}

.badge.role.landlord {
  background: rgba(255, 255, 255, 0.2);
}

.badge.role.tenant {
  background: rgba(255, 255, 255, 0.14);
}

.badge.role.admin {
  background: rgba(255, 120, 117, 0.24);
}

.badge.identity.verified {
  background: rgba(251, 191, 36, 0.22);
  color: #fbbf24;
}

.badge.identity.pending {
  background: rgba(251, 191, 36, 0.22);
  color: #fbbf24;
}

.badge.identity.idle {
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.78);
}

.badge.wechat.bound {
  background: rgba(91, 219, 143, 0.18);
  color: #c9ffd8;
}

.badge.wechat.unbound {
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.66);
}

.badge-icon {
  font-size: 18rpx;
}

.badge-dot {
  font-size: 16rpx;
}

.hero-stats {
  display: flex;
  background: rgba(0, 0, 0, 0.14);
}

.stat-card {
  position: relative;
  flex: 1;
  min-width: 0;
  padding: 22rpx 12rpx 18rpx;
  text-align: center;
}

.stat-card + .stat-card {
  border-left: 1rpx solid rgba(255, 255, 255, 0.12);
}

.stat-card.active {
  background: rgba(255, 255, 255, 0.08);
}

.stat-number {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1;
  color: #ffffff;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.68);
}

.stat-badge {
  position: absolute;
  top: 12rpx;
  right: 50%;
  transform: translateX(34rpx);
  min-width: 24rpx;
  padding: 0 6rpx;
  height: 24rpx;
  line-height: 24rpx;
  border-radius: 999rpx;
  background: #ef4444;
  color: #ffffff;
  font-size: 16rpx;
  font-weight: 700;
}

.guest-card {
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  border-radius: 28rpx;
}

.guest-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.guest-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #666666;
}

.auth-actions {
  margin-top: 20rpx;
  display: flex;
  gap: 12rpx;
}

.auth-btn {
  margin: 0;
  border-radius: 999rpx;
  background: #f2f4f8;
  color: #333333;
}

.auth-btn.primary {
  background: #2f64f5;
  color: #ffffff;
}

.section-card {
  margin-top: 10rpx;
  background: #ffffff;
  border-radius: 28rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  min-height: 108rpx;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  margin-right: 18rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon.amber {
  background: #fffbeb;
  color: #d97706;
}

.menu-icon.purple {
  background: #f3f0ff;
  color: #7c3aed;
}

.menu-icon.red {
  background: #fff1f0;
  color: #ef4444;
}

.menu-icon-text {
  font-size: 26rpx;
  font-weight: 700;
}

.menu-main {
  flex: 1;
  min-width: 0;
}

.menu-title {
  font-size: 28rpx;
  color: #1f1f1f;
  font-weight: 600;
}

.menu-subtitle {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.5;
}

.arrow {
  margin-left: 12rpx;
  color: #c7c7cc;
  font-size: 28rpx;
}

.account-section {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  background: #ffffff;
  border-radius: 28rpx;
}

.account-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.account-section-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #9ca3af;
}

.account-section-action {
  font-size: 22rpx;
  color: #2563eb;
}

.account-scroll {
  width: 100%;
  white-space: nowrap;
}

.account-inline-list {
  display: inline-flex;
  align-items: flex-start;
  gap: 18rpx;
}

.account-inline-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  width: 96rpx;
}

.account-inline-avatar,
.account-inline-add {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.account-inline-avatar {
  background: #eff6ff;
  border: 4rpx solid transparent;
}

.account-inline-avatar.active {
  border-color: #2563eb;
}

.account-inline-image {
  width: 100%;
  height: 100%;
}

.account-inline-add {
  border: 2rpx dashed #d1d5db;
  background: #f5f5f7;
  color: #9ca3af;
  font-size: 40rpx;
  line-height: 1;
}

.account-inline-name {
  width: 100%;
  font-size: 18rpx;
  color: #374151;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.account-inline-name.active {
  color: #2563eb;
}

.account-inline-name.dim {
  color: #c4c4c6;
}

.logout-wrap {
  margin-top: 20rpx;
}

.logout-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  margin: 0;
  border: none;
  border-radius: 24rpx;
  background: #fff1f0;
  color: #ef4444;
  font-size: 28rpx;
  font-weight: 600;
}

.account-switcher-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 99;
  display: flex;
  align-items: flex-end;
  background: rgba(11, 19, 43, 0.4);
}

.account-switcher-panel {
  width: 100%;
  padding: 30rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 36rpx 36rpx 0 0;
  background: linear-gradient(180deg, #fbfcff 0%, #f4f7ff 100%);
  box-shadow: 0 -16rpx 36rpx rgba(15, 41, 114, 0.12);
}

.account-switcher-header {
  margin-bottom: 24rpx;
}

.account-switcher-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.account-switcher-subtitle {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7f8797;
}

.account-card-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.account-card {
  position: relative;
  display: flex;
  align-items: center;
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 2rpx solid transparent;
  box-shadow: 0 10rpx 24rpx rgba(26, 47, 106, 0.06);
}

.account-card.active {
  border-color: #bfd1ff;
  background: linear-gradient(180deg, #ffffff 0%, #f4f8ff 100%);
  box-shadow: 0 14rpx 28rpx rgba(47, 100, 245, 0.12);
}

.account-card-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 46rpx;
  background: #eef2f8;
  flex-shrink: 0;
}

.account-card-remove {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #ff5a5f;
  background: #fff1f1;
}

.account-card-main {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.account-card-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.account-card-name {
  max-width: 320rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f1f1f;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.account-card-role {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #2f64f5;
  background: #edf3ff;
}

.account-card-subline {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #7f8797;
}

.account-card-tags {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.account-card-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #6e7788;
  background: #f5f7fb;
}

.account-card-tag.active {
  color: #2f64f5;
  background: #edf3ff;
}

.account-switcher-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.account-switcher-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  margin: 0;
  border-radius: 20rpx;
  background: #ffffff;
  color: #1f1f1f;
  border: 2rpx solid #dfe3eb;
  font-size: 28rpx;
}

.account-switcher-btn.primary {
  color: #ffffff;
  background: #2f64f5;
  border-color: #2f64f5;
}
