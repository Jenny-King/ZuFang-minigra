@import "../../styles/variables.wxss";

.profile-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  background: var(--color-background-muted);
}

.profile-loading {
  margin: var(--space-md);
  padding: var(--card-padding);
  background: var(--color-background-card);
  border-radius: var(--radius-xl);
}

/* Hero */
.hero {
  padding-top: 88rpx;
  background: var(--gradient-brand);
  position: relative;
  overflow: visible;
  flex-shrink: 0;
  padding-bottom: 0;
  height: 441rpx;
  display: block;
  box-sizing: border-box;
  left: 0rpx;
  top: 0rpx;
}
.hero::before {
  content: '';
  position: absolute;
  width: 520rpx;
  height: 520rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  top: -160rpx;
  right: -120rpx;
  pointer-events: none;
}
.hero::after {
  content: '';
  position: absolute;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.04);
  bottom: -100rpx;
  left: -40rpx;
  pointer-events: none;
}
.hero-main {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 44rpx 40rpx 28rpx;
  position: relative;
  z-index: 1;
  position: relative;
  left: 0rpx;
  top: -87rpx;
}
.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}
.avatar {
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.18);
  background: linear-gradient(135deg, #93c5fd, #3b82f6);
}
.hero-info {
  flex: 1;
  min-width: 0;
}
.hero-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.hero-name-row:active {
  opacity: 0.8;
}
.hero-name {
  font-size: var(--font-xl);
  font-weight: var(--weight-heavy);
  color: var(--color-text-inverse);
  letter-spacing: 0.6rpx;
}
.hero-chevron {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.8);
}
.hero-phone {
  font-size: var(--font-label);
  color: rgba(255, 255, 255, 0.7);
  margin-top: 6rpx;
}
.badges {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 40rpx 24rpx;
  position: relative;
  z-index: 1;
  flex-wrap: wrap;
  position: relative;
  left: 0rpx;
  top: -107rpx;
}
.badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 18rpx;
  border-radius: var(--radius-pill);
  font-size: var(--font-caption);
  font-weight: var(--weight-bold);
  border: 2rpx solid transparent;
}
.badge-role {
  background: rgba(255, 255, 255, 0.18);
  color: var(--color-text-inverse);
  border-color: rgba(255, 255, 255, 0.28);
}
.badge-warn {
  background: var(--color-warning-bg);
  color: #92400e;
  border-color: #fde68a;
}
.badge-muted {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.55);
  border-color: rgba(255, 255, 255, 0.15);
}

/* Stats 3-col inline row */
.stats-row {
  display: flex;
  margin: 0 32rpx 24rpx;
  background: rgba(255, 255, 255, 0.14);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-xl);
  overflow: hidden;
  position: relative;
  z-index: 1;
  position: relative;
  left: 0rpx;
  top: -107rpx;
}
.stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 26rpx 12rpx;
  position: relative;
}
.stat-favorites {
  position: relative;
  left: 0rpx;
  top: 2rpx;
}
.stat-notifications {
  position: relative;
  left: 0rpx;
  top: 2rpx;
}
.stat:active {
  background: rgba(255, 255, 255, 0.08);
}
.stat + .stat::before {
  content: '';
  position: absolute;
  left: 0;
  top: 16%;
  bottom: 16%;
  width: 2rpx;
  background: rgba(255, 255, 255, 0.2);
}
.stat-num {
  font-size: var(--font-xl);
  font-weight: var(--weight-heavy);
  color: var(--color-text-inverse);
  letter-spacing: -0.6rpx;
}
.stat-label {
  font-size: var(--font-caption);
  color: rgba(255, 255, 255, 0.7);
  margin-top: 6rpx;
  font-weight: var(--weight-medium);
}
.stat-badge {
  position: absolute;
  top: 24rpx;
  right: 50%;
  transform: translateX(48rpx);
  min-width: 28rpx;
  padding: 0 8rpx;
  height: 28rpx;
  line-height: 28rpx;
  border-radius: var(--radius-pill);
  background: var(--color-danger);
  color: var(--color-text-inverse);
  font-size: 16rpx;
  font-weight: var(--weight-heavy);
}

/* Scroll area */
.page-scroll {
  flex: 1;
  padding-bottom: 0;
}

/* Sections -> Card groups */
.card-group {
  margin: 24rpx 0 0;
  background: var(--color-background-card);
  border-radius: 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06), 0 0 0 1rpx rgba(0,0,0,0.04);
  overflow: hidden;
}
.card-group + .card-group {
  margin-top: 20rpx;
}
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx 20rpx;
  border-bottom: 2rpx solid var(--color-border);
}
.card-header-title {
  font-size: var(--font-label);
  font-weight: var(--weight-bold);
  color: var(--color-text-3);
  letter-spacing: 0.8rpx;
}
.card-header-action {
  font-size: var(--font-label);
  color: var(--color-primary);
  font-weight: var(--weight-medium);
}

/* Appointments Preview */
.appt-preview-list {
  display: flex;
  flex-direction: column;
}
.appt-preview-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 26rpx 28rpx 28rpx;
}
.appt-preview-item + .appt-preview-item {
  border-top: 2rpx solid var(--color-border);
}
.appt-preview-item:active {
  background: var(--color-background-subtle);
}
.appt-preview-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #d9ecff 0%, #c5e0ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.appt-preview-icon-image {
  width: 42rpx;
  height: 42rpx;
}
.appt-preview-main {
  flex: 1;
  min-width: 0;
}
.appt-preview-title {
  display: block;
  color: var(--color-text-1);
  font-size: var(--font-title-sm);
  font-weight: var(--weight-heavy);
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.appt-preview-subtitle {
  display: block;
  margin-top: 8rpx;
  color: var(--color-text-3);
  font-size: var(--font-caption);
  line-height: 1.5;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.appt-preview-status {
  flex-shrink: 0;
  margin-left: 8rpx;
  font-size: var(--font-caption);
  font-weight: var(--weight-bold);
  color: var(--color-warning);
}
.appt-preview-status.pending {
  color: var(--color-warning);
}
.appt-preview-status.confirmed {
  color: var(--color-success);
}
.appt-preview-status.rejected,
.appt-preview-status.cancelled {
  color: var(--color-text-3);
}
.appt-preview-status.rescheduled {
  color: var(--color-info);
}

/* Appointments Empty State */
.appt-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 44rpx 32rpx 40rpx;
  gap: 16rpx;
  height: 222rpx;
  display: flex;
  box-sizing: border-box;
}
.appt-empty-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-lg);
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}
.appt-empty-icon-text {
  font-size: var(--font-xl);
  color: var(--color-primary);
  font-weight: var(--weight-bold);
}
.appt-empty-text {
  font-size: var(--font-label);
  color: var(--color-text-3);
}
.appt-empty-btn {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  padding: 0 44rpx;
  border-radius: var(--radius-pill);
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: var(--font-label);
  font-weight: var(--weight-bold);
  border: none;
  line-height: normal;
}
.appt-empty-btn::after {
  border: none;
}

/* Menu */
.menu-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 26rpx 28rpx;
  position: relative;
}
.menu-item:active {
  background: var(--color-background-subtle);
}
.menu-item + .menu-item {
  border-top: 2rpx solid var(--color-border);
}
.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.menu-icon.bg-blue {
  background: linear-gradient(135deg, #3b82f6, #1d4ed8);
}
.menu-icon.bg-purple {
  background: linear-gradient(135deg, #8b5cf6, #6d28d9);
}
.menu-icon.bg-orange {
  background: linear-gradient(135deg, #f59e0b, #d97706);
}
.menu-icon-svg {
  width: 44rpx;
  height: 44rpx;
  background-color: var(--color-text-inverse);
  -webkit-mask-size: contain;
  -webkit-mask-repeat: no-repeat;
  -webkit-mask-position: center;
}
.icon-support {
  -webkit-mask-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M3 18v-6a9 9 0 0 1 18 0v6'/%3E%3Cpath d='M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z'/%3E%3C/svg%3E");
}
.icon-settings {
  -webkit-mask-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='12' cy='12' r='3'/%3E%3Cpath d='M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z'/%3E%3C/svg%3E");
}
.icon-switch-role {
  -webkit-mask-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M17 1l4 4-4 4'/%3E%3Cpath d='M3 11V9a4 4 0 0 1 4-4h14'/%3E%3Cpath d='M7 23l-4-4 4-4'/%3E%3Cpath d='M21 13v2a4 4 0 0 1-4 4H3'/%3E%3C/svg%3E");
}
.menu-text {
  flex: 1;
}
.menu-title {
  font-size: var(--font-title-sm);
  font-weight: var(--weight-bold);
  color: var(--color-text-1);
}
.menu-sub {
  font-size: var(--font-caption);
  color: var(--color-text-3);
  margin-top: 4rpx;
}
.menu-tag {
  font-size: var(--font-caption);
  font-weight: var(--weight-bold);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-pill);
  background: var(--color-success-bg);
  color: var(--color-success);
  margin-right: 8rpx;
}
.menu-arrow {
  font-size: var(--font-title-sm);
  color: var(--color-text-3);
  font-family: monospace;
}


/* Logout */
.logout-wrap {
  padding: 20rpx 24rpx 28rpx;
}
.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 92rpx;
  background: var(--color-background-card);
  border: 3rpx solid #fecaca !important;
  border-radius: var(--radius-xl);
  color: var(--color-danger);
  font-size: var(--font-title-sm);
  font-weight: var(--weight-bold);
  line-height: normal;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.logout-btn::after {
  display: none;
}
.logout-btn:active {
  background: #fef2f2;
}

/* Guest Card */
.guest-card {
  margin: 32rpx;
  padding: var(--space-xl) var(--space-lg);
  border-radius: var(--radius-xl);
  background: var(--color-background-card);
  box-shadow: var(--shadow-card);
}
.guest-title {
  color: var(--color-text-1);
  font-size: var(--font-xl);
  font-weight: var(--weight-heavy);
}
.guest-subtitle {
  margin-top: var(--space-xs);
  color: var(--color-text-2);
  font-size: var(--font-sm);
}
.auth-actions {
  display: flex;
  gap: var(--space-xs);
  margin-top: var(--space-md);
}
.auth-btn {
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  padding: 0 28rpx;
  border-radius: var(--radius-pill);
  background: var(--color-background-subtle);
  color: var(--color-text-1);
}
.auth-btn.primary {
  background: var(--color-primary);
  color: var(--color-text-inverse);
}

/* Account Switcher Mask */
.account-switcher-mask {
  position: fixed;
  inset: 0;
  z-index: 99;
  display: flex;
  align-items: flex-end;
  background: var(--overlay-bg);
}

.account-switcher-panel {
  width: 100%;
  padding: var(--space-xl) var(--space-lg) calc(var(--space-lg) + env(safe-area-inset-bottom));
  border-radius: var(--radius-panel) var(--radius-panel) 0 0;
  background: var(--color-background-page);
  box-shadow: var(--shadow-float);
}

.account-switcher-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: var(--space-lg);
}

.account-switcher-title {
  color: var(--color-text-1);
  font-size: var(--font-xl);
  font-weight: var(--weight-heavy);
}

.account-switcher-subtitle {
  margin-top: var(--space-2xs);
  color: var(--color-text-2);
  font-size: var(--font-caption);
}

.tap-area {
  min-width: 88rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.account-switcher-close {
  color: var(--color-text-2);
  font-size: var(--font-xl);
}

.account-card-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.account-card {
  position: relative;
  display: flex;
  align-items: center;
  padding: var(--space-md);
  border: var(--line-width-hairline) solid transparent;
  border-radius: var(--radius-lg);
  background: var(--color-background-card);
}

.account-card.active {
  background: var(--color-primary-bg);
  border: var(--line-width-hairline) solid var(--color-primary);
}

.account-card-remove {
  position: absolute;
  top: var(--space-sm);
  right: var(--space-sm);
  padding: var(--space-2xs) var(--space-xs);
  border-radius: var(--radius-pill);
  background: var(--color-danger-bg);
  color: var(--color-danger);
  font-size: var(--font-xs);
}

.account-card-main {
  flex: 1;
  min-width: 0;
  margin-left: var(--space-sm);
}

.account-card-title-row {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.account-card-name {
  max-width: 320rpx;
  color: var(--color-text-1);
  font-size: var(--font-title-sm);
  font-weight: var(--weight-bold);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.account-card-role {
  padding: var(--space-3xs) var(--space-xs);
  border-radius: var(--radius-pill);
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: var(--font-xs);
}

.account-card-subline {
  margin-top: var(--space-2xs);
  color: var(--color-text-2);
  font-size: var(--font-caption);
}

.account-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2xs);
  margin-top: var(--space-sm);
}

.account-card-tag {
  padding: var(--space-2xs) var(--space-xs);
  border-radius: var(--radius-pill);
  background: var(--color-background-subtle);
  color: var(--color-text-2);
  font-size: var(--font-xs);
}

.account-card-tag.active {
  background: var(--color-primary);
  color: var(--color-text-inverse);
}

.account-switcher-actions {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-lg);
}

.account-switcher-btn {
  flex: 1;
  height: var(--button-height);
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  border-radius: var(--radius-lg);
  background: var(--color-background-card);
  color: var(--color-text-1);
  border: var(--line-width-thin) solid var(--color-border-strong);
  font-size: var(--font-md);
}

.account-switcher-btn.primary {
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-color: var(--color-primary);
}
