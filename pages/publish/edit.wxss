@import "../../styles/variables.wxss";

.publish-page {
  --color-primary: #3c7bfd;
  --color-primary-bg: rgba(60, 123, 253, 0.1);
  --color-primary-dark: #245fda;
  --color-info: #3c7bfd;
  --color-info-bg: rgba(60, 123, 253, 0.1);
  min-height: 100vh;
  background: #f7f8fa;
}

.publish-shell {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-top: 20rpx;
  padding-bottom: calc(172rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(172rpx + env(safe-area-inset-bottom));
}

.form-card,
.loading-panel {
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, 0.05);
}

.publish-progress {
  position: sticky;
  top: 0;
  z-index: 12;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 8rpx 32rpx 0;
  background: linear-gradient(180deg, rgba(247, 248, 250, 0.96) 0%, rgba(247, 248, 250, 0.9) 100%);
  backdrop-filter: blur(12rpx);
}

.publish-progress.active .publish-progress__meta {
  background: rgba(60, 123, 253, 0.08);
}

.publish-progress__track {
  position: relative;
  height: 8rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.18);
}

.publish-progress__fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #6ba2ff 0%, #3c7bfd 100%);
  transition: width var(--duration-fast) var(--easing-standard);
}

.publish-progress__meta {
  display: flex;
  align-items: center;
  align-self: flex-start;
  gap: 12rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  transition: background var(--duration-fast) var(--easing-standard);
}

.publish-progress__step {
  color: var(--color-primary);
  font-size: var(--font-sm);
  font-weight: var(--weight-heavy);
}

.publish-progress__label {
  color: var(--color-text-2);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
}

.loading-panel {
  padding: var(--card-padding);
}

.error-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  padding: var(--card-padding);
  border-radius: var(--radius-lg);
  background: var(--color-danger-bg);
}

.error-box__text {
  flex: 1;
  color: var(--color-danger);
  font-size: var(--font-sm);
  line-height: var(--lh-normal);
}

.error-box__retry {
  min-height: var(--control-height-sm);
  margin: 0;
  padding: 0 var(--space-md);
  border-radius: var(--radius-pill);
  background: var(--color-background-card);
  color: var(--color-danger);
  font-size: var(--font-sm);
}

.error-box__retry::after {
  border: none;
}

.form-card {
  padding: 32rpx;
  margin-bottom: 0;
}

.section-title {
  margin-bottom: 8rpx;
  color: var(--color-text-1);
  font-size: var(--font-xl);
  font-weight: var(--weight-heavy);
}

.form-row {
  padding: 0;
  border-bottom: none;
}

.form-card .form-row + .form-row {
  margin-top: 40rpx;
}

.form-row--featured {
  margin-top: 12rpx;
}

.label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
  margin-bottom: 12rpx;
}

.label-row--action {
  align-items: center;
}

.label-row--action .label {
  margin-bottom: 0;
}

.label {
  display: block;
  margin-bottom: 14rpx;
  color: var(--color-text-1);
  font-size: var(--font-md);
  font-weight: var(--weight-bold);
}

.label-count {
  color: var(--color-primary);
  font-size: var(--font-sm);
  font-weight: var(--weight-heavy);
}

.field-caption {
  display: block;
  margin-bottom: 14rpx;
  color: var(--color-text-3);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
}

.helper-text {
  margin-top: 10rpx;
  color: var(--color-text-3);
  font-size: var(--font-sm);
  line-height: var(--lh-normal);
}

.helper-text--top {
  margin-top: 0;
  margin-bottom: 18rpx;
}

.input,
.textarea,
.layout-picker,
.meta-tag-control {
  box-sizing: border-box;
  width: 100%;
  background: #f7f8fa;
}

.input {
  height: 96rpx;
  line-height: 96rpx;
  padding: 0 28rpx;
  border: none;
  border-radius: 24rpx;
  color: var(--color-text-1);
  font-size: var(--font-md);
}

.input-outline {
  background: #ffffff;
  box-shadow: inset 0 0 0 2rpx #dce3ee;
}

.title-input {
  font-size: var(--font-lg);
  font-weight: var(--weight-medium);
}

.layout-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 96rpx;
  line-height: normal;
  padding: 0 28rpx;
}

.layout-trigger__value {
  display: inline-block;
  color: var(--color-text-1);
  font-size: var(--font-md);
  line-height: 1;
  margin-top: -4rpx;
}

.layout-trigger__value--placeholder {
  color: var(--color-text-3);
}

.layout-trigger__arrow {
  display: inline-block;
  color: var(--color-text-3);
  font-size: var(--font-md);
  font-weight: var(--weight-bold);
  line-height: 1;
  margin-top: -4rpx;
}

.layout-sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 28;
  background: rgba(15, 23, 42, 0.28);
}

.layout-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 29;
  border-radius: 36rpx 36rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -16rpx 40rpx rgba(15, 23, 42, 0.12);
  padding: 16rpx 24rpx calc(24rpx + constant(safe-area-inset-bottom));
  padding: 16rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
}

.layout-sheet__handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 20rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.4);
}

.layout-sheet__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.layout-sheet__action {
  min-width: 72rpx;
  color: var(--color-text-3);
  font-size: var(--font-md);
  line-height: 44rpx;
}

.layout-sheet__action--primary {
  color: var(--color-primary);
  font-weight: var(--weight-bold);
  text-align: right;
}

.layout-sheet__title {
  color: var(--color-text-1);
  font-size: var(--font-lg);
  font-weight: var(--weight-heavy);
}

.layout-sheet__picker {
  width: 100%;
  height: 360rpx;
}

.layout-wheel__item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  color: var(--color-text-1);
  font-size: var(--font-xl);
  font-weight: var(--weight-heavy);
  line-height: 96rpx;
}

.meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.meta-tag,
.location-panel,
.submit-preview {
  padding: 24rpx;
  border: none;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.04);
}

.meta-tag-label {
  display: block;
  margin-bottom: 14rpx;
  color: var(--color-text-2);
  font-size: var(--font-sm);
}

.meta-tag-control {
  height: 96rpx;
  border-radius: 22rpx;
}

.meta-picker {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  height: 96rpx;
  padding: 0 24rpx;
  color: var(--color-text-1);
}

.location-panel {
  padding: 0;
  background: transparent;
  box-shadow: none;
}

.location-btn {
  width: auto;
  min-width: 0;
  height: auto;
  line-height: 1.2;
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  color: var(--color-primary);
  font-size: var(--font-sm);
  font-weight: var(--weight-bold);
}

.location-btn::after {
  border: none;
}

.location-address {
  margin-top: 0;
}

.location-map {
  width: 100%;
  height: 260rpx;
  margin-top: 16rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.08);
}

.textarea {
  min-height: 240rpx;
  padding: 28rpx;
  border: none;
  border-radius: 24rpx;
  color: var(--color-text-1);
  font-size: var(--font-md);
  line-height: 1.7;
}

.facility-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.facility-tag {
  box-sizing: border-box;
  width: calc((100% - 28rpx) / 3);
  min-height: 76rpx;
  padding: 0 12rpx;
  border: none;
  border-radius: var(--radius-md);
  background: #f7f8fa;
  color: #333333;
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  line-height: 76rpx;
  text-align: center;
}

.facility-tag.active {
  background: rgba(60, 123, 253, 0.1);
  color: var(--color-primary);
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.image-grid-top {
  margin-top: 8rpx;
}

.image-item {
  position: relative;
  width: auto;
  height: 200rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: #eef2f7;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.upload-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  background: var(--overlay-bg);
}

.upload-overlay__progress {
  color: var(--color-text-inverse);
  font-size: var(--font-sm);
  font-weight: var(--weight-bold);
}

.remove-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  border-radius: var(--radius-pill);
  background: rgba(17, 24, 39, 0.52);
  color: var(--color-text-inverse);
  font-size: var(--font-sm);
  font-weight: var(--weight-bold);
  text-align: center;
}

.image-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  width: auto;
  height: 200rpx;
  border: 2rpx dashed rgba(60, 123, 253, 0.22);
  border-radius: 24rpx;
  background: #ffffff;
  color: #76839c;
}

.image-add__icon {
  color: var(--color-primary);
  font-size: 48rpx;
  font-weight: var(--weight-medium);
  line-height: 1;
}

.image-add__title {
  color: var(--color-text-1);
  font-size: var(--font-md);
  font-weight: var(--weight-bold);
}

.image-add__hint {
  color: var(--color-text-3);
  font-size: var(--font-sm);
}

.submit-preview {
  background: linear-gradient(180deg, #f9fbff 0%, #f2f7ff 100%);
  box-shadow: none;
}

.submit-preview-title {
  color: var(--color-primary-dark);
  font-size: var(--font-lg);
  font-weight: var(--weight-heavy);
}

.submit-preview-subtitle {
  margin-top: var(--space-2xs);
  color: var(--color-primary);
  font-size: var(--font-sm);
  line-height: var(--lh-normal);
}

.step-actions {
  display: flex;
  gap: 12rpx;
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  box-sizing: border-box;
  width: 100%;
  padding: 20rpx 32rpx calc(24rpx + constant(safe-area-inset-bottom));
  padding: 20rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(247, 248, 250, 0.92);
  box-shadow: 0 -12rpx 30rpx rgba(15, 23, 42, 0.08);
  backdrop-filter: blur(20rpx);
}

.step-btn {
  flex: 1;
  height: var(--button-height);
  line-height: var(--button-height);
  margin: 0;
  border-radius: var(--radius-pill);
  font-size: var(--font-lg);
  font-weight: var(--weight-bold);
}

.step-btn::after {
  border: none;
}

.step-btn.primary {
  flex: 2;
  background: linear-gradient(180deg, #4c88ff 0%, #3c7bfd 100%);
  color: var(--color-text-inverse);
  box-shadow: 0 12rpx 24rpx rgba(60, 123, 253, 0.22);
}

.step-btn.secondary {
  flex: 1;
  background: #ffffff;
  color: #333333;
  box-shadow: 0 10rpx 20rpx rgba(148, 163, 184, 0.12);
}
