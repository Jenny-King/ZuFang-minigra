{
  "name": "coding4-1",
  "version": "1.0.0",
  "private": true,
  "description": "微信小程序租房平台（云开发）",
  "scripts": {
    "lint": "eslint \"cloudfunctions/**/*.js\" \"**/*.js\" --ignore-pattern \"node_modules/**\"",
    "lint:fix": "eslint --fix \"cloudfunctions/**/*.js\" \"**/*.js\" --ignore-pattern \"node_modules/**\"",
    "test": "jest",
    "test:auth:devtools": "node scripts/devtools-auth-smoke.js",
    "cleanup:test-users": "node scripts/cleanup-test-users.js",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "check": "npm run lint && npm run test"
  },
  "devDependencies": {
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "miniprogram-automator": "^0.12.1"
  }
}
