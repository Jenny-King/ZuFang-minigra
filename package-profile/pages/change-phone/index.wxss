.change-phone-page {
  min-height: 100vh;
}

.change-phone-card {
  padding: 28rpx;
  border-radius: 28rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f1f1f;
  text-align: center;
}

.subtitle {
  margin: 16rpx 0 28rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7f8797;
  text-align: center;
}

.form-item {
  margin-bottom: 24rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 26rpx;
  color: #333333;
}

.row {
  display: flex;
  gap: 12rpx;
}

.flex-1 {
  flex: 1;
}

.input {
  width: 100%;
  height: 84rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e8ebf2;
  border-radius: 18rpx;
  font-size: 28rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.code-btn {
  min-width: 210rpx;
  margin: 0;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
  color: #ffffff;
  background: #2f64f5;
}

.code-btn[disabled] {
  color: #ffffff;
  background: #b8c7f8;
}

.submit-btn {
  margin-top: 12rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #1f4fd7 0%, #2f64f5 100%);
  color: #ffffff;
  font-size: 30rpx;
}
