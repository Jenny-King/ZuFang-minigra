@import "../../styles/variables.wxss";

.publish-page {
  --color-primary: #3c7bfd;
  --color-primary-bg: rgba(60, 123, 253, 0.1);
  --color-primary-dark: #245fda;
  --color-info: #3c7bfd;
  --color-info-bg: rgba(60, 123, 253, 0.1);
  min-height: 100vh;
  background: linear-gradient(180deg, #eef4ff 0, #f5f7fb 280rpx, var(--color-background-page) 280rpx);
}

.publish-shell {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: calc(140rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.publish-hero,
.form-card,
.loading-panel {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, 0.06);
}

.publish-hero {
  padding: var(--card-padding);
}

.form-title {
  color: var(--color-text-1);
  font-size: var(--font-xl);
  font-weight: var(--weight-heavy);
  transition: all var(--duration-fast) var(--easing-standard);
}

.form-title.active {
  padding: 20rpx 24rpx;
  border-radius: var(--radius-lg);
  background: var(--color-info-bg);
  color: var(--color-info);
  box-shadow: 0 10rpx 24rpx rgba(60, 123, 253, 0.14);
}

.step-subtitle {
  margin-top: var(--space-2xs);
  color: var(--color-text-2);
  font-size: var(--font-sm);
  line-height: var(--lh-normal);
}

.stepper-wrap {
  margin-top: var(--space-md);
}

.loading-panel {
  padding: var(--card-padding);
}

.error-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  padding: var(--card-padding);
  border-radius: var(--radius-lg);
  background: var(--color-danger-bg);
}

.error-box__text {
  flex: 1;
  color: var(--color-danger);
  font-size: var(--font-sm);
  line-height: var(--lh-normal);
}

.error-box__retry {
  min-height: var(--control-height-sm);
  margin: 0;
  padding: 0 var(--space-md);
  border-radius: var(--radius-pill);
  background: var(--color-background-card);
  color: var(--color-danger);
  font-size: var(--font-caption);
}

.error-box__retry::after {
  border: none;
}

.form-card {
  padding: var(--card-padding);
  margin-bottom: 0;
}

.section-title {
  margin-bottom: 4rpx;
  color: var(--color-text-1);
  font-size: var(--font-md);
  font-weight: var(--weight-heavy);
}

.form-row {
  padding: 0;
  border-bottom: none;
}

.form-card .form-row + .form-row {
  margin-top: 28rpx;
}

.label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
  margin-bottom: 14rpx;
}

.label-row--action {
  align-items: center;
}

.label-row--action .label {
  margin-bottom: 0;
}

.label {
  display: block;
  margin-bottom: 14rpx;
  color: var(--color-text-1);
  font-size: 28rpx;
  font-weight: var(--weight-bold);
}

.helper-text {
  margin-top: 10rpx;
  color: var(--color-text-3);
  font-size: var(--font-caption);
  line-height: var(--lh-normal);
}

.input,
.textarea,
.layout-picker,
.meta-tag-control {
  box-sizing: border-box;
  width: 100%;
  background: #f7f8fa;
}

.input {
  min-height: 84rpx;
  padding: 0 20rpx;
  border: none;
  border-radius: var(--radius-md);
  color: var(--color-text-1);
  font-size: var(--font-md);
}

.layout-picker-row {
  display: flex;
  gap: 12rpx;
}

.layout-picker {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 84rpx;
  line-height: 84rpx;
}

.meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.meta-tag,
.location-panel,
.submit-preview {
  padding: 20rpx;
  border: none;
  border-radius: var(--radius-lg);
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
}

.meta-tag-label {
  display: block;
  margin-bottom: var(--space-sm);
  color: var(--color-text-2);
  font-size: var(--font-caption);
}

.meta-tag-control {
  min-height: 72rpx;
  border-radius: var(--radius-md);
}

.meta-picker {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 0 20rpx;
  color: var(--color-text-1);
}

.location-panel {
  padding: 0;
  background: transparent;
  box-shadow: none;
}

.location-btn {
  width: auto;
  min-width: 176rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: var(--radius-pill);
  background: rgba(60, 123, 253, 0.1);
  color: var(--color-primary);
  font-size: var(--font-sm);
  font-weight: var(--weight-bold);
}

.location-btn::after {
  border: none;
}

.location-address {
  margin-top: 0;
}

.location-map {
  width: 100%;
  height: 260rpx;
  margin-top: 16rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.08);
}

.textarea {
  min-height: 240rpx;
  padding: 20rpx;
  border: none;
  border-radius: var(--radius-md);
  color: var(--color-text-1);
  font-size: var(--font-md);
}

.facility-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.facility-tag {
  box-sizing: border-box;
  width: calc((100% - 28rpx) / 3);
  min-height: 76rpx;
  padding: 0 12rpx;
  border: none;
  border-radius: var(--radius-md);
  background: #f7f8fa;
  color: #333333;
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  line-height: 76rpx;
  text-align: center;
}

.facility-tag.active {
  background: rgba(60, 123, 253, 0.1);
  color: var(--color-primary);
  box-shadow: inset 0 0 0 2rpx rgba(60, 123, 253, 0.24);
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.image-grid-top {
  margin-top: var(--space-3xs);
}

.image-item {
  position: relative;
  width: var(--image-upload-size);
  height: var(--image-upload-size);
}

.preview-image {
  width: 100%;
}

.upload-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  background: var(--overlay-bg);
}

.upload-overlay__progress {
  color: var(--color-text-inverse);
  font-size: var(--font-sm);
  font-weight: var(--weight-bold);
}

.remove-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  border-radius: var(--radius-pill);
  background: rgba(0, 0, 0, 0.5);
  color: var(--color-text-inverse);
  font-size: 20rpx;
  text-align: center;
}

.image-add {
  display: flex;
  align-items: center;
  justify-content: center;
  width: var(--image-upload-size);
  height: var(--image-upload-size);
  border: none;
  border-radius: var(--radius-md);
  background: #f7f8fa;
  color: #76839c;
  font-size: var(--font-label);
  box-shadow: inset 0 0 0 2rpx rgba(60, 123, 253, 0.12);
}

.submit-preview {
  background: linear-gradient(180deg, #f9fbff 0%, #f2f7ff 100%);
  box-shadow: none;
}

.submit-preview-title {
  color: var(--color-primary-dark);
  font-size: var(--font-label);
  font-weight: var(--weight-heavy);
}

.submit-preview-subtitle {
  margin-top: var(--space-2xs);
  color: var(--color-primary);
  font-size: var(--font-caption);
  line-height: var(--lh-normal);
}

.step-actions {
  display: flex;
  gap: 12rpx;
  position: sticky;
  bottom: 0;
  z-index: 20;
  margin: 0 -32rpx -32rpx;
  padding: 18rpx 32rpx calc(18rpx + constant(safe-area-inset-bottom));
  padding: 18rpx 32rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
  backdrop-filter: blur(18rpx);
}

.step-btn {
  flex: 1;
  height: var(--button-height);
  line-height: var(--button-height);
  margin: 0;
  border-radius: var(--radius-pill);
  font-size: var(--font-md);
  font-weight: var(--weight-bold);
}

.step-btn::after {
  border: none;
}

.step-btn.primary {
  flex: 2;
  background: linear-gradient(180deg, #4c88ff 0%, #3c7bfd 100%);
  color: var(--color-text-inverse);
  box-shadow: 0 12rpx 24rpx rgba(60, 123, 253, 0.22);
}

.step-btn.secondary {
  flex: 1;
  background: #f2f2f2;
  color: #333333;
}
