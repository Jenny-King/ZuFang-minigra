@import "../../styles/variables.wxss";

.listings-page {
  min-height: 100vh;
  background: var(--color-background-page);
}

.listings-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  margin-bottom: var(--space-sm);
}

.head-copy {
  flex: 1;
  min-width: 0;
}

.page-title {
  font-size: var(--font-xl);
  font-weight: var(--weight-heavy);
  line-height: var(--lh-tight);
  color: var(--color-text-1);
}

.page-subtitle {
  margin-top: var(--space-2xs);
  font-size: var(--font-sm);
  color: var(--color-text-3);
  line-height: var(--lh-normal);
}

.publish-entry-btn {
  margin: 0;
  flex-shrink: 0;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 var(--space-lg);
  border-radius: var(--radius-lg);
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: var(--font-sm);
  font-weight: var(--weight-bold);
  box-shadow: 0 16rpx 32rpx rgba(37, 99, 235, 0.22);
}

.head-actions {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  flex-shrink: 0;
}

.booking-manage-btn {
  margin: 0;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 var(--space-lg);
  border-radius: var(--radius-lg);
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: var(--font-sm);
  font-weight: var(--weight-bold);
}

.booking-manage-btn::after {
  border: none;
}

.publish-entry-btn::after {
  border: none;
}

.stats-bar {
  display: flex;
  gap: var(--space-xs);
  margin-bottom: var(--space-lg);
}

.stat-card {
  flex: 1;
  position: relative;
  padding: var(--space-md) var(--space-xs);
  border-radius: var(--radius-xl);
  border: var(--line-width-thin) solid transparent;
  text-align: center;
  background: var(--color-background-card);
  box-shadow: var(--shadow-card);
  transition: background var(--duration-normal) var(--easing-standard),
              box-shadow var(--duration-normal) var(--easing-standard),
              border-color var(--duration-normal) var(--easing-standard);
}

.stat-card.active {
  border-color: var(--color-primary);
  background: var(--color-primary-bg);
  box-shadow: 0 6rpx 16rpx rgba(37, 99, 235, 0.08);
}

.stat-number {
  font-size: var(--font-xl);
  font-weight: var(--weight-heavy);
  line-height: 1;
}

.stat-card.blue .stat-number {
  color: var(--color-primary);
}

.stat-card.green .stat-number {
  color: var(--color-success);
}

.stat-card.amber .stat-number {
  color: var(--color-warning);
}

.stat-card.gray .stat-number {
  color: var(--color-text-3);
}

.stat-label {
  margin-top: var(--space-2xs);
  font-size: var(--font-caption);
  color: var(--color-text-2);
}

.stat-card.active .stat-label {
  font-weight: var(--weight-bold);
  color: var(--color-primary);
}

.hint-bar {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-sm) var(--space-md);
  margin-bottom: var(--space-sm);
  border-radius: var(--radius-lg);
  background: var(--color-info-bg);
}

.hint-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  flex-shrink: 0;
  border-radius: var(--radius-pill);
  background: rgba(37, 99, 235, 0.16);
}

.hint-icon-mark {
  color: var(--color-primary);
  font-size: var(--font-sm);
  font-weight: var(--weight-heavy);
}

.hint-text {
  flex: 1;
  font-size: var(--font-caption);
  color: var(--color-primary-dark);
  line-height: var(--lh-snug);
}

.hint-close {
  font-size: var(--font-lg);
  color: rgba(37, 99, 235, 0.5);
  padding: 0 var(--space-3xs);
}

.error-box {
  padding: var(--space-md);
  margin-bottom: var(--space-md);
  border-radius: var(--radius-lg);
  color: var(--color-danger);
  background: var(--color-danger-bg);
  font-size: var(--font-sm);
}

.listing-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.listing-card {
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-2xl);
  background: var(--color-background-card);
  box-shadow: var(--shadow-card-soft);
}

.card-inner {
  position: relative;
  z-index: 2;
  transition: transform var(--duration-normal) var(--easing-standard);
  background: var(--color-background-card);
}

.listing-card.swiped .card-inner {
  transform: translateX(-240rpx);
}

.card-body {
  display: flex;
  gap: var(--space-sm);
  padding: var(--card-padding);
}

.thumb-box {
  flex: 0 0 var(--image-thumb-size);
  width: var(--image-thumb-size);
  height: var(--image-thumb-size);
  border-radius: var(--radius-xl);
  overflow: hidden;
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
}

.thumb-image {
  width: 100%;
  height: 100%;
}

.thumb-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  color: var(--color-primary);
  font-size: 48rpx;
  font-weight: var(--weight-heavy);
}

.card-info {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: var(--font-md);
  font-weight: var(--weight-bold);
  color: var(--color-text-1);
  line-height: var(--lh-snug);
}

.card-price {
  margin-top: var(--space-xs);
  font-size: var(--font-title-sm);
  font-weight: var(--weight-heavy);
  color: var(--color-price-highlight);
  display: flex;
  align-items: baseline;
}

.price-unit {
  font-size: var(--font-caption);
  font-weight: var(--weight-regular);
  color: var(--color-text-3);
  margin-left: var(--space-3xs);
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-top: var(--space-sm);
}

.tag {
  padding: var(--space-3xs) var(--space-sm);
  border-radius: var(--radius-md);
  font-size: var(--font-xs);
  line-height: var(--lh-normal);
  font-weight: var(--weight-medium);
}

.tag.neutral {
  background: var(--color-background-subtle);
  color: var(--color-text-2);
}

.tag.success {
  background: var(--color-accent-green-bg);
  color: var(--color-accent-green);
}

.tag.warning {
  background: var(--color-accent-amber-bg);
  color: var(--color-warning);
}

.tag.danger {
  background: var(--color-danger-bg);
  color: var(--color-danger);
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  padding: var(--space-sm) var(--card-padding) var(--space-md);
  border-top: var(--line-width-hairline) solid var(--color-border);
}

.card-time {
  font-size: var(--font-caption);
  color: var(--color-text-3);
}

.card-actions {
  display: flex;
  gap: var(--space-xs);
}

.action-btn {
  margin: 0;
  height: var(--control-height-sm);
  line-height: var(--control-height-sm);
  padding: 0 var(--space-md);
  border-radius: var(--radius-md);
  font-size: var(--font-caption);
  font-weight: var(--weight-medium);
}

.action-btn.edit,
.action-btn.more {
  background: var(--color-background-subtle);
  color: var(--color-text-1);
}

.action-btn.more {
  min-width: 76rpx;
}

.action-btn::after {
  border: none;
}

.swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: stretch;
  overflow: hidden;
  border-radius: 0 var(--radius-2xl) var(--radius-2xl) 0;
  z-index: 1;
}

.swipe-btn {
  margin: 0;
  flex: 0 0 120rpx;
  width: 120rpx;
  height: 100%;
  align-self: stretch;
  padding: 0;
  border-radius: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--color-text-inverse);
  text-align: center;
  box-sizing: border-box;
}

.swipe-btn-text {
  font-size: var(--font-md);
  font-weight: var(--weight-medium);
  color: inherit;
}

.swipe-unpublish {
  background: var(--color-text-3);
  color: var(--color-text-inverse);
}

.swipe-publish {
  background: var(--color-primary);
  color: var(--color-text-inverse);
}

.swipe-delete {
  background: var(--color-danger);
  border-radius: 0 var(--radius-2xl) var(--radius-2xl) 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx var(--space-xl);
  border-radius: var(--radius-2xl);
  background: var(--color-background-card);
  text-align: center;
}

.empty-state.slim {
  padding: 56rpx var(--space-xl);
}

.empty-icon {
  font-size: 64rpx;
}

.empty-title {
  margin-top: var(--space-sm);
  font-size: var(--font-title-sm);
  font-weight: var(--weight-bold);
  color: var(--color-text-1);
}

.empty-subtitle {
  margin-top: var(--space-xs);
  font-size: var(--font-sm);
  line-height: var(--lh-relaxed);
  color: var(--color-text-3);
}

.empty-action-btn {
  margin-top: var(--space-lg);
  min-width: 260rpx;
  height: var(--control-height-md);
  line-height: var(--control-height-md);
  border-radius: var(--radius-lg);
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: var(--font-label);
  font-weight: var(--weight-bold);
}

.loading-tip {
  text-align: center;
  color: var(--color-text-3);
  font-size: var(--font-caption);
  padding: var(--space-lg) 0;
}

.delete-modal-mask {
  position: fixed;
  inset: 0;
  z-index: 999;
  background: var(--overlay-bg);
  display: flex;
  align-items: flex-end;
}

.delete-modal-panel {
  width: 100%;
  padding: var(--space-xl) var(--card-padding) var(--space-2xl);
  border-radius: var(--radius-panel) var(--radius-panel) 0 0;
  background: var(--color-background-card);
}

.delete-modal-title {
  font-size: var(--font-lg);
  font-weight: var(--weight-heavy);
  color: var(--color-text-1);
  text-align: center;
  line-height: var(--lh-snug);
}

.delete-modal-subtitle {
  margin-top: var(--space-sm);
  font-size: var(--font-sm);
  color: var(--color-text-2);
  text-align: center;
  line-height: var(--lh-relaxed);
}

.delete-confirm-btn,
.delete-cancel-btn {
  margin-top: var(--space-sm);
  height: var(--action-bar-button-height);
  line-height: var(--action-bar-button-height);
  border-radius: var(--radius-lg);
  font-size: var(--font-md);
}

.delete-confirm-btn {
  background: var(--color-danger);
  color: var(--color-text-inverse);
  font-weight: var(--weight-heavy);
}

.delete-cancel-btn {
  background: var(--color-background-subtle);
  color: var(--color-text-2);
}

.delete-confirm-btn::after,
.delete-cancel-btn::after {
  border: none;
}
