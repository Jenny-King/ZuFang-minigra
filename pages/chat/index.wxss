@import "../../styles/variables.wxss";

.chat-page {
  min-height: 100vh;
  background: var(--color-background-card);
}

.error-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  padding: var(--card-padding);
  margin: 24rpx 32rpx;
  border-radius: var(--radius-sm);
  background: var(--color-danger-bg);
}

.error-box__text {
  color: var(--color-danger);
  font-size: var(--font-sm);
}

.error-box__retry {
  min-height: var(--control-height-sm);
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 var(--space-md);
  border-radius: var(--radius-pill);
  background: var(--color-background-card);
  color: var(--color-danger);
  font-size: var(--font-caption);
}

.error-box__retry::after {
  border: none;
}

/* ── Search ── */
.search-bar {
  padding: 16rpx 32rpx 20rpx;
  background: var(--color-background-card);
  border-bottom: 1rpx solid var(--color-border-subtle);
  position: sticky;
  top: 0;
  z-index: 100;
}
.search-inner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--color-background-page);
  border-radius: 40rpx;
  padding: 0 28rpx;
  height: 72rpx;
}
.search-inner icon {
  display: flex;
  align-items: center;
  margin-top: 4rpx;
}
.search-inner input {
  flex: 1;
  border: none;
  background: transparent;
  font-size: 28rpx;
  color: var(--color-text-1);
}
.search-placeholder {
  color: var(--color-text-3);
}

/* ── List Scroll ── */
.list-scroll {
  background: var(--color-background-card);
  min-height: calc(100vh - 110rpx);
}

/* ── Chat Item ── */
.chat-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 32rpx;
  position: relative;
  transition: background .15s;
}
.chat-item:active {
  background: var(--color-background-page);
}
.chat-item + .chat-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 152rpx;
  right: 0;
  height: 1rpx;
  background: var(--color-border-subtle);
}

/* Avatar */
.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}
.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
}

/* Badge */
.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: var(--color-danger);
  border-radius: 18rpx;
  border: 4rpx solid var(--color-background-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  padding: 0 8rpx;
  line-height: normal;
  box-sizing: border-box;
}

/* Main */
.chat-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.chat-row1 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}
.chat-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-1);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.chat-time {
  font-size: 24rpx;
  color: var(--color-text-3);
  white-space: nowrap;
  flex-shrink: 0;
}

/* House Preview Card */
.house-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #f9fafb;
  border: 1rpx solid var(--color-border-subtle, #f0f0f0);
  border-radius: 16rpx;
  padding: 14rpx 18rpx;
  overflow: hidden;
}
.house-thumb {
  width: 88rpx;
  height: 88rpx;
  background: var(--color-background-subtle);
  border-radius: 12rpx;
  flex-shrink: 0;
}
.house-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.house-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-1);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.house-meta {
  font-size: 22rpx;
  color: var(--color-text-3);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.house-price {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-primary);
  white-space: nowrap;
  flex-shrink: 0;
}

/* Last Message */
.chat-preview {
  font-size: 26rpx;
  color: var(--color-text-2);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
