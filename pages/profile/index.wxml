<view class="container profile-page">
  <view wx:if="{{loading && isLoggedIn && !userInfo}}" class="profile-loading section">
    <skeleton type="profile" />
  </view>

  <block wx:if="{{isLoggedIn && userInfo}}">
    <view class="hero" style="height: 535rpx; display: block; box-sizing: border-box; left: 0rpx; top: 0rpx" style="height: 441rpx; display: block; box-sizing: border-box; left: 0rpx; top: 0rpx">
      <view class="hero-main" style="position: relative; left: 0rpx; top: -87rpx">
        <view class="avatar-wrap" bindtap="onAvatarTap">
          <image class="avatar" src="{{userInfo.avatarUrl || '/assets/images/avatar-placeholder.png'}}" mode="aspectFill" />
        </view>
        <view class="hero-info">
          <view class="hero-name-row" bindtap="onSwitchAccountTap">
            <text class="hero-name">{{userInfo.displayName}}</text>
            <text class="hero-chevron">▼</text>
          </view>
          <view class="hero-phone">{{userInfo.displayPhone}}</view>
        </view>
      </view>
      <view class="badges" style="position: relative; left: 0rpx; top: -107rpx">
        <view class="badge badge-role {{userInfo.roleBadgeClass}}">
          <text>{{userInfo.displayRole}}</text>
        </view>
        <view class="badge badge-warn {{userInfo.identityBadgeClass}}">
          <text>{{userInfo.identityBadgeText}}</text>
        </view>
        <view class="badge badge-muted {{userInfo.wechatBadgeClass}}">
          <text>{{userInfo.displayWechatStatus}}</text>
        </view>
      </view>
      
      <!-- Stats 3-col inline row -->
      <view class="stats-row" style="position: relative; left: 0rpx; top: -107rpx">
        <view class="stat {{activeQuickAction === 'favorites' ? 'active' : ''}}" data-action="favorites" bindtap="onQuickActionTap" style="position: relative; left: 0rpx; top: 2rpx">
          <text class="stat-num">{{quickStats.favoriteLabel}}</text>
          <text class="stat-label">我的收藏</text>
        </view>
        <view class="stat {{activeQuickAction === 'history' ? 'active' : ''}}" data-action="history" bindtap="onQuickActionTap">
          <text class="stat-num">{{quickStats.historyLabel}}</text>
          <text class="stat-label">浏览历史</text>
        </view>
        <view class="stat {{activeQuickAction === 'notifications' ? 'active' : ''}}" data-action="notifications" bindtap="onQuickActionTap" style="position: relative; left: 0rpx; top: 2rpx">
          <text class="stat-num">{{quickStats.notificationLabel}}</text>
          <text class="stat-label">消息通知</text>
          <text class="stat-badge" wx:if="{{unreadNotificationCount > 0}}">新</text>
        </view>
      </view>
    </view>
  </block>

  <view class="guest-card" wx:if="{{!isLoggedIn}}">
    <view class="guest-title">未登录</view>
    <view class="guest-subtitle">登录后可查看收藏、历史、通知与个人资料</view>
    <view class="auth-actions">
      <button size="mini" class="auth-btn primary" bindtap="onGoLogin">登录</button>
      <button size="mini" class="auth-btn" bindtap="onGoRegister">注册</button>
    </view>
  </view>

  <view class="page-scroll" wx:if="{{isLoggedIn && userInfo}}">

    <!-- 我的预约 -->
    <view class="card-group">
      <view class="card-header">
        <text class="card-header-title">我的预约</text>
        <text class="card-header-action" data-action="bookings" bindtap="onQuickActionTap">全部</text>
      </view>
      <view class="appt-empty" style="height: 222rpx; display: flex; box-sizing: border-box">
        <text class="appt-empty-text">快速查看预约看房记录</text>
        <button class="appt-empty-btn" data-action="bookings" bindtap="onQuickActionTap">去查看预约</button>
      </view>
    </view>

    <!-- 工具菜单 -->
    <view class="card-group">
      <view class="menu-item" bindtap="onGoSupportCenter">
        <view class="menu-icon bg-blue">
          <text class="menu-icon-text">客</text>
        </view>
        <view class="menu-text">
          <view class="menu-title">客服中心</view>
          <view class="menu-sub">常见问题与在线客服</view>
        </view>
        <view class="menu-arrow">></view>
      </view>
      <view class="menu-item" bindtap="onOpenSettingsTap">
        <view class="menu-icon bg-purple">
          <text class="menu-icon-text">设</text>
        </view>
        <view class="menu-text">
          <view class="menu-title">设置</view>
          <view class="menu-sub">账号安全与偏好设置</view>
        </view>
        <view class="menu-arrow">></view>
      </view>
      <view class="menu-item" bindtap="onSwitchRoleTap">
        <view class="menu-icon bg-orange">
           <text class="menu-icon-text">角</text>
        </view>
        <view class="menu-text">
          <view class="menu-title">切换角色</view>
          <view class="menu-sub">租客 / 房东 身份切换</view>
        </view>
        <view class="menu-tag">{{userInfo.displayRole}}</view>
        <view class="menu-arrow">></view>
      </view>
    </view>



    <view class="logout-wrap" wx:if="{{isLoggedIn}}">
      <button class="logout-btn" bindtap="onLogoutTap">
        退出当前账号
      </button>
    </view>
  </view>

  <!-- 账号管理弹窗 -->
  <view class="account-switcher-mask" wx:if="{{accountSwitcherVisible}}" bindtap="onCloseAccountSwitcher">
    <view class="account-switcher-panel" catchtap="noop">
      <view class="account-switcher-header">
        <view>
          <view class="account-switcher-title">切换账号</view>
          <view class="account-switcher-subtitle">已缓存的账号可直接切换，无需重复输入登录信息</view>
        </view>
        <view class="tap-area account-switcher-close" bindtap="onCloseAccountSwitcher">×</view>
      </view>

      <view class="account-card-list">
        <view
          class="account-card {{item.isActive ? 'active' : ''}}"
          wx:for="{{cachedAccounts}}"
          wx:key="userId"
          data-user-id="{{item.userId}}"
          bindtap="onSelectAccountTap"
        >
          <view class="account-card-remove" data-user-id="{{item.userId}}" catchtap="onRemoveAccountTap">
            {{removingAccountId === item.userId ? '处理中' : '删除记录'}}
          </view>
          <lazy-image
            class="account-card-avatar"
            src="{{item.avatarUrl}}"
            mode="aspectFill"
            radius="50%"
            width="92rpx"
            height="92rpx"
          />
          <view class="account-card-main">
            <view class="account-card-title-row">
              <text class="account-card-name">{{item.displayName}}</text>
              <text class="account-card-role">{{item.displayRole}}</text>
            </view>
            <view class="account-card-subline">{{item.displayPhone}}</view>
            <view class="account-card-tags">
              <text class="account-card-tag {{item.isActive ? 'active' : ''}}">{{item.isActive ? '当前账号' : '点击切换'}}</text>
              <text class="account-card-tag">{{item.wechatBound ? '微信已绑定' : '微信未绑定'}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="account-switcher-actions">
        <button class="account-switcher-btn primary" bindtap="onAddAccountTap">添加账号</button>
        <button class="account-switcher-btn" bindtap="onCloseAccountSwitcher">取消</button>
      </view>
    </view>
  </view>
</view>
