.favorites-page {
  min-height: 100vh;
  padding-bottom: 28rpx;
}

.favorites-page.highlight .listing-card {
  box-shadow: 0 0 0 2rpx rgba(60, 123, 253, 0.12), 0 18rpx 40rpx rgba(37, 99, 235, 0.1);
}

.error-box {
  padding: 20rpx;
  margin-bottom: 20rpx;
  border-radius: 8rpx;
  color: #ff4d4f;
  background: #fff1f0;
  font-size: 24rpx;
}

.fav-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.listing-card {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(15, 23, 42, 0.06);
}

.card-inner {
  position: relative;
  z-index: 2;
  background: #ffffff;
  transition: transform 0.28s ease;
}

.listing-card.swiped .card-inner {
  transform: translateX(-104rpx);
}

.listing-body {
  display: flex;
  gap: 18rpx;
  padding: 22rpx;
}

.cover {
  display: block;
  flex: 0 0 180rpx;
  width: 180rpx;
  height: 140rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
}

.main {
  flex: 1;
  min-width: 0;
}

.title {
  font-size: 30rpx;
  color: #1f1f1f;
  font-weight: 600;
  line-height: 1.45;
}

.meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #667085;
}

.address {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7f8797;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.footer {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 10rpx 14rpx;
}

.price {
  color: #ff5a5f;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
}

.time {
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 1.6;
}

.swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: stretch;
  width: 88rpx;
  z-index: 1;
}

.swipe-btn {
  flex: 0 0 88rpx;
  width: 88rpx;
  height: auto;
  align-self: stretch;
  margin: 0;
  padding: 0;
  border-radius: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  text-align: center;
  box-sizing: border-box;
}

.swipe-btn-char {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1;
  color: inherit;
}

.swipe-btn-char + .swipe-btn-char {
  margin-top: 8rpx;
}

.swipe-delete {
  background: #ef4444;
}

.loading-tip {
  text-align: center;
  color: #999999;
  font-size: 24rpx;
  padding: 22rpx 0;
}
