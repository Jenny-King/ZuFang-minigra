.verify-page {
  min-height: 100vh;
}

.verify-card {
  padding: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24rpx;
}

.status-box {
  background: #f5f8ff;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 22rpx;
}

.status-label {
  font-size: 24rpx;
  color: #666666;
}

.status-value {
  font-size: 24rpx;
  margin-left: 8rpx;
}

.status-value.ok {
  color: #52c41a;
}

.status-value.pending {
  color: #faad14;
}

.masked {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #666666;
}

.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.input {
  width: 100%;
  height: 76rpx;
  border: 2rpx solid #ececec;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  background: #ffffff;
}

.submit-btn {
  margin-top: 10rpx;
  height: 84rpx;
  line-height: 84rpx;
  background: #1677ff;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 30rpx;
}