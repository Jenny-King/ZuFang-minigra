@import "../../styles/auth-form.wxss";

.subtitle {
  margin: 20rpx 0 48rpx;
  text-align: center;
  color: var(--color-text-3);
  font-size: var(--font-sm);
  line-height: var(--lh-normal);
}

.wechat-btn {
  height: 104rpx;
  line-height: 104rpx;
  border-radius: var(--radius-2xl);
  background: var(--color-success);
  color: var(--color-text-inverse);
  font-size: var(--font-lg);
  font-weight: var(--weight-heavy);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wechat-btn::after {
  border: none;
}

.divider {
  display: flex;
  align-items: center;
  margin: 48rpx 0 32rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: var(--color-border);
}

.divider-text {
  padding: 0 var(--space-lg);
  font-size: var(--font-sm);
  color: var(--color-text-3);
}

.tabs {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.tab {
  position: relative;
  min-width: 168rpx;
  text-align: center;
  padding: 0 var(--space-xs) var(--space-md);
  font-size: var(--font-title-sm);
  line-height: var(--lh-normal);
  color: var(--color-text-2);
}

.tab--active {
  color: var(--color-primary);
  font-weight: var(--weight-bold);
}

.tab--active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -1rpx;
  transform: translateX(-50%);
  width: 56rpx;
  height: 6rpx;
  border-radius: var(--radius-pill);
  background: var(--color-primary);
}

.group {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  margin-bottom: 20rpx;
  color: var(--color-text-1);
  font-size: var(--font-md);
  font-weight: var(--weight-heavy);
}

.required::after {
  content: " *";
  color: var(--color-danger);
  font-weight: var(--weight-heavy);
}

.field {
  position: relative;
}

.input {
  background: var(--color-background-subtle);
  border-radius: var(--radius-2xl);
  transition: all var(--duration-fast) ease;
}

.input-inline {
  border-radius: var(--radius-2xl);
}

.input.has-action {
  padding-right: 104rpx;
}

.eye {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-3);
  font-size: var(--font-lg);
  z-index: 2;
}

.meta {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  gap: 20rpx;
  min-height: 40rpx;
}

.hint {
  color: var(--color-text-3);
  font-size: 26rpx;
  line-height: var(--lh-snug);
}

.submit-btn {
  width: 100%;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border-radius: 32rpx;
  margin-top: 20rpx;
  background: #bfd5ff;
  color: #fff;
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  box-shadow: none;
  border: none;
  transition: all 0.2s ease;
}

.submit-btn::after {
  display: none;
}

.submit-btn.enabled {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  box-shadow: 0 24rpx 48rpx rgba(60, 123, 253, 0.22);
}

.protocol {
  margin-top: 28rpx;
  color: var(--color-text-3);
  font-size: 24rpx;
  line-height: var(--lh-normal);
  text-align: center;
}

.login {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.link-divider {
  color: var(--color-border);
  font-size: 24rpx;
}

