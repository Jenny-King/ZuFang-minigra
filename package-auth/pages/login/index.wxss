@import "../../styles/auth-form.wxss";

.wechat-btn {
  background: #4cab58;
  color: var(--color-text-inverse);
}

.divider {
  margin: 28rpx 0 24rpx;
  text-align: center;
  color: var(--color-text-3);
  font-size: 24rpx;
}

.mode-tabs {
  display: flex;
  justify-content: center;
  gap: 56rpx;
  margin-bottom: 28rpx;
  padding-bottom: 8rpx;
  border-bottom: 1rpx solid rgba(156, 163, 175, 0.18);
}

.mode-tab {
  position: relative;
  padding-bottom: 16rpx;
  color: var(--color-text-3);
  font-size: 28rpx;
  font-weight: var(--weight-medium);
}

.mode-tab.active {
  color: var(--color-primary);
  font-weight: var(--weight-heavy);
}

.mode-tab.active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 48rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: var(--color-primary);
  transform: translateX(-50%);
}
