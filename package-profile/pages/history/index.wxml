<view class="container history-page">
  <view class="toolbar">
    <button class="clear-btn" size="mini" bindtap="onClearTap">清空历史</button>
  </view>

  <view wx:if="{{errorText}}" class="error-box">{{errorText}}</view>
  <view wx:if="{{!loading && list.length === 0}}" class="empty-tip">暂无浏览历史</view>

  <view class="history-list">
    <view class="history-item card" wx:for="{{list}}" wx:key="historyId">
      <image
        class="cover"
        src="{{item.displayImage}}"
        mode="aspectFill"
        data-house-id="{{item.houseId}}"
        bindtap="onGoDetailTap"
      />
      <view class="main" data-house-id="{{item.houseId}}" bindtap="onGoDetailTap">
        <view class="title text-ellipsis">{{item.displayTitle}}</view>
        <view class="meta">{{item.displayType}} · {{item.displayAddress}}</view>
        <view class="footer">
          <text class="price">{{item.displayPrice}}</text>
          <text class="time">浏览于 {{item.displayViewTime}}</text>
        </view>
      </view>
      <button
        class="remove-btn"
        size="mini"
        data-history-id="{{item.historyId}}"
        bindtap="onRemoveTap"
      >删除</button>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-tip">加载中...</view>
  <view wx:if="{{!loading && list.length > 0 && !hasMore}}" class="loading-tip">没有更多了</view>
</view>