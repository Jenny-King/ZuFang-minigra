.auth-page {
  min-height: 100vh;
}

.auth-card {
  padding: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.input {
  width: 100%;
  height: 76rpx;
  border: 2rpx solid #ececec;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  background: #ffffff;
}

.role-group {
  display: flex;
  gap: 36rpx;
}

.role-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #333333;
  font-size: 26rpx;
}

.submit-btn {
  margin-top: 10rpx;
  height: 84rpx;
  line-height: 84rpx;
  background: #1677ff;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.bottom-text {
  text-align: center;
  margin-top: 24rpx;
  color: #666666;
  font-size: 24rpx;
}

.link {
  color: #1677ff;
}