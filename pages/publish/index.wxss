@import "../../styles/variables.wxss";

.listings-page {
  min-height: 100vh;
  background: var(--color-background-page);
}

.listings-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.page-title {
  flex: 1;
  min-width: 0;
  font-size: var(--font-title-xs);
  font-weight: var(--weight-heavy);
  line-height: var(--lh-tight);
  color: var(--color-text-1);
}

.head-actions {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  flex-shrink: 0;
}

.booking-manage-btn,
.publish-entry-btn {
  margin: 0;
  height: var(--control-height-xs);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 var(--space-lg);
  border-radius: var(--radius-pill);
  font-size: var(--font-caption);
  font-weight: var(--weight-bold);
}

.booking-manage-btn {
  background: var(--color-background-card);
  color: var(--color-primary);
  box-shadow: inset 0 0 0 var(--line-width-thin) var(--color-primary);
}

.publish-entry-btn {
  background: var(--color-primary);
  color: var(--color-text-inverse);
  box-shadow: var(--shadow-primary-soft);
}

.booking-manage-btn::after,
.publish-entry-btn::after {
  border: none;
}

.segment-wrap {
  margin-bottom: var(--space-lg);
}

.segment-control {
  display: flex;
  gap: var(--space-3xs);
  padding: var(--space-3xs);
  border-radius: var(--radius-lg);
  background: var(--color-background-subtle);
}

.segment-tab {
  flex: 1;
  min-width: 0;
  height: var(--listing-manage-segment-height);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2xs);
  border-radius: var(--radius-md);
  color: var(--color-text-2);
}

.segment-tab.active {
  background: var(--color-background-card);
  color: var(--color-text-1);
  box-shadow: var(--shadow-card);
}

.segment-label {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: var(--font-caption);
  font-weight: var(--weight-medium);
  line-height: 1;
}

.segment-tab.active .segment-label {
  font-weight: var(--weight-bold);
}

.segment-badge {
  min-width: var(--badge-size-sm);
  height: var(--badge-size-sm);
  padding: 0 var(--space-2xs);
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-border-strong);
  color: var(--color-text-3);
  font-size: var(--font-xs);
  font-weight: var(--weight-bold);
  line-height: 1;
}

.segment-tab.active .segment-badge {
  background: var(--color-primary);
  color: var(--color-text-inverse);
}

.error-box {
  padding: var(--space-md);
  margin-bottom: var(--space-md);
  border-radius: var(--radius-lg);
  background: var(--color-danger-bg);
  color: var(--color-danger);
  font-size: var(--font-sm);
  line-height: var(--lh-normal);
}

.listing-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.listing-card {
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-xl);
  background: var(--color-background-card);
  box-shadow: var(--shadow-card-soft);
}

.card-inner {
  position: relative;
  z-index: 2;
  background: var(--color-background-card);
  transition: transform var(--duration-normal) var(--easing-standard);
}

.listing-card.swiped .card-inner {
  transform: translateX(-240rpx);
}

.card-main {
  display: flex;
  gap: var(--space-sm);
  padding: var(--space-lg) var(--card-padding) var(--space-md);
}

.thumb-box {
  flex: 0 0 var(--listing-manage-thumb-width);
  width: var(--listing-manage-thumb-width);
  height: var(--listing-manage-thumb-height);
  border-radius: var(--radius-md);
  overflow: hidden;
  background: linear-gradient(
    135deg,
    var(--color-primary-bg) 0%,
    var(--color-background-selected) 100%
  );
}

.thumb-image {
  width: 100%;
  height: 100%;
}

.thumb-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  color: var(--color-primary);
  font-size: var(--font-title-sm);
  font-weight: var(--weight-heavy);
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-title-row {
  display: flex;
  align-items: flex-start;
  gap: var(--space-xs);
}

.card-title {
  flex: 1;
  min-width: 0;
  color: var(--color-text-1);
  font-size: var(--font-label);
  font-weight: var(--weight-bold);
  line-height: var(--lh-snug);
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.status-chip {
  flex-shrink: 0;
  padding: var(--space-3xs) var(--space-sm);
  border-radius: var(--radius-pill);
  font-size: var(--font-xs);
  font-weight: var(--weight-bold);
  line-height: 1;
}

.status-chip.success {
  background: var(--color-success-bg);
  color: var(--color-success);
}

.status-chip.warning {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}

.status-chip.offline {
  background: var(--color-background-subtle);
  color: var(--color-text-3);
}

.card-price {
  margin-top: var(--space-2xs);
  display: flex;
  align-items: baseline;
  color: var(--color-price-highlight);
  font-size: var(--font-title-xs);
  font-weight: var(--weight-heavy);
  line-height: 1.2;
}

.status-hidden .card-price {
  color: var(--color-text-3);
}

.price-unit {
  margin-left: var(--space-3xs);
  color: var(--color-text-3);
  font-size: var(--font-caption);
  font-weight: var(--weight-medium);
}

.card-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-2xs);
  margin-top: var(--space-xs);
}

.card-meta-item {
  color: var(--color-text-3);
  font-size: var(--font-caption);
  line-height: var(--lh-normal);
}

.card-meta-dot {
  width: var(--space-3xs);
  height: var(--space-3xs);
  border-radius: var(--radius-pill);
  flex-shrink: 0;
  background: var(--color-border-strong);
}

.card-meta-date {
  margin-left: auto;
  color: var(--color-text-3);
  font-size: var(--font-xs);
  line-height: var(--lh-normal);
}

.card-actions-bar {
  display: flex;
  align-items: center;
  border-top: var(--line-width-hairline) solid var(--color-border);
  overflow: hidden;
}

.card-action-btn {
  flex: 1;
  margin: 0;
  height: var(--listing-manage-action-height);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 var(--space-sm);
  border-radius: 0;
  background: var(--color-background-card);
  color: var(--color-text-2);
  font-size: var(--font-label);
  font-weight: var(--weight-medium);
}

.card-action-btn.primary {
  color: var(--color-primary);
  font-weight: var(--weight-bold);
}

.card-action-btn.danger {
  color: var(--color-danger);
}

.card-action-btn::after {
  border: none;
}

.card-action-divider {
  flex-shrink: 0;
  width: var(--line-width-hairline);
  height: var(--font-xl);
  background: var(--color-border);
}

.swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: stretch;
  overflow: hidden;
  border-radius: 0 var(--radius-xl) var(--radius-xl) 0;
  z-index: 1;
}

.swipe-btn {
  flex: 0 0 120rpx;
  width: 120rpx;
  height: 100%;
  margin: 0;
  padding: 0;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-inverse);
}

.swipe-btn::after {
  border: none;
}

.swipe-btn-text {
  color: inherit;
  font-size: var(--font-label);
  font-weight: var(--weight-bold);
  line-height: var(--lh-tight);
}

.swipe-unpublish {
  background: var(--color-text-3);
}

.swipe-publish {
  background: var(--color-primary);
}

.swipe-delete {
  background: var(--color-danger);
  border-radius: 0 var(--radius-xl) var(--radius-xl) 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 88rpx var(--space-xl);
  border-radius: var(--radius-xl);
  background: var(--color-background-card);
  text-align: center;
  box-shadow: var(--shadow-card-soft);
}

.empty-state.slim {
  padding-top: 64rpx;
  padding-bottom: 64rpx;
}

.empty-icon {
  font-size: var(--font-2xl);
}

.empty-title {
  margin-top: var(--space-sm);
  color: var(--color-text-1);
  font-size: var(--font-title-sm);
  font-weight: var(--weight-bold);
  line-height: var(--lh-tight);
}

.empty-subtitle {
  margin-top: var(--space-xs);
  color: var(--color-text-3);
  font-size: var(--font-sm);
  line-height: var(--lh-relaxed);
}

.empty-action-btn {
  margin-top: var(--space-lg);
  min-width: 260rpx;
  height: var(--control-height-md);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 var(--space-xl);
  border-radius: var(--radius-pill);
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: var(--font-label);
  font-weight: var(--weight-bold);
  box-shadow: var(--shadow-primary-soft);
}

.empty-action-btn::after {
  border: none;
}

.loading-tip {
  padding: var(--space-lg) 0;
  color: var(--color-text-3);
  font-size: var(--font-caption);
  text-align: center;
}

.delete-modal-mask {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  align-items: flex-end;
  background: var(--overlay-bg);
}

.delete-modal-panel {
  width: 100%;
  padding: var(--space-xl) var(--card-padding) var(--space-2xl);
  border-radius: var(--radius-panel) var(--radius-panel) 0 0;
  background: var(--color-background-card);
}

.delete-modal-title {
  color: var(--color-text-1);
  font-size: var(--font-lg);
  font-weight: var(--weight-heavy);
  line-height: var(--lh-snug);
  text-align: center;
}

.delete-modal-subtitle {
  margin-top: var(--space-sm);
  color: var(--color-text-2);
  font-size: var(--font-sm);
  line-height: var(--lh-relaxed);
  text-align: center;
}

.delete-confirm-btn,
.delete-cancel-btn {
  margin-top: var(--space-sm);
  height: var(--action-bar-button-height);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 var(--space-lg);
  border-radius: var(--radius-lg);
  font-size: var(--font-md);
}

.delete-confirm-btn {
  background: var(--color-danger);
  color: var(--color-text-inverse);
  font-weight: var(--weight-heavy);
}

.delete-cancel-btn {
  background: var(--color-background-subtle);
  color: var(--color-text-2);
}

.delete-confirm-btn::after,
.delete-cancel-btn::after {
  border: none;
}

.listings-page.tenant-page {
  padding: 0;
  background: #eef2f6;
}

.tenant-shell {
  position: relative;
  height: 100vh;
  min-height: 100vh;
  overflow: hidden;
  background: #eef2f6;
}

.tenant-map-stage {
  position: relative;
  height: 100vh;
  min-height: 100vh;
  background: linear-gradient(180deg, #edf2f7 0%, #dfe8ef 100%);
}

.tenant-map-card {
  position: absolute;
  inset: 0;
  overflow: hidden;
  background: #dfe7ee;
}

.tenant-map {
  width: 100%;
  height: 100vh;
}

.tenant-map-status {
  position: absolute;
  top: 28rpx;
  left: 24rpx;
  max-width: 420rpx;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.12);
}

.tenant-map-status-title {
  color: #111827;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.3;
}

.tenant-map-status-subtitle {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 20rpx;
  line-height: 1.45;
}

.tenant-map-tools {
  position: absolute;
  top: 220rpx;
  right: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tenant-map-tool {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.96);
  color: #111827;
  font-size: 36rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 24rpx rgba(15, 23, 42, 0.12);
}

.tenant-map-tool-location {
  font-size: 24rpx;
}

.tenant-view-toggle {
  position: absolute;
  left: 50%;
  bottom: 560rpx;
  width: 260rpx;
  margin-left: -130rpx;
  display: flex;
  justify-content: center;
  transition: bottom var(--duration-normal) var(--easing-standard);
}

.tenant-view-toggle.raised {
  bottom: 1020rpx;
}

.tenant-view-toggle-pill {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.92);
  box-shadow: 0 16rpx 32rpx rgba(15, 23, 42, 0.18);
}

.tenant-view-toggle-btn {
  min-width: 112rpx;
  height: 56rpx;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.55);
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tenant-view-toggle-btn.active {
  background: #ffffff;
  color: #111827;
}

.tenant-bottom-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 3;
}

.tenant-sheet-panel {
  border-radius: 36rpx 36rpx 0 0;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -24rpx 56rpx rgba(15, 23, 42, 0.16);
  padding: 12rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  backdrop-filter: blur(12px);
  overflow: hidden;
  transition: max-height var(--duration-normal) var(--easing-standard);
}

.tenant-bottom-sheet.collapsed .tenant-sheet-panel {
  max-height: 520rpx;
}

.tenant-bottom-sheet.expanded .tenant-sheet-panel {
  max-height: 980rpx;
}

.tenant-sheet-handle {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 8rpx 0 18rpx;
}

.tenant-sheet-grabber {
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #d1d5db;
}

.tenant-sheet-handle-label {
  color: #9ca3af;
  font-size: 20rpx;
  line-height: 1;
}

.tenant-sheet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.tenant-sheet-head-main {
  flex: 1;
  min-width: 0;
}

.tenant-sheet-title {
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.3;
}

.tenant-sheet-count {
  margin-top: 6rpx;
  color: #9ca3af;
  font-size: 22rpx;
  line-height: 1.4;
}

.tenant-sheet-sort {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f0fdf4;
}

.tenant-sheet-sort-text,
.tenant-sheet-sort-arrow {
  color: #07c160;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.tenant-sheet-notice {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 18rpx;
  margin-bottom: 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 20rpx;
  background: #f8fafc;
}

.tenant-sheet-notice-location {
  color: #111827;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.4;
  flex-shrink: 0;
}

.tenant-sheet-notice-divider {
  width: 8rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #d1d5db;
  flex-shrink: 0;
}

.tenant-sheet-notice-text {
  flex: 1;
  min-width: 0;
  color: #6b7280;
  font-size: 20rpx;
  line-height: 1.45;
}

.tenant-sheet-error {
  margin-top: 0;
  margin-bottom: var(--space-sm);
}

.tenant-sheet-loading {
  padding-top: var(--space-xl);
  padding-bottom: var(--space-xl);
}

.tenant-sheet-empty {
  margin-top: var(--space-sm);
  box-shadow: none;
  background: #f8fafc;
}

.tenant-sheet-list-scroll {
  height: 328rpx;
  transition: height var(--duration-normal) var(--easing-standard);
}

.tenant-sheet-list-scroll.expanded {
  height: 726rpx;
}

.tenant-sheet-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 8rpx 0 12rpx;
}

.tenant-sheet-card {
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1px solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.06);
}

.tenant-sheet-card.active {
  border-color: rgba(7, 193, 96, 0.36);
  background: linear-gradient(135deg, #f0fdf4 0%, #ffffff 100%);
  box-shadow: 0 12rpx 28rpx rgba(7, 193, 96, 0.14);
}

.tenant-sheet-thumb-wrap {
  position: relative;
  flex: 0 0 176rpx;
  width: 176rpx;
  height: 136rpx;
  overflow: hidden;
  border-radius: 18rpx;
  background: #e5e7eb;
}

.tenant-sheet-thumb {
  width: 100%;
  height: 100%;
}

.tenant-sheet-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.75);
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 700;
  line-height: 1;
}

.tenant-sheet-badge.active {
  background: #07c160;
}

.tenant-sheet-card-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.tenant-sheet-card-title {
  color: #111827;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.tenant-sheet-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.tenant-sheet-tag {
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
  background: #eef2ff;
  color: #3b82f6;
  font-size: 18rpx;
  line-height: 1.3;
}

.tenant-sheet-tag-primary {
  background: #e8f8ef;
  color: #07c160;
}

.tenant-sheet-card-meta,
.tenant-sheet-card-address {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 20rpx;
  line-height: 1.45;
}

.tenant-sheet-card-price-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: auto;
  padding-top: 14rpx;
}

.tenant-sheet-card-price {
  color: #e53935;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.2;
}

.tenant-sheet-card-distance {
  color: #9ca3af;
  font-size: 20rpx;
  line-height: 1.4;
  text-align: right;
}
