.publish-page {
  min-height: 100vh;
  background: #f5f5f7;
}

.publish-shell {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.publish-hero {
  padding: 24rpx;
}

.form-card {
  padding: 24rpx;
}

.form-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f1f1f;
  transition: all 0.2s ease;
}

.form-title.active {
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  color: #1677ff;
  background: #eaf3ff;
  box-shadow: 0 18rpx 36rpx rgba(22, 119, 255, 0.14);
}

.step-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8b95a7;
}

.stepper {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.step-item {
  flex: 1;
  padding: 16rpx 12rpx;
  border-radius: 20rpx;
  background: #f6f8fb;
  border: 2rpx solid #edf1f5;
  text-align: center;
}

.step-item.active {
  background: #eff6ff;
  border-color: #bfdbfe;
}

.step-item.done {
  background: #f0fdf4;
  border-color: #bbf7d0;
}

.step-dot {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  margin: 0 auto;
  border-radius: 20rpx;
  background: #dbeafe;
  color: #2563eb;
  font-size: 22rpx;
  font-weight: 700;
}

.step-item.done .step-dot {
  background: #dcfce7;
  color: #16a34a;
}

.step-label {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #4b5563;
  font-weight: 600;
}

.step-item.active .step-label {
  color: #2563eb;
}

.section-title {
  margin-bottom: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
}

.helper-banner {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #eff6ff;
  color: #1d4ed8;
  font-size: 24rpx;
}

.error-box {
  padding: 20rpx;
  border-radius: 18rpx;
  color: #dc2626;
  background: #fff1f0;
  font-size: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #333333;
  font-weight: 600;
}

.helper-text {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.6;
}

.input {
  height: 76rpx;
  border: 2rpx solid #e8edf3;
  border-radius: 18rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.layout-picker-row {
  display: flex;
  gap: 12rpx;
}

.layout-picker {
  flex: 1;
  text-align: center;
  line-height: 72rpx;
}

.meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.meta-tag {
  box-sizing: border-box;
  padding: 18rpx;
  border: 2rpx solid #e6ebf2;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fbfdff 0%, #f5f8fc 100%);
}

.meta-tag-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.meta-tag-control {
  height: 68rpx;
  border-radius: 16rpx;
  border-color: #e8edf3;
  background: #ffffff;
}

.meta-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1f2937;
}

.location-panel {
  padding: 20rpx;
  border: 2rpx solid #e6ebf2;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fbfdff 0%, #f5f8fc 100%);
}

.location-btn {
  margin: 0;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 16rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 24rpx;
}

.location-address {
  margin-top: 12rpx;
}

.textarea {
  width: 100%;
  min-height: 220rpx;
  border: 2rpx solid #e8edf3;
  border-radius: 18rpx;
  padding: 18rpx;
  font-size: 28rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.facility-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.facility-tag {
  box-sizing: border-box;
  width: calc((100% - 24rpx) / 3);
  min-height: 72rpx;
  padding: 0 12rpx;
  border: 2rpx solid #e6ebf2;
  border-radius: 16rpx;
  background: #ffffff;
  color: #4b5563;
  font-size: 24rpx;
  line-height: 68rpx;
  text-align: center;
}

.facility-tag.active {
  border-color: #1677ff;
  background: #eaf3ff;
  color: #1677ff;
  box-shadow: 0 12rpx 24rpx rgba(22, 119, 255, 0.12);
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-grid-top {
  margin-top: 6rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: 18rpx;
  background: #f5f5f5;
}

.remove-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  background: #ff4d4f;
  color: #ffffff;
  font-size: 20rpx;
  text-align: center;
  line-height: 36rpx;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #999999;
  background: #ffffff;
}

.submit-preview {
  padding: 20rpx;
  border-radius: 22rpx;
  background: #eff6ff;
}

.submit-preview-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1d4ed8;
}

.submit-preview-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #5b86dc;
}

.step-actions {
  display: flex;
  gap: 16rpx;
}

.step-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.step-btn.primary {
  background: #1677ff;
  color: #ffffff;
}

.step-btn.secondary {
  background: #f3f4f6;
  color: #4b5563;
}
