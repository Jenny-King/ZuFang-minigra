.auth-page {
  min-height: 100vh;
}

.auth-card {
  padding: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24rpx;
}

.quick-accounts {
  margin-bottom: 28rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #f7faff 0%, #eef4ff 100%);
}

.quick-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.quick-subtitle {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7a8393;
}

.quick-account-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.quick-account-item {
  display: flex;
  align-items: center;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 2rpx solid transparent;
}

.quick-account-item.active {
  border-color: #b8cdfd;
  box-shadow: 0 12rpx 24rpx rgba(47, 100, 245, 0.08);
}

.quick-account-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 38rpx;
  background: #eef2f8;
  flex-shrink: 0;
}

.quick-account-main {
  flex: 1;
  min-width: 0;
  margin-left: 16rpx;
}

.quick-account-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.quick-account-phone {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #7a8393;
}

.quick-account-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #2f64f5;
  background: #edf3ff;
}

.quick-account-arrow {
  font-size: 22rpx;
  color: #2f64f5;
}

.wechat-btn {
  height: 84rpx;
  line-height: 84rpx;
  background: #07c160;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.divider {
  margin: 24rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
}

.mode-tabs {
  display: flex;
  background: #f5f6f8;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666666;
}

.mode-tab.active {
  background: #1677ff;
  color: #ffffff;
}

.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.row {
  display: flex;
  gap: 12rpx;
}

.flex-1 {
  flex: 1;
}

.input {
  width: 100%;
  height: 76rpx;
  border: 2rpx solid #ececec;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  background: #ffffff;
}

.code-btn {
  min-width: 180rpx;
  margin: 0;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  background: #1677ff;
  color: #ffffff;
}

.submit-btn {
  margin-top: 10rpx;
  height: 84rpx;
  line-height: 84rpx;
  background: #1677ff;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.bottom-text {
  text-align: center;
  margin-top: 24rpx;
  color: #666666;
  font-size: 24rpx;
}

.link {
  color: #1677ff;
}
