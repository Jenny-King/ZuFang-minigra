{
  "name": "coding4-1",
  "version": "1.0.0",
  "private": true,
  "description": "微信小程序租房平台（云开发）",
  "scripts": {
    "lint": "eslint \"cloudfunctions/**/*.js\" \"**/*.js\" --ignore-pattern \"node_modules/**\"",
    "lint:fix": "eslint --fix \"cloudfunctions/**/*.js\" \"**/*.js\" --ignore-pattern \"node_modules/**\"",
    "test": "jest",
    "test:auth:devtools": "node scripts/auth/devtools-auth-smoke.js",
    "cleanup:test-users": "node scripts/cleanup/cleanup-test-users.js",
    "cleanup:housing-data": "node scripts/cleanup/cleanup-housing-data.js",
    "deploy:cf": "powershell -ExecutionPolicy Bypass -File scripts/deploy/deploy-cloudfunction.ps1",
    "seed:houses6": "node scripts/data/seed-six-house-test-data.js",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "check": "npm run lint && npm run test"
  },
  "devDependencies": {
    "@cloudbase/manager-node": "^4.10.2",
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "miniprogram-automator": "^0.12.1"
  },
  "dependencies": {
    "@vant/weapp": "^1.11.7"
  }
}
