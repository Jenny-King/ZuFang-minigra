@import "../../../styles/variables.wxss";

.detail-page {
  padding-bottom: calc(var(--bottom-bar-height) + env(safe-area-inset-bottom));
  background: var(--color-background-page);
}

.detail-loading {
  padding: var(--card-padding);
}

.error-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  padding: var(--card-padding);
  border-radius: var(--radius-sm);
  background: var(--color-danger-bg);
}

.error-box__text {
  flex: 1;
  color: var(--color-danger);
  font-size: var(--font-sm);
}

.error-box__retry {
  min-height: var(--control-height-sm);
  margin: 0;
  padding: 0 var(--space-md);
  border-radius: var(--radius-pill);
  background: var(--color-background-card);
  color: var(--color-danger);
  font-size: var(--font-caption);
}

.error-box__retry::after {
  border: none;
}

.detail-card {
  overflow: hidden;
  border-radius: var(--radius-panel);
  background: var(--color-background-card);
  box-shadow: var(--shadow-card-soft);
}

.gallery-wrap {
  position: relative;
}

.image-swiper {
  width: 100%;
  height: 440rpx;
  background: var(--color-background-subtle);
}

.swiper-item,
.swiper-image {
  width: 100%;
}

.gallery-counter {
  position: absolute;
  right: var(--space-md);
  bottom: var(--space-md);
  padding: var(--space-3xs) var(--space-sm);
  border-radius: var(--radius-pill);
  background: var(--toast-bg);
  color: var(--toast-text);
  font-size: var(--font-caption);
}

.main-info {
  padding: var(--card-padding);
}

.title {
  color: var(--color-text-1);
  font-size: var(--font-2xl);
  font-weight: var(--weight-heavy);
  line-height: var(--lh-snug);
}

.price {
  margin-top: var(--space-sm);
  color: var(--color-price-highlight);
  font-size: 58rpx;
  font-weight: var(--weight-heavy);
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-top: var(--space-md);
}

.meta-item {
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-md);
  background: var(--color-info-bg);
  color: var(--color-info);
  font-size: var(--font-caption);
  font-weight: var(--weight-medium);
}

.address {
  margin-top: var(--space-lg);
  color: var(--color-text-2);
  font-size: var(--font-sm);
  line-height: var(--lh-normal);
}

.section {
  padding: 44rpx var(--card-padding) 48rpx;
}

.section-divider {
  width: 100%;
  height: 16rpx;
  background: #f7f8fa;
}

.section-header {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  margin-bottom: var(--space-lg);
}

.section-marker {
  width: 4rpx;
  height: 26rpx;
  border-radius: var(--radius-pill);
  background: var(--color-primary);
}

.section-title {
  color: var(--color-text-1);
  font-size: 36rpx;
  font-weight: var(--weight-heavy);
}

.section-content,
.address-text {
  color: var(--color-text-2);
  font-size: 28rpx;
  line-height: var(--lh-relaxed);
}

.map-wrap {
  overflow: hidden;
  border-radius: 16rpx;
}

.detail-map {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
}

.nearby-block--spaced {
  margin-top: var(--space-2xl);
}

.facility-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.facility-item {
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-md);
  background: #f2f2f2;
  color: #666666;
  font-size: var(--font-caption);
  font-weight: var(--weight-medium);
}

.contact-block {
  margin-top: var(--space-2xl);
  padding-top: var(--space-xl);
  border-top: var(--line-width-thin) solid var(--color-background-subtle);
}

.nearby-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md) 0;
  border-bottom: var(--line-width-hairline) solid var(--color-background-subtle);
}

.nearby-title {
  color: var(--color-text-1);
  flex: 1;
  padding-right: var(--space-md);
  font-size: var(--font-md);
  line-height: var(--lh-snug);
}

.nearby-distance {
  color: var(--color-text-3);
  font-size: var(--font-sm);
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding: var(--space-sm) var(--page-padding);
  padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom));
  background: var(--color-background-card);
  border-top: var(--line-width-thin) solid var(--color-background-subtle);
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.favorite-action,
.contact-btn {
  margin: 0;
}

.favorite-action::after,
.contact-btn::after {
  border: none;
}

.favorite-action {
  width: 132rpx;
  min-width: 132rpx;
  height: 100rpx;
  margin: 0;
  padding: 0;
  border-radius: var(--radius-lg);
  background: transparent;
  color: var(--color-text-2);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.favorite-action--active {
  background: transparent;
}

.favorite-icon {
  font-size: 34rpx;
  line-height: 1;
  color: var(--color-accent-rose);
}

.favorite-label {
  font-size: var(--font-xs);
  line-height: 1;
  color: var(--color-text-2);
}

.contact-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: var(--radius-pill);
  background: var(--gradient-brand);
  color: var(--color-text-inverse);
  font-size: var(--font-md);
  font-weight: var(--weight-heavy);
  box-shadow: var(--shadow-float);
}
