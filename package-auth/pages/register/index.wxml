<view class="container auth-page">
  <view class="card auth-card">
    <view class="title">注册账号</view>
    <view class="subtitle">填写基础信息后即可完成注册并自动登录</view>

    <view class="group">
      <view class="label required">昵称</view>
      <view class="field">
        <input class="input" data-field="nickName" value="{{formData.nickName}}" placeholder="请输入昵称" bindinput="onInputChange" maxlength="16" />
      </view>
      <view class="meta">
        <view class="hint">2-16 个字符，建议使用真实或常用称呼</view>
      </view>
    </view>

    <view class="group">
      <view class="label required">手机号</view>
      <view class="field">
        <input class="input" type="number" data-field="phone" value="{{formData.phone}}" placeholder="请输入 11 位手机号" bindinput="onInputChange" maxlength="11" />
      </view>
      <view class="meta">
        <view class="hint">用于登录、找回密码和安全验证</view>
      </view>
    </view>

    <view class="group">
      <view class="label required">密码</view>
      <view class="field">
        <input class="input has-action" password="{{!showPassword}}" data-field="password" value="{{formData.password}}" placeholder="6-20 位，至少字母+数字" bindinput="onInputChange" />
        <view class="eye" bindtap="togglePassword">{{showPassword ? '🙈' : '👁'}}</view>
      </view>
      <view class="meta">
        <view class="strength">
          <text>强度</text>
          <view class="bars">
            <view class="bar {{passwordStrength >= 1 ? 'active' : ''}}"></view>
            <view class="bar {{passwordStrength >= 2 ? 'active' : ''}}"></view>
            <view class="bar {{passwordStrength >= 3 ? 'active' : ''}}"></view>
          </view>
          <text>{{strengthText || '未设置'}}</text>
        </view>
      </view>
    </view>

    <view class="group">
      <view class="label">微信号（选填）</view>
      <view class="field">
        <input class="input" data-field="wechatId" value="{{formData.wechatId}}" placeholder="请输入微信号" bindinput="onInputChange" />
      </view>
      <view class="meta">
        <view class="hint">用于后续沟通或资料补充，可稍后完善</view>
      </view>
    </view>

    <view class="group">
      <view class="label required">默认身份</view>
      <view class="role-wrap">
        <view class="role {{formData.role === 'tenant' ? 'active' : ''}}" data-role="tenant" bindtap="onRoleChange">
          <view class="dot">{{formData.role === 'tenant' ? '✓' : ''}}</view>
          <view class="role-name">租客</view>
        </view>
        <view class="role {{formData.role === 'landlord' ? 'active' : ''}}" data-role="landlord" bindtap="onRoleChange">
          <view class="dot">{{formData.role === 'landlord' ? '✓' : ''}}</view>
          <view class="role-name">房东</view>
        </view>
      </view>
      <view class="meta">
        <view class="hint">注册后仍可在个人中心切换身份</view>
      </view>
    </view>

    <button class="submit-btn {{isReady ? 'enabled' : ''}}" loading="{{submitLoading}}" bindtap="onSubmitTap">注册并登录</button>

    <view class="protocol">
      点击即表示你已同意
      <text class="link">《用户协议》</text>
      与
      <text class="link">《隐私政策》</text>
    </view>

    <view class="bottom-text login">
      已有账号？
      <text class="link" bindtap="onGoLoginTap">去登录</text>
    </view>
  </view>
</view>
