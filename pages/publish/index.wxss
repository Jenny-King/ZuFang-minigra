.listings-page {
  min-height: 100vh;
  background: #f5f5f7;
}

.listings-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.head-copy {
  flex: 1;
  min-width: 0;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.2;
  color: #1a1a1a;
}

.page-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8c8c8c;
  line-height: 1.6;
}

.publish-entry-btn {
  margin: 0;
  flex-shrink: 0;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 16rpx 32rpx rgba(37, 99, 235, 0.22);
}

.stats-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  position: relative;
  padding: 20rpx 12rpx;
  border-radius: 24rpx;
  border: 2rpx solid transparent;
  text-align: center;
  background: #ffffff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.03);
  transition: background 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
}

.stat-card.active {
  border-color: #3c7bfd;
  background: rgba(60, 123, 253, 0.05);
  box-shadow: 0 6rpx 16rpx rgba(60, 123, 253, 0.08);
}

.stat-number {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
}

.stat-card.blue .stat-number {
  color: #2563eb;
}

.stat-card.green .stat-number {
  color: #16a34a;
}

.stat-card.amber .stat-number {
  color: #d97706;
}

.stat-card.gray .stat-number {
  color: #9ca3af;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #666666;
}

.stat-card.active .stat-label {
  font-weight: 600;
  color: #3c7bfd;
}

.hint-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 18rpx;
  border-radius: 20rpx;
  background: rgba(60, 123, 253, 0.08);
}

.hint-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: rgba(60, 123, 253, 0.16);
}

.hint-icon-mark {
  color: #3c7bfd;
  font-size: 24rpx;
  font-weight: 700;
}

.hint-text {
  flex: 1;
  font-size: 23rpx;
  color: #2f65d9;
  line-height: 1.5;
}

.hint-close {
  font-size: 34rpx;
  color: rgba(60, 123, 253, 0.5);
  padding: 0 4rpx;
}

.error-box {
  padding: 20rpx;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  color: #dc2626;
  background: #fff1f0;
  font-size: 24rpx;
}

.listing-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.listing-card {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.06);
}

.card-inner {
  position: relative;
  z-index: 2;
  transition: transform 0.28s ease;
  background: #ffffff;
}

.listing-card.swiped .card-inner {
  transform: translateX(-220rpx);
}

.card-body {
  display: flex;
  gap: 18rpx;
  padding: 24rpx;
}

.thumb-box {
  width: 148rpx;
  height: 148rpx;
  flex-shrink: 0;
  border-radius: 22rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
}

.thumb-image {
  width: 100%;
  height: 100%;
}

.thumb-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  color: #2563eb;
  font-size: 48rpx;
  font-weight: 700;
}

.card-info {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.45;
}

.card-price {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-price-highlight);
}

.price-unit {
  font-size: 22rpx;
  font-weight: 400;
  color: #9ca3af;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.tag {
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
  line-height: 1.6;
}

.tag.neutral {
  background: #f3f4f6;
  color: #6b7280;
}

.tag.success {
  background: #dcfce7;
  color: #15803d;
}

.tag.warning {
  background: #fef3c7;
  color: #b45309;
}

.tag.danger {
  background: #fee2e2;
  color: #dc2626;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 24rpx 22rpx;
  border-top: 1rpx solid #f0f2f5;
}

.card-time {
  font-size: 22rpx;
  color: #c4c4c6;
}

.card-actions {
  display: flex;
  gap: 10rpx;
}

.action-btn {
  margin: 0;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.action-btn.edit {
  background: #f2f2f2;
  color: #333333;
}

.action-btn.more {
  min-width: 76rpx;
  background: #f2f2f2;
  color: #333333;
}

.action-btn::after {
  border: none;
}

.swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  display: flex;
  overflow: hidden;
  border-radius: 0 28rpx 28rpx 0;
  z-index: 1;
}

.swipe-btn {
  margin: 0;
  width: 110rpx;
  height: 100%;
  border-radius: 0;
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;
}

.swipe-offline {
  background: #f59e0b;
}

.swipe-delete {
  background: #ef4444;
  border-radius: 0 28rpx 28rpx 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  text-align: center;
}

.empty-state.slim {
  padding: 56rpx 30rpx;
}

.empty-icon {
  font-size: 64rpx;
}

.empty-title {
  margin-top: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
}

.empty-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #9ca3af;
}

.empty-action-btn {
  margin-top: 24rpx;
  min-width: 260rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 18rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
}

.loading-tip {
  text-align: center;
  color: #9ca3af;
  font-size: 22rpx;
  padding: 24rpx 0;
}

.delete-modal-mask {
  position: fixed;
  inset: 0;
  z-index: 999;
  background: rgba(0, 0, 0, 0.38);
  display: flex;
  align-items: flex-end;
}

.delete-modal-panel {
  width: 100%;
  padding: 30rpx 28rpx 40rpx;
  border-radius: 32rpx 32rpx 0 0;
  background: #ffffff;
}

.delete-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  text-align: center;
  line-height: 1.5;
}

.delete-modal-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #6b7280;
  text-align: center;
  line-height: 1.7;
}

.delete-confirm-btn,
.delete-cancel-btn {
  margin-top: 18rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
}

.delete-confirm-btn {
  background: #ff4d4f;
  color: #ffffff;
  font-weight: 700;
}

.delete-cancel-btn {
  background: #f7f8fa;
  color: #666666;
}

.delete-confirm-btn::after,
.delete-cancel-btn::after {
  border: none;
}
