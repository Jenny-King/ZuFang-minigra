@import "../../styles/variables.wxss";

.profile-page {
  min-height: 100vh;
  padding-bottom: var(--space-lg);
  background: var(--color-background-page);
}

.profile-loading {
  padding: var(--card-padding);
}

.hero-card {
  padding: 40rpx;
  margin-bottom: var(--space-lg);
  overflow: hidden;
  border-radius: var(--radius-2xl);
  background: var(--gradient-brand);
  color: var(--color-text-inverse);
  box-shadow: var(--shadow-float);
}

.hero-main {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.hero-avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  box-shadow: 0 10rpx 20rpx rgba(15, 41, 114, 0.12);
}

.hero-avatar-image {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 999rpx;
}

.hero-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
}

.hero-name {
  color: var(--color-text-inverse);
  font-size: var(--font-xl);
  font-weight: var(--weight-heavy);
  line-height: var(--lh-tight);
}

.hero-subline {
  color: var(--color-text-inverse);
  font-size: var(--font-sm);
  opacity: 0.72;
}

.hero-avatar-tip {
  color: rgba(255, 255, 255, 0.66);
  font-size: var(--font-xxs);
  line-height: 1.35;
}

.hero-badges {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  padding: 24rpx 0 0;
}

.badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2xs);
  padding: var(--space-2xs) var(--space-sm);
  border-radius: var(--radius-pill);
  border: var(--line-width-hairline) solid rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.16);
  font-size: var(--font-xs);
  color: rgba(255, 255, 255, 0.96);
}

.badge.role.landlord,
.badge.role.tenant,
.badge.role.admin,
.badge.identity.idle,
.badge.wechat.unbound,
.hero-stats,
.stat-card.active {
  background: rgba(255, 255, 255, 0.16);
}

.badge.identity.verified,
.badge.identity.pending {
  background: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.98);
}

.badge.wechat.bound {
  background: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.98);
}

.badge-icon {
  font-size: var(--font-xxs);
}

.badge-dot {
  font-size: var(--font-xs);
}

.hero-stats {
  display: flex;
  margin-top: 28rpx;
  overflow: hidden;
  border-radius: var(--radius-xl);
  background: rgba(255, 255, 255, 0.08);
  box-shadow: inset 0 0 0 var(--line-width-hairline) rgba(255, 255, 255, 0.08);
}

.stat-card {
  position: relative;
  flex: 1;
  min-width: 0;
  padding: 24rpx 12rpx;
  text-align: center;
}

.stat-card + .stat-card {
  border-left: var(--line-width-hairline) solid rgba(255, 255, 255, 0.16);
}

.stat-number {
  display: block;
  color: var(--color-text-inverse);
  font-size: var(--font-2xl);
  font-weight: var(--weight-heavy);
  line-height: 1;
}

.stat-label {
  display: block;
  margin-top: var(--space-2xs);
  color: var(--color-text-inverse);
  font-size: var(--font-xs);
  opacity: 0.8;
}

.stat-badge {
  position: absolute;
  top: var(--space-xs);
  right: 50%;
  transform: translateX(34rpx);
  min-width: 24rpx;
  padding: 0 var(--space-3xs);
  height: 24rpx;
  line-height: 24rpx;
  border-radius: var(--radius-pill);
  background: var(--color-danger);
  color: var(--color-text-inverse);
  font-size: var(--font-xxs);
  font-weight: var(--weight-heavy);
}

.guest-card {
  padding: var(--space-xl) var(--space-lg);
  margin-bottom: var(--space-lg);
  border-radius: var(--radius-2xl);
}

.guest-title {
  color: var(--color-text-1);
  font-size: var(--font-xl);
  font-weight: var(--weight-heavy);
}

.guest-subtitle {
  margin-top: var(--space-xs);
  color: var(--color-text-2);
  font-size: var(--font-sm);
  line-height: var(--lh-relaxed);
}

.auth-actions {
  display: flex;
  gap: var(--space-xs);
  margin-top: var(--space-md);
}

.auth-btn {
  margin: 0;
  border-radius: var(--radius-pill);
  background: var(--color-background-subtle);
  color: var(--color-text-1);
}

.auth-btn.primary {
  background: var(--color-primary);
  color: var(--color-text-inverse);
}

.section-card {
  margin-top: var(--space-xs);
  overflow: hidden;
  border-radius: var(--radius-2xl);
  background: var(--color-background-card);
}

.menu-item {
  display: flex;
  align-items: center;
  min-height: 108rpx;
  padding: var(--space-md) var(--page-padding);
  border-bottom: var(--line-width-hairline) solid var(--color-border);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  margin-right: var(--space-sm);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon.amber {
  background: var(--color-accent-amber-bg);
  color: var(--color-warning);
}

.menu-icon.purple {
  background: var(--color-accent-purple-bg);
  color: var(--color-accent-purple);
}

.menu-icon.red {
  background: var(--color-danger-bg);
  color: var(--color-danger);
}

.menu-icon-text {
  font-size: var(--font-label);
  font-weight: var(--weight-heavy);
}

.menu-main {
  flex: 1;
  min-width: 0;
}

.menu-title {
  color: var(--color-text-1);
  font-size: var(--font-md);
  font-weight: var(--weight-bold);
}

.menu-subtitle {
  display: block;
  margin-top: var(--space-3xs);
  color: var(--color-text-3);
  font-size: var(--font-caption);
  line-height: var(--lh-snug);
}

.arrow {
  margin-left: var(--space-xs);
  color: var(--color-text-3);
  font-size: var(--font-md);
}

.account-section {
  margin-top: var(--space-md);
  padding: var(--space-md) var(--page-padding);
  border-radius: var(--radius-2xl);
  background: var(--color-background-card);
}

.account-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-sm);
}

.account-section-label {
  color: var(--color-text-3);
  font-size: var(--font-caption);
  font-weight: var(--weight-bold);
}

.account-section-action {
  color: var(--color-primary);
  font-size: var(--font-caption);
}

.account-scroll {
  width: 100%;
  white-space: nowrap;
}

.account-inline-list {
  display: inline-flex;
  align-items: flex-start;
  gap: var(--space-md);
}

.account-inline-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2xs);
  width: 96rpx;
}

.account-inline-avatar,
.account-inline-add {
  width: var(--avatar-size-md);
  height: var(--avatar-size-md);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-pill);
  overflow: hidden;
}

.account-inline-avatar {
  background: var(--color-primary-bg);
  border: 4rpx solid transparent;
}

.account-inline-avatar.active {
  border-color: var(--color-primary);
}

.account-inline-image {
  width: 100%;
}

.account-inline-add {
  border: var(--line-width-thin) dashed var(--color-border-strong);
  background: var(--color-background-page);
  color: var(--color-text-3);
  font-size: var(--font-2xl);
  line-height: 1;
}

.account-inline-name {
  width: 100%;
  color: var(--color-text-2);
  font-size: var(--font-xxs);
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.account-inline-name.active {
  color: var(--color-primary);
}

.account-inline-name.dim {
  color: var(--color-text-3);
}

.logout-wrap {
  margin-top: var(--space-md);
}

.logout-btn {
  width: 100%;
  height: var(--button-height);
  line-height: var(--button-height);
  margin: 0;
  border: 2rpx solid rgba(255, 77, 79, 0.9);
  border-radius: var(--radius-xl);
  background: var(--color-background-card);
  color: var(--color-danger);
  font-size: var(--font-md);
  font-weight: var(--weight-bold);
  box-shadow: 0 12rpx 28rpx rgba(255, 77, 79, 0.08);
}

.logout-btn::after {
  border: none;
}

.account-switcher-mask {
  position: fixed;
  inset: 0;
  z-index: 99;
  display: flex;
  align-items: flex-end;
  background: var(--overlay-bg);
}

.account-switcher-panel {
  width: 100%;
  padding: var(--space-xl) var(--space-lg) calc(var(--space-lg) + env(safe-area-inset-bottom));
  border-radius: var(--radius-panel) var(--radius-panel) 0 0;
  background: var(--gradient-panel);
  box-shadow: var(--shadow-float);
}

.account-switcher-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: var(--space-lg);
}

.account-switcher-title {
  color: var(--color-text-1);
  font-size: var(--font-xl);
  font-weight: var(--weight-heavy);
}

.account-switcher-subtitle {
  margin-top: var(--space-2xs);
  color: var(--color-text-2);
  font-size: var(--font-caption);
  line-height: var(--lh-normal);
}

.tap-area {
  min-width: 88rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.account-switcher-close {
  color: var(--color-text-2);
  font-size: var(--font-xl);
}

.account-card-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.account-card {
  position: relative;
  display: flex;
  align-items: center;
  padding: var(--space-md);
  border: var(--line-width-hairline) solid transparent;
  border-radius: var(--radius-lg);
  background: transparent;
}

.account-card:active {
  background: var(--color-background-subtle);
}

.account-card.active {
  background: var(--color-primary-bg);
  border: var(--line-width-hairline) solid var(--color-primary);
  border-radius: var(--radius-lg);
}

.account-card-avatar {
  width: var(--avatar-size-lg);
  flex-shrink: 0;
}

.account-card-remove {
  position: absolute;
  top: var(--space-sm);
  right: var(--space-sm);
  padding: var(--space-2xs) var(--space-xs);
  border-radius: var(--radius-pill);
  background: var(--color-danger-bg);
  color: var(--color-danger);
  font-size: var(--font-xs);
}

.account-card-main {
  flex: 1;
  min-width: 0;
  margin-left: var(--space-sm);
}

.account-card-title-row {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.account-card-name {
  max-width: 320rpx;
  color: var(--color-text-1);
  font-size: var(--font-title-sm);
  font-weight: var(--weight-bold);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.account-card-role {
  padding: var(--space-3xs) var(--space-xs);
  border-radius: var(--radius-pill);
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: var(--font-xs);
}

.account-card-subline {
  margin-top: var(--space-2xs);
  color: var(--color-text-2);
  font-size: var(--font-caption);
}

.account-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2xs);
  margin-top: var(--space-sm);
}

.account-card-tag {
  padding: var(--space-2xs) var(--space-xs);
  border-radius: var(--radius-pill);
  background: var(--color-background-subtle);
  color: var(--color-text-2);
  font-size: var(--font-xs);
}

.account-card-tag.active {
  background: var(--color-primary);
  color: var(--color-text-inverse);
}

.account-switcher-actions {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-lg);
}

.account-switcher-btn {
  flex: 1;
  height: var(--button-height);
  line-height: var(--button-height);
  margin: 0;
  border-radius: var(--radius-lg);
  background: var(--color-background-card);
  color: var(--color-text-1);
  border: var(--line-width-thin) solid var(--color-border-strong);
  font-size: var(--font-md);
}

.account-switcher-btn.primary {
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-color: var(--color-primary);
}
