.my-houses-page {
  min-height: 100vh;
}

.toolbar {
  margin-bottom: var(--space-sm);
  display: flex;
  justify-content: flex-end;
}

.publish-btn {
  margin: 0;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  border-radius: var(--radius-control);
  background: var(--color-primary);
  color: #ffffff;
  font-size: 22rpx;
}

.error-box {
  padding: 20rpx;
  margin-bottom: 20rpx;
  border-radius: var(--radius-card);
  color: var(--color-warning);
  background: #fff1f0;
  font-size: var(--font-meta);
}

.house-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.house-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx;
}

.main {
  flex: 1;
  min-width: 0;
}

.title {
  font-size: var(--font-body);
  color: var(--color-text-main);
  font-weight: 500;
}

.meta {
  margin-top: var(--space-xs);
  display: flex;
  gap: var(--space-sm);
  align-items: center;
  flex-wrap: wrap;
  font-size: var(--font-meta);
  color: var(--color-text-secondary);
}

.price {
  color: var(--color-warning);
  font-size: var(--font-body);
  font-weight: 600;
}

.status {
  color: var(--color-text-secondary);
}

.time {
  margin-top: 12rpx;
  color: var(--color-text-secondary);
  font-size: var(--font-meta);
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.edit-btn {
  margin: 0;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  border-radius: var(--radius-control);
  background: #f5f5f5;
  color: var(--color-text-secondary);
  font-size: 22rpx;
}

.delete-btn {
  margin: 0;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  border-radius: var(--radius-control);
  background: #fff1f0;
  color: var(--color-warning);
  font-size: 22rpx;
}

.loading-tip {
  text-align: center;
  color: var(--color-text-secondary);
  font-size: var(--font-meta);
  padding: 22rpx 0;
}
