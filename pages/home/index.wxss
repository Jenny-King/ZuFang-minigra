@import "../../styles/variables.wxss";

.home-page {
  min-height: 100vh;
  background: var(--color-background-page);
}

.home-top-bar {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 10;
  padding: 0 var(--page-padding) 20rpx;
  background: var(--color-background-card);
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.03);
}

.home-scroll {
  height: 100vh;
}

.home-content {
  padding: 0 var(--page-padding) calc(var(--space-3xl) + env(safe-area-inset-bottom));
}

.search-panel {
  padding-top: 8rpx;
}

.search-capsule {
  display: flex;
  align-items: center;
  min-height: var(--input-height);
  overflow: hidden;
  padding: 0 var(--space-md);
  border-radius: var(--radius-pill);
  background: var(--color-background-subtle);
  box-shadow:
    inset 0 0 0 var(--line-width-thin) rgba(229, 231, 235, 0.95),
    0 8rpx 20rpx rgba(15, 23, 42, 0.04);
}

.search-capsule-city {
  display: flex;
  align-items: center;
  gap: var(--space-2xs);
  flex-shrink: 0;
  max-width: 180rpx;
  min-height: var(--input-height);
  padding-right: var(--space-md);
}

.city-dot {
  width: 14rpx;
  height: 14rpx;
  flex-shrink: 0;
  border-radius: var(--radius-pill);
  background: var(--color-success);
  box-shadow: 0 0 0 var(--space-3xs) var(--color-success-bg);
}

.search-capsule-city-label {
  max-width: 132rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: var(--font-sm);
  font-weight: var(--weight-bold);
  color: var(--color-text-1);
}

.city-entry-arrow,
.filter-chip-arrow {
  color: var(--color-text-3);
  font-size: var(--font-xs);
}

.search-capsule-input {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: var(--space-2xs);
  min-height: var(--input-height);
  padding-left: var(--space-sm);
  border-left: var(--line-width-thin) solid rgba(209, 213, 219, 0.9);
}

.search-capsule-icon {
  flex-shrink: 0;
  color: #a1a1aa;
  font-size: 26rpx;
  line-height: 1;
}

.search-input {
  flex: 1;
  height: var(--input-height);
  min-height: var(--input-height);
  line-height: var(--input-height);
  padding: 0;
  font-size: var(--font-sm);
  color: var(--color-text-1);
}

.search-input-placeholder {
  color: var(--color-text-3);
  font-size: var(--font-sm);
  line-height: var(--input-height);
}

.filter-bar {
  display: flex;
  width: 100%;
  margin-top: 16rpx;
  padding: 6rpx 0 4rpx;
  white-space: nowrap;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2xs);
  min-height: 60rpx;
  margin-right: var(--space-xs);
  padding: 0 22rpx;
  border: var(--line-width-thin) solid rgba(229, 231, 235, 0.92);
  border-radius: var(--radius-pill);
  background: var(--color-background-card);
  color: var(--color-text-2);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.04);
}

.filter-chip-active {
  border-color: rgba(37, 99, 235, 0.18);
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

.filter-chip-active .filter-chip-arrow {
  color: var(--color-primary);
}

.filter-reset-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  min-height: 60rpx;
  margin: 0;
  padding: 0 22rpx;
  border: var(--line-width-thin) solid rgba(37, 99, 235, 0.14);
  border-radius: var(--radius-pill);
  background: var(--color-background-card);
  color: var(--color-primary);
  font-size: var(--font-sm);
  font-weight: var(--weight-bold);
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.04);
}

.filter-reset-btn::after {
  border: none;
}

.error-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  padding: var(--card-padding);
  margin-top: var(--space-lg);
  border-radius: var(--radius-lg);
  background: var(--color-danger-bg);
}

.error-box__text {
  flex: 1;
  color: var(--color-danger);
  font-size: var(--font-sm);
  line-height: var(--lh-normal);
}

.error-box__retry {
  min-width: 120rpx;
  min-height: var(--control-height-sm);
  margin: 0;
  padding: 0 var(--space-md);
  border-radius: var(--radius-pill);
  background: var(--color-background-card);
  color: var(--color-danger);
  font-size: var(--font-caption);
  font-weight: var(--weight-bold);
}

.error-box__retry::after {
  border: none;
}

.content-section,
.latest-section {
  margin-top: var(--space-lg);
}

.section-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-2xs) 0 var(--space-lg);
}

.section-heading-title {
  color: var(--color-text-1);
  font-size: var(--font-title-sm);
  font-weight: var(--weight-heavy);
}

.section-heading-link,
.section-heading-count {
  color: var(--color-text-3);
  font-size: var(--font-caption);
}

.section-heading-link {
  padding: 8rpx 14rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.04);
}

.featured-row {
  display: flex;
  width: 100%;
  white-space: nowrap;
  padding-right: var(--space-xs);
  padding-bottom: var(--space-2xs);
}

.featured-card {
  display: inline-block;
  width: 308rpx;
  margin-right: var(--space-md);
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--color-background-card);
  box-shadow: var(--shadow-card-soft);
  vertical-align: top;
}

.featured-thumb-wrap,
.latest-card-thumb-wrap {
  position: relative;
  overflow: hidden;
}

.featured-thumb-wrap {
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  background: var(--color-background-card);
}

.featured-thumb,
.latest-card-thumb {
  display: block;
  width: 100%;
}

.accent-blue {
  background: var(--color-background-card);
}

.accent-green {
  background: var(--color-background-card);
}

.accent-gold {
  background: var(--color-background-card);
}

.accent-pink {
  background: var(--color-background-card);
}

.accent-purple {
  background: var(--color-background-card);
}

.featured-badge {
  position: absolute;
  left: var(--space-md);
  top: var(--space-md);
  padding: var(--space-3xs) var(--space-xs);
  border-radius: var(--radius-pill);
  color: var(--color-text-inverse);
  font-size: var(--font-xs);
  font-weight: var(--weight-bold);
}

.featured-badge-red {
  background: var(--color-danger);
}

.featured-badge-blue {
  background: var(--color-primary);
}

.featured-badge-green {
  background: var(--color-success);
}

.featured-body {
  padding: 18rpx 16rpx 20rpx;
}

.featured-price,
.latest-card-price {
  display: flex;
  align-items: flex-end;
  gap: var(--space-2xs);
}

.featured-price {
  margin-bottom: 8rpx;
}

.featured-price-main,
.latest-card-price-main {
  color: var(--color-price-highlight);
  font-size: var(--font-xl);
  font-weight: var(--weight-heavy);
}

.featured-price-unit,
.latest-card-price-unit {
  padding-bottom: var(--space-3xs);
  color: var(--color-text-3);
  font-size: var(--font-xs);
}

.featured-title {
  margin-top: 0;
  margin-bottom: 8rpx;
  color: var(--color-text-1);
  font-size: var(--font-sm);
  font-weight: var(--weight-bold);
  line-height: var(--lh-snug);
}

.featured-tags {
  display: flex;
  flex-wrap: nowrap;
  align-items: center;
  gap: var(--space-2xs);
  min-height: 52rpx;
  overflow: hidden;
  margin-top: 0;
  white-space: nowrap;
}

.latest-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2xs);
  margin-top: 14rpx;
}

.featured-tag,
.latest-card-tag {
  padding: var(--space-3xs) var(--space-xs);
  border-radius: var(--radius-sm);
  background: var(--color-background-subtle);
  color: var(--color-text-2);
  font-size: var(--font-xs);
  line-height: var(--lh-normal);
}

.featured-tags .featured-tag {
  flex: 0 0 auto;
  white-space: nowrap;
}

.featured-tags .featured-tag-highlight {
  flex: 1 1 auto;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
}

.featured-tag-highlight,
.latest-card-tag-highlight {
  background: var(--color-accent-green-bg);
  color: var(--color-accent-green);
}

.divider {
  height: 8rpx;
  margin-top: var(--space-lg);
  border-radius: var(--radius-pill);
  background: var(--color-background-muted);
}

.latest-heading {
  padding-top: var(--space-lg);
}

.sort-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx;
  border-radius: var(--radius-lg);
  background: var(--color-background-card);
  box-shadow: var(--shadow-card-soft);
}

.sort-tab {
  flex: 1;
  padding: 18rpx 0;
  border-radius: var(--radius-md);
  text-align: center;
  color: var(--color-text-2);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
}

.sort-tab-active {
  background: rgba(37, 99, 235, 0.1);
  color: var(--color-primary);
  font-weight: var(--weight-heavy);
  box-shadow: inset 0 0 0 2rpx rgba(37, 99, 235, 0.06);
}

.latest-list {
  margin-top: 20rpx;
}

.latest-card {
  display: flex;
  align-items: flex-start;
  gap: var(--space-md);
  padding: 22rpx 20rpx;
  margin-bottom: var(--space-lg);
  border-radius: var(--radius-2xl);
  background: var(--color-background-card);
  border: var(--line-width-hairline) solid rgba(229, 231, 235, 0.75);
  box-shadow: var(--shadow-card-soft);
}

.latest-card-thumb-wrap {
  width: var(--image-thumb-size);
  flex-shrink: 0;
  overflow: hidden;
  border-radius: var(--radius-lg);
  background: var(--color-background-subtle);
}

.latest-card-body {
  flex: 1;
  min-width: 0;
}

.latest-card-price {
  margin-top: 10rpx;
}

.latest-card-title {
  color: var(--color-text-1);
  font-size: var(--font-title-sm);
  font-weight: var(--weight-bold);
  line-height: var(--lh-snug);
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.latest-card-address {
  margin-top: 12rpx;
  color: var(--color-text-3);
  font-size: var(--font-caption);
  line-height: var(--lh-normal);
}

.latest-card-time {
  margin-top: 8rpx;
  color: var(--color-text-3);
  font-size: var(--font-xs);
}

.loading-tip {
  padding: var(--space-lg) 0;
  color: var(--color-text-3);
  font-size: var(--font-caption);
  text-align: center;
}
