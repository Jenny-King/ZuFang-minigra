<view class="container detail-page">
  <view wx:if="{{loading && !houseDetail}}" class="detail-loading card">
    <skeleton type="detail" />
  </view>

  <view wx:if="{{errorText}}" class="error-box">
    <text class="error-box__text">{{errorText}}</text>
    <button class="error-box__retry" bindtap="loadPageData">重试</button>
  </view>

  <view wx:if="{{houseDetail}}" class="detail-card">
    <view class="gallery-wrap">
      <swiper class="image-swiper" circular indicator-dots bindchange="onSwiperChange">
        <swiper-item wx:for="{{houseDetail.displayImages}}" wx:key="index">
          <view class="swiper-item" data-url="{{item}}" bindtap="onPreviewImage">
            <lazy-image
              class="swiper-image"
              src="{{item}}"
              mode="aspectFill"
              radius="var(--radius-lg)"
              height="440rpx"
            />
          </view>
        </swiper-item>
      </swiper>
      <view class="gallery-counter">{{swiperCurrent + 1}}/{{houseDetail.displayImages.length}}</view>
    </view>

    <view class="main-info">
      <view class="title">{{houseDetail.displayTitle}}</view>
      <view class="price">{{houseDetail.displayPrice}}</view>
      <view class="meta-row">
        <text class="meta-item">{{houseDetail.displayType}}</text>
        <text class="meta-item">{{houseDetail.displayArea}}</text>
        <text class="meta-item">{{houseDetail.displayFloor}}</text>
      </view>
      <view class="address">{{houseDetail.displayAddress}}</view>
    </view>

    <view class="section-divider"></view>

    <view class="section">
      <view class="section-header">
        <view class="section-marker"></view>
        <view class="section-title">房源描述</view>
      </view>
      <view class="section-content">{{houseDetail.displayDescription}}</view>
    </view>

    <view wx:if="{{houseDetail.latitude || nearbyList.length}}" class="section-divider"></view>

    <view wx:if="{{houseDetail.latitude || nearbyList.length}}" class="section">
      <view wx:if="{{houseDetail.latitude}}">
        <view class="section-header">
          <view class="section-marker"></view>
          <view class="section-title">位置</view>
        </view>
        <view class="map-wrap">
          <map
            class="detail-map"
            latitude="{{houseDetail.latitude}}"
            longitude="{{houseDetail.longitude}}"
            markers="{{mapMarkers}}"
            scale="15"
          />
        </view>
      </view>

      <view wx:if="{{nearbyList.length}}" class="nearby-block {{houseDetail.latitude ? 'nearby-block--spaced' : ''}}">
        <view class="section-header">
          <view class="section-marker"></view>
          <view class="section-title">周边设施</view>
        </view>
        <view
          wx:for="{{nearbyList}}"
          wx:key="index"
          class="nearby-item"
        >
          <text class="nearby-title">{{item.title}}</text>
          <text class="nearby-distance">{{item.displayDistance}}</text>
        </view>
      </view>
    </view>

    <view class="section-divider"></view>

    <view class="section">
      <view class="section-header">
        <view class="section-marker"></view>
        <view class="section-title">配套设施</view>
      </view>
      <view wx:if="{{houseDetail.displayFacilities && houseDetail.displayFacilities.length}}" class="facility-list">
        <text
          class="facility-item"
          wx:for="{{houseDetail.displayFacilities}}"
          wx:key="index"
        >{{item}}</text>
      </view>
      <empty-state
        wx:else
        title="暂无设施"
        subtitle="房东暂未补充"
      />

      <view class="contact-block">
        <view class="section-header">
          <view class="section-marker"></view>
          <view class="section-title">联系人</view>
        </view>
        <view class="section-content">{{houseDetail.displayContactName}}（{{houseDetail.displayContactPhone}}）</view>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <button class="favorite-action {{isFavorite ? 'favorite-action--active' : ''}}" loading="{{favoriteLoading}}" bindtap="onToggleFavoriteTap">
      <text class="favorite-icon">{{isFavorite ? '♥' : '♡'}}</text>
      <text class="favorite-label">{{isFavorite ? '已收藏' : '收藏'}}</text>
    </button>
    <button class="booking-btn" bindtap="onBookingTap">预约看房</button>
    <button class="contact-btn" bindtap="onContactTap">联系房东</button>
  </view>
</view>
