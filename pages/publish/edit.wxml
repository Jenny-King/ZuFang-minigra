<view class="container publish-page">
  <view class="publish-shell">
    <view class="publish-progress {{titleHighlight ? 'active' : ''}}">
      <view class="publish-progress__track">
        <view class="publish-progress__fill" style="width: {{progressPercent}}%;"></view>
      </view>
      <view class="publish-progress__meta">
        <text class="publish-progress__step">{{progressStepText}}</text>
        <text class="publish-progress__label">{{progressLabel}}</text>
      </view>
    </view>

    <view wx:if="{{loadingDetail}}" class="loading-panel card">
      <skeleton type="detail" />
    </view>

    <view wx:if="{{errorText}}" class="error-box">
      <text class="error-box__text">{{errorText}}</text>
      <button class="error-box__retry" bindtap="reloadHouseDetail">重试</button>
    </view>

    <block wx:if="{{!loadingDetail}}">
      <view wx:if="{{currentStep === 0}}" class="card form-card">
        <view class="section-title">1. 基础信息</view>

        <view class="form-row form-row--featured">
          <view class="label-row">
            <text class="label">房源图片 <text class="label-count">({{imageList.length}}/9)</text></text>
          </view>
          <view class="helper-text helper-text--top">优先上传客厅、卧室和采光照片，首图会更影响点击率</view>
          <view class="image-grid image-grid-top">
            <view class="image-item" wx:for="{{imageList}}" wx:key="index">
              <lazy-image
                class="preview-image"
                src="{{item.url}}"
                mode="aspectFill"
                radius="var(--radius-md)"
                height="200rpx"
              />
              <view wx:if="{{item.uploading}}" class="upload-overlay">
                <view class="upload-overlay__progress">{{item.progress || 0}}%</view>
              </view>
              <view class="remove-btn" data-index="{{index}}" bindtap="onRemoveImage">×</view>
            </view>
            <view wx:if="{{imageList.length < 9}}" class="image-add" bindtap="onChooseImages">
              <view class="image-add__icon">+</view>
              <view class="image-add__title">添加图片</view>
              <view class="image-add__hint">相册或拍摄</view>
            </view>
          </view>
        </view>

        <view class="form-row">
          <text class="field-caption">房源标题</text>
          <input
            class="input input-outline title-input"
            data-field="title"
            value="{{formData.title}}"
            placeholder="请输入房源标题（如：张江高科 2室1厅 精装修）"
            bindinput="onInputChange"
          />
        </view>

        <view class="form-row">
          <text class="label">户型</text>
          <view class="layout-wheel-shell">
            <picker-view
              class="layout-wheel"
              value="{{layoutPickerValue}}"
              indicator-style="height: 84rpx;"
              bindchange="onLayoutPickerChange"
            >
              <picker-view-column>
                <view wx:for="{{roomOptions}}" wx:key="value" class="layout-wheel__item">{{item.value}}</view>
              </picker-view-column>
              <picker-view-column>
                <view wx:for="{{hallOptions}}" wx:key="value" class="layout-wheel__item">{{item.value}}</view>
              </picker-view-column>
              <picker-view-column>
                <view wx:for="{{bathOptions}}" wx:key="value" class="layout-wheel__item">{{item.value}}</view>
              </picker-view-column>
            </picker-view>
            <view class="layout-wheel__units">
              <text class="layout-wheel__unit">室</text>
              <text class="layout-wheel__unit">厅</text>
              <text class="layout-wheel__unit">卫</text>
            </view>
          </view>
          <view class="helper-text">当前户型：{{formData.layoutText || '请选择室 / 厅 / 卫'}}</view>
        </view>

        <view class="form-row">
          <text class="label">房源基础信息</text>
          <view class="meta-grid">
            <view class="meta-tag">
              <text class="meta-tag-label">月租金（元）</text>
              <input class="input meta-tag-control" type="number" data-field="price" value="{{formData.price}}" placeholder="请输入月租金" bindinput="onInputChange" />
            </view>
            <view class="meta-tag">
              <text class="meta-tag-label">面积（㎡）</text>
              <input class="input meta-tag-control" type="number" data-field="area" value="{{formData.area}}" placeholder="请输入面积" bindinput="onInputChange" />
            </view>
            <view class="meta-tag">
              <text class="meta-tag-label">最短租期</text>
              <input
                class="input meta-tag-control"
                type="number"
                data-field="minRentPeriod"
                value="{{formData.minRentPeriod}}"
                placeholder="请输入最短租期（月）"
                bindinput="onInputChange"
              />
            </view>
            <view class="meta-tag">
              <text class="meta-tag-label">楼层</text>
              <input class="input meta-tag-control" data-field="floor" value="{{formData.floor}}" placeholder="如：12/30层" bindinput="onInputChange" />
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{currentStep === 1}}" class="card form-card">
        <view class="section-title">2. 位置描述</view>

        <view class="form-row">
          <view class="label-row label-row--action">
            <text class="label">地址信息</text>
            <button class="location-btn" size="mini" bindtap="onChooseLocation">地图回填</button>
          </view>
          <view class="location-panel">
            <input class="input location-address" data-field="address" value="{{formData.address}}" placeholder="请输入详细地址" bindinput="onInputChange" />
            <view class="helper-text">可先地图定位自动带出城市、区域和地址，也可手动补充详细地址</view>
            <view wx:if="{{formData.city || formData.region}}" class="helper-text">
              已识别位置：{{formData.city || '未知城市'}}{{formData.region ? ' · ' + formData.region : ''}}
            </view>
            <map
              wx:if="{{formData.latitude}}"
              class="location-map"
              latitude="{{formData.latitude}}"
              longitude="{{formData.longitude}}"
              scale="15"
            />
            <view class="helper-text">{{formData.address || '未选择位置'}}</view>
          </view>
        </view>

        <view class="form-row">
          <text class="label">房源描述</text>
          <textarea class="textarea" data-field="description" value="{{formData.description}}" placeholder="描述房源亮点、配套、通勤和入住建议" bindinput="onInputChange" />
        </view>
      </view>

      <view wx:if="{{currentStep === 2}}" class="card form-card">
        <view class="section-title">3. 设施与联系</view>

        <view class="form-row">
          <text class="label">配套设施</text>
          <view class="facility-grid">
            <view
              wx:for="{{facilityOptions}}"
              wx:key="key"
              class="facility-tag {{formData.facilities[item.key] ? 'active' : ''}}"
              data-key="{{item.key}}"
              bindtap="onFacilityToggle"
            >{{item.label}}</view>
          </view>
          <view class="helper-text">点击标签可多选</view>
        </view>

        <view class="form-row">
          <text class="label">联系人</text>
          <input class="input" data-field="contactName" value="{{formData.contactName}}" placeholder="请输入联系人姓名" bindinput="onInputChange" />
        </view>

        <view class="form-row">
          <text class="label">联系电话</text>
          <input class="input" type="number" data-field="contactPhone" value="{{formData.contactPhone}}" placeholder="请输入手机号" bindinput="onInputChange" />
        </view>

        <view class="form-row">
          <view class="submit-preview">
            <view class="submit-preview-title">{{isEdit ? '保存后将返回房源管理页' : '发布后将返回房源管理页'}}</view>
            <view class="submit-preview-subtitle">新房源会自动出现在列表顶部，编辑也会刷新为最新状态。</view>
          </view>
        </view>
      </view>
    </block>

    <view class="step-actions">
      <button wx:if="{{currentStep > 0}}" class="step-btn secondary" bindtap="onPrevStepTap">上一步</button>
      <button wx:if="{{currentStep < 2}}" class="step-btn primary" bindtap="onNextStepTap">下一步</button>
      <button wx:if="{{currentStep === 2}}" class="step-btn primary" loading="{{submitting}}" bindtap="onSubmitTap">
        {{isEdit ? '保存修改' : '发布房源'}}
      </button>
    </view>
  </view>
</view>
