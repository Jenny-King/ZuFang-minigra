<view class="container booking-page">
  <!-- 房源摘要卡片 -->
  <view wx:if="{{houseCard}}" class="house-summary card">
    <lazy-image
      class="house-summary__image"
      src="{{houseCard.imageUrl}}"
      mode="aspectFill"
      radius="16rpx"
      width="120rpx"
      height="120rpx"
    />
    <view class="house-summary__info">
      <text class="house-summary__title text-ellipsis">{{houseCard.title}}</text>
      <text class="house-summary__price">{{houseCard.priceText}}</text>
      <text class="house-summary__meta text-ellipsis">{{houseCard.address}}</text>
    </view>
  </view>

  <!-- 日期选择 -->
  <view class="form-section card">
    <view class="form-section__header">
      <text class="form-section__title">选择日期</text>
      <text class="form-section__required">*</text>
    </view>
    <scroll-view class="date-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="date-list">
        <view
          wx:for="{{dateOptions}}"
          wx:key="value"
          class="date-chip {{selectedDate === item.value ? 'active' : ''}} {{item.disabled ? 'disabled' : ''}}"
          data-value="{{item.value}}"
          data-disabled="{{item.disabled}}"
          bindtap="onDateTap"
        >
          <text class="date-chip__week">{{item.weekday}}</text>
          <text class="date-chip__day">{{item.dayLabel}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 时间段选择 -->
  <view class="form-section card">
    <view class="form-section__header">
      <text class="form-section__title">选择时间段</text>
      <text class="form-section__required">*</text>
    </view>
    <view class="time-grid">
      <view
        wx:for="{{timeSlots}}"
        wx:key="value"
        class="time-chip {{selectedTimeSlot === item.value ? 'active' : ''}}"
        data-value="{{item.value}}"
        bindtap="onTimeSlotTap"
      >
        <text>{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="form-section card">
    <view class="form-section__header">
      <text class="form-section__title">联系方式</text>
      <text class="form-section__required">*</text>
    </view>
    <view class="form-row">
      <text class="form-label">联系人</text>
      <input
        class="form-input"
        value="{{contactName}}"
        placeholder="请输入您的姓名"
        bindinput="onContactNameInput"
      />
    </view>
    <view class="form-row">
      <text class="form-label">手机号</text>
      <input
        class="form-input"
        value="{{contactPhone}}"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        bindinput="onContactPhoneInput"
      />
    </view>
  </view>

  <!-- 备注 -->
  <view class="form-section card">
    <view class="form-section__header">
      <text class="form-section__title">备注</text>
      <text class="form-section__optional">选填</text>
    </view>
    <textarea
      class="form-textarea"
      value="{{remark}}"
      placeholder="如有特殊需求可在此说明，如希望看其他房间等..."
      maxlength="200"
      bindinput="onRemarkInput"
    />
    <text class="textarea-count">{{remark.length}}/200</text>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button
      class="submit-btn"
      loading="{{submitting}}"
      disabled="{{submitting || !canSubmit}}"
      bindtap="onSubmitTap"
    >提交预约</button>
  </view>
</view>
