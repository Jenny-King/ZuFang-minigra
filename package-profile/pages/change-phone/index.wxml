<view class="container change-phone-page">
  <view class="card change-phone-card">
    <view class="title">{{phoneEntryMeta.actionText}}</view>
    <view class="subtitle">
      <text wx:if="{{phoneEntryMeta.hasBoundPhone}}">当前手机号：{{currentPhoneText}}</text>
      <text wx:else>当前账号还没有绑定手机号</text>
    </view>

    <view class="form-item">
      <text class="label">{{phoneEntryMeta.hasBoundPhone ? "新手机号" : "手机号"}}</text>
      <input
        class="input"
        type="number"
        maxlength="11"
        placeholder="{{phoneEntryMeta.phonePlaceholder}}"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="form-item">
      <text class="label">验证码</text>
      <view class="row">
        <input
          class="input flex-1"
          type="number"
          maxlength="6"
          placeholder="{{phoneEntryMeta.codePlaceholder}}"
          value="{{code}}"
          bindinput="onCodeInput"
        />
        <button
          class="code-btn"
          loading="{{sendingCode}}"
          disabled="{{sendingCode || cdRunning}}"
          bindtap="onSendCodeTap"
        >
          {{cdRunning ? (cdSecs + "秒后重发") : "发送验证码"}}
        </button>
      </view>
    </view>

    <button class="submit-btn" loading="{{submitLoading}}" bindtap="onSubmitTap">
      {{phoneEntryMeta.submitText}}
    </button>
  </view>
</view>
