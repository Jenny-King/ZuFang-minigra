.support-page {
  min-height: 100vh;
  padding-bottom: 28rpx;
}

.support-hero {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #f4f8ff 0%, #e5efff 100%);
  color: #1f1f1f;
  border: 2rpx solid rgba(37, 99, 235, 0.08);
  box-shadow: 0 20rpx 40rpx rgba(37, 99, 235, 0.12);
}

.support-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #2563eb;
}

.support-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #5b6b89;
}

.support-tags {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.support-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: rgba(37, 99, 235, 0.1);
  color: #2563eb;
}

.section-title {
  margin: 22rpx 6rpx 16rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #4c5668;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.quick-card {
  padding: 24rpx;
  border-radius: 24rpx;
}

.quick-card-button {
  margin: 0;
  width: 100%;
  text-align: left;
  background: #ffffff;
}

.quick-card-button::after {
  border: none;
}

.quick-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.quick-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7f8797;
}

.faq-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.faq-card {
  padding: 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid transparent;
}

.faq-card.active {
  border-color: rgba(37, 99, 235, 0.14);
  background: #f4f8ff;
  box-shadow: 0 12rpx 28rpx rgba(37, 99, 235, 0.08);
}

.faq-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.faq-question {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f1f1f;
  line-height: 1.6;
}

.faq-arrow {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #2563eb;
  background: #eaf2ff;
}

.faq-answer {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #667085;
}

.feedback-card {
  padding: 24rpx;
  border-radius: 24rpx;
}

.feedback-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.feedback-subtitle {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #7f8797;
}

.feedback-label {
  margin-top: 22rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #4c5668;
}

.feedback-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.feedback-tag {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #647084;
  background: #f4f7fb;
}

.feedback-tag.active {
  color: #2563eb;
  background: rgba(37, 99, 235, 0.1);
}

.feedback-textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  border: none;
  background: #f4f6fa;
  font-size: 24rpx;
  color: #1f1f1f;
  box-sizing: border-box;
}

.feedback-input {
  width: 100%;
  height: 84rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  border: none;
  background: #f4f6fa;
  font-size: 24rpx;
  color: #1f1f1f;
  box-sizing: border-box;
}

.feedback-btn {
  margin-top: 24rpx;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #2f64f5 0%, #1f4fd7 100%);
  color: #ffffff;
  font-size: 28rpx;
  box-shadow: 0 16rpx 32rpx rgba(37, 99, 235, 0.22);
}

.feedback-btn::after {
  border: none;
}

.support-note {
  padding: 24rpx;
  border-radius: 24rpx;
}

.support-note-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.support-note-line {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #667085;
}

.support-note-btn {
  margin-top: 22rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: #eef4ff;
  color: #2563eb;
  border: none;
  font-size: 26rpx;
}

.support-note-btn::after {
  border: none;
}
