@import "../../styles/auth-form.wxss";

.subtitle {
  margin: 20rpx 0 48rpx;
  text-align: center;
  color: var(--color-text-3);
  font-size: var(--font-sm);
  line-height: var(--lh-normal);
}

.group {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  margin-bottom: 20rpx;
  color: var(--color-text-1);
  font-size: var(--font-md);
  font-weight: var(--weight-heavy);
}

.required::after {
  content: " *";
  color: var(--color-danger);
  font-weight: var(--weight-heavy);
}

.field {
  position: relative;
}

.input {
  background: var(--color-background-subtle);
  border-radius: var(--radius-2xl); /* Match rounded inputs */
  transition: all var(--duration-fast) ease;
}

.input.has-action {
  padding-right: 104rpx;
}

.eye {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-3);
  font-size: var(--font-lg);
  z-index: 2;
}

.meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  gap: 20rpx;
  min-height: 40rpx;
}

.hint {
  color: var(--color-text-3);
  font-size: 26rpx;
  line-height: var(--lh-snug);
}

.strength {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-3);
}

.bars {
  display: flex;
  gap: 8rpx;
}

.bar {
  width: 48rpx;
  height: 12rpx;
  border-radius: var(--radius-pill);
  background: var(--color-border);
  transition: all var(--duration-fast) var(--easing-standard);
}

.bar.active {
  background: var(--color-success);
}

.role-wrap {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-top: 8rpx;
}

.role {
  border: 2rpx solid var(--color-background-muted);
  background: var(--color-background-page);
  border-radius: var(--radius-lg);
  height: 112rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 0 28rpx;
  transition: all var(--duration-fast) var(--easing-standard);
}

.role.active {
  background: var(--color-primary-bg);
  border-color: rgba(60, 123, 253, 0.3);
}

.dot {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 3rpx solid var(--color-border-strong);
  background: var(--color-background-card);
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  color: var(--color-text-inverse);
  font-size: var(--font-md);
  font-weight: var(--weight-heavy);
  transition: all var(--duration-fast) var(--easing-standard);
}

.role.active .dot {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.role-name {
  font-size: var(--font-md);
  font-weight: var(--weight-heavy);
  color: var(--color-text-1);
}

.role.active .role-name {
  color: var(--color-primary);
}

.submit-btn {
  width: 100%;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border-radius: 32rpx;
  margin-top: 20rpx;
  background: #bfd5ff;
  color: #fff;
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  box-shadow: none;
  border: none;
  transition: all 0.2s ease;
}

.submit-btn::after {
  display: none;
}

.submit-btn.enabled {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  box-shadow: 0 24rpx 48rpx rgba(60, 123, 253, 0.22);
}

.protocol {
  margin-top: 28rpx;
  color: var(--color-text-3);
  font-size: 24rpx;
  line-height: var(--lh-normal);
  text-align: center;
}

.login {
  margin-top: 20rpx;
}
