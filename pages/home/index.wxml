<view class="home-page">
  <view
    id="homeTopBar"
    class="home-top-bar {{dropdownVisible ? 'home-top-bar-dropdown-open' : ''}}"
    style="{{topBarStyle}}"
  >
    <view class="search-panel">
      <view class="search-capsule">
        <view class="search-capsule-city" bindtap="onCityTap">
          <view class="city-dot"></view>
          <text class="search-capsule-city-label">{{selectedCityLabel || (locationLoading ? "定位中" : currentCityLabel)}}</text>
          <text class="city-entry-arrow">▾</text>
        </view>
        <view class="search-capsule-input">
          <text class="search-capsule-icon">⌕</text>
          <input
            class="search-input"
            placeholder="搜索小区、地铁、房源关键词"
            placeholder-class="search-input-placeholder"
            value="{{keywordDraft}}"
            bindinput="onKeywordInput"
            confirm-type="search"
            bindconfirm="onSearchTap"
          />
        </view>
      </view>
    </view>

    <scroll-view class="filter-bar" scroll-x enhanced show-scrollbar="{{false}}">
      <view
        class="filter-chip {{(activeDropdown === 'region' && dropdownVisible) || selectedRegionIndex > 0 ? 'filter-chip-active' : ''}}"
        data-key="region"
        bindtap="onFilterChipTap"
      >
        {{selectedRegionIndex > 0 ? ('区域 · ' + (regionOptions[selectedRegionIndex].label || '全部')) : '区域'}}
        <text class="filter-chip-arrow">{{activeDropdown === 'region' && dropdownVisible ? '▴' : '▾'}}</text>
      </view>
      <view
        class="filter-chip {{(activeDropdown === 'type' && dropdownVisible) || selectedRoomFilterLabel ? 'filter-chip-active' : ''}}"
        data-key="type"
        bindtap="onFilterChipTap"
      >
        {{selectedRoomFilterLabel ? ('居室 · ' + selectedRoomFilterLabel) : '居室'}}
        <text class="filter-chip-arrow">{{activeDropdown === 'type' && dropdownVisible ? '▴' : '▾'}}</text>
      </view>
      <view
        class="filter-chip {{(activeDropdown === 'price' && dropdownVisible) || selectedPriceLabel ? 'filter-chip-active' : ''}}"
        data-key="price"
        bindtap="onFilterChipTap"
      >
        {{selectedPriceLabel ? ('租金 · ' + selectedPriceLabel) : '租金'}}
        <text class="filter-chip-arrow">{{activeDropdown === 'price' && dropdownVisible ? '▴' : '▾'}}</text>
      </view>
    </scroll-view>
  </view>

  <view
    wx:if="{{dropdownVisible}}"
    class="filter-dropdown-layer"
    style="top: {{dropdownTop}}px;"
  >
    <view
      class="filter-dropdown-mask {{dropdownEntered ? 'filter-dropdown-mask-visible' : ''}}"
      bindtap="onCloseDropdown"
    ></view>
    <view
      class="filter-dropdown-panel {{dropdownEntered ? 'filter-dropdown-panel-entered' : ''}}"
      catchtap="noop"
    >
      <view class="filter-dropdown-sheet">
        <scroll-view class="filter-dropdown-content" scroll-y enhanced show-scrollbar="{{false}}">
          <view wx:if="{{activeDropdown === 'region'}}" class="filter-dropdown-section">
            <view class="filter-dropdown-title">选择区域</view>
            <view class="filter-option-grid">
            <view
              wx:for="{{regionOptions}}"
              wx:key="value"
              class="filter-option-tag {{draftRegionIndex === index ? 'filter-option-tag-active' : ''}}"
              data-key="region"
                data-index="{{index}}"
              bindtap="onSelectDropdownOption"
            >
              <text class="filter-option-tag-text">{{item.label || "全部区域"}}</text>
            </view>
          </view>
        </view>

        <view wx:if="{{activeDropdown === 'type'}}" class="filter-dropdown-section">
          <view class="filter-dropdown-title">选择居室</view>
          <view class="filter-option-grid">
            <view
              wx:for="{{draftRoomFilterOptions}}"
              wx:key="value"
              class="filter-option-tag {{item.selected ? 'filter-option-tag-active' : ''}}"
              data-value="{{item.value}}"
              bindtap="onToggleRoomFilter"
            >
              <text class="filter-option-tag-text">{{item.label}}</text>
            </view>
          </view>
        </view>

          <view wx:if="{{activeDropdown === 'price'}}" class="filter-dropdown-section">
            <view class="filter-dropdown-title">选择租金</view>
            <view class="price-range-form">
              <view
                class="price-input-box {{draftMinPrice ? 'price-input-box-filled' : ''}}"
              >
                <input
                  class="price-input"
                  type="number"
                  maxlength="6"
                  placeholder="最低租金"
                  value="{{draftMinPrice}}"
                  data-field="min"
                  bindinput="onPriceInput"
                />
                <text class="price-input-unit">元/月</text>
              </view>
              <text class="price-range-divider">-</text>
              <view
                class="price-input-box {{draftMaxPrice ? 'price-input-box-filled' : ''}}"
              >
                <input
                  class="price-input"
                  type="number"
                  maxlength="6"
                  placeholder="最高租金"
                  value="{{draftMaxPrice}}"
                  data-field="max"
                  bindinput="onPriceInput"
                />
                <text class="price-input-unit">元/月</text>
              </view>
            </view>
            <view class="price-range-hint">支持只填最低或最高，留空表示不限</view>
          </view>
        </scroll-view>

        <view class="filter-dropdown-actions">
          <button class="dropdown-action-btn dropdown-action-btn-secondary" bindtap="onDropdownReset">
            重置
          </button>
          <button class="dropdown-action-btn dropdown-action-btn-primary" bindtap="onDropdownConfirm">
            确定
          </button>
        </view>
      </view>
    </view>
  </view>

  <scroll-view
    class="home-scroll"
    scroll-y="{{!dropdownVisible}}"
    enhanced
    show-scrollbar="{{false}}"
    style="{{scrollAreaStyle}}"
  >
    <view class="home-content">
      <view wx:if="{{errorText}}" class="error-box">
        <text class="error-box__text">{{errorText}}</text>
        <button class="error-box__retry" bindtap="refreshList">重试</button>
      </view>

      <block wx:if="{{loading && !latestList.length && !errorText}}">
        <view class="content-section">
          <view class="section-heading">
            <text class="section-heading-title">精选推荐</text>
            <text class="section-heading-link">今日精选</text>
          </view>
          <skeleton type="card" count="{{2}}" />
        </view>

        <view class="divider"></view>

        <view class="latest-section">
          <view class="section-heading latest-heading">
            <text class="section-heading-title">最新发布</text>
            <text class="section-heading-count">为你加载中</text>
          </view>
          <skeleton type="list-item" count="{{4}}" />
        </view>
      </block>

      <block wx:else>
        <view wx:if="{{featuredList.length > 0}}" class="content-section">
          <view class="section-heading">
            <text class="section-heading-title">精选推荐</text>
            <text class="section-heading-link">为你精选</text>
          </view>
          <scroll-view class="featured-row" scroll-x enhanced show-scrollbar="{{false}}">
            <view
              class="featured-card"
              wx:for="{{featuredList}}"
              wx:key="_id"
              data-house-id="{{item._id}}"
              bindtap="onGoDetail"
            >
              <view class="featured-thumb-wrap {{item.accentClass}}">
                <lazy-image
                  class="featured-thumb"
                  src="{{item.displayImage}}"
                  mode="aspectFill"
                  radius="var(--radius-lg)"
                  height="340rpx"
                />
                <view class="featured-badge featured-badge-{{item.featuredBadgeType}}">
                  {{item.featuredBadgeLabel}}
                </view>
              </view>
              <view class="featured-body">
                <view class="featured-price">
                  <text class="featured-price-main">{{item.displayPrice}}</text>
                  <text class="featured-price-unit">/月</text>
                </view>
                <view class="featured-title text-ellipsis">{{item.displayTitle}}</view>
                <view class="featured-tags">
                  <text class="featured-tag">{{item.displayType}}</text>
                  <text class="featured-tag">{{item.displayArea}}</text>
                  <text class="featured-tag featured-tag-highlight">{{item.displayRegion}}</text>
                </view>
              </view>
            </view>
          </scroll-view>
        </view>

        <view class="divider"></view>

        <view class="latest-section">
          <view class="section-heading latest-heading">
            <text class="section-heading-title">最新发布</text>
            <text class="section-heading-count">共 {{total}} 套在租房源</text>
          </view>

          <view class="sort-row">
            <view
              wx:for="{{listSortTabs}}"
              wx:key="key"
              class="sort-tab {{item.active ? 'sort-tab-active' : ''}}"
              data-key="{{item.key}}"
              bindtap="onListSortTap"
            >
              {{item.label}}
            </view>
          </view>

          <empty-state
            wx:if="{{!loading && latestList.length === 0}}"
            title="暂无房源"
            subtitle="试试调整筛选条件"
            btn-text="{{hasActiveFilter ? '重置筛选' : ''}}"
            btn-type="ghost"
            bindbtntap="resetFilter"
          />

          <view wx:else class="latest-list">
            <view
              class="latest-card"
              wx:for="{{latestList}}"
              wx:key="_id"
              data-house-id="{{item._id}}"
              bindtap="onGoDetail"
            >
              <view class="latest-card-thumb-wrap {{item.accentClass}}">
                <lazy-image
                  class="latest-card-thumb"
                  src="{{item.displayImage}}"
                  mode="aspectFill"
                  radius="var(--radius-lg)"
                  height="148rpx"
                />
              </view>
              <view class="latest-card-body">
                <view class="latest-card-title">{{item.displayTitle}}</view>
                <view class="latest-card-price">
                  <text class="latest-card-price-main">{{item.displayPrice}}</text>
                  <text class="latest-card-price-unit">/月</text>
                </view>
                <view class="latest-card-tags">
                  <text class="latest-card-tag">{{item.displayType}}</text>
                  <text class="latest-card-tag">{{item.displayArea}}</text>
                  <text class="latest-card-tag latest-card-tag-highlight">{{item.displayRegion}}</text>
                </view>
                <view class="latest-card-address text-ellipsis">{{item.displayAddress}}</view>
                <view class="latest-card-time">{{item.displayCreateTime}}</view>
              </view>
            </view>
          </view>

          <view wx:if="{{!loading && latestList.length > 0 && !hasMore}}" class="loading-tip">没有更多了</view>
        </view>
      </block>
    </view>
  </scroll-view>
</view>
