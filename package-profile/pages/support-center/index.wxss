.support-page {
  min-height: 100vh;
  padding-bottom: 28rpx;
}

.support-hero {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(160deg, #0f8d77 0%, #12b59a 100%);
  color: #ffffff;
  box-shadow: 0 20rpx 40rpx rgba(18, 181, 154, 0.18);
}

.support-title {
  font-size: 38rpx;
  font-weight: 700;
}

.support-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.84);
}

.support-tags {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.support-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.15);
}

.section-title {
  margin: 22rpx 6rpx 16rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #4c5668;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.quick-card {
  padding: 24rpx;
  border-radius: 24rpx;
}

.quick-card-button {
  margin: 0;
  width: 100%;
  text-align: left;
  background: #ffffff;
}

.quick-card-button::after {
  border: none;
}

.quick-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.quick-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7f8797;
}

.faq-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.faq-card {
  padding: 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid transparent;
}

.faq-card.active {
  border-color: #9fe1d5;
  background: #f4fffc;
}

.faq-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.faq-question {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f1f1f;
  line-height: 1.6;
}

.faq-arrow {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #12a58d;
  background: #ebfaf6;
}

.faq-answer {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #667085;
}

.feedback-card {
  padding: 24rpx;
  border-radius: 24rpx;
}

.feedback-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.feedback-subtitle {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #7f8797;
}

.feedback-label {
  margin-top: 22rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #4c5668;
}

.feedback-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.feedback-tag {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #647084;
  background: #f4f7fb;
}

.feedback-tag.active {
  color: #0f8d77;
  background: #e9faf6;
}

.feedback-textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  font-size: 24rpx;
  color: #1f1f1f;
  box-sizing: border-box;
}

.feedback-input {
  width: 100%;
  height: 84rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  font-size: 24rpx;
  color: #1f1f1f;
  box-sizing: border-box;
}

.feedback-btn {
  margin-top: 24rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 20rpx;
  background: #0f8d77;
  color: #ffffff;
  font-size: 28rpx;
}

.support-note {
  padding: 24rpx;
  border-radius: 24rpx;
}

.support-note-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.support-note-line {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #667085;
}

.support-note-btn {
  margin-top: 22rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 18rpx;
  background: #eff8f6;
  color: #0f8d77;
  border: 2rpx solid #c6ece4;
  font-size: 26rpx;
}
