<view class="chat-detail-page">
  <view wx:if="{{errorText}}" class="error-box">{{errorText}}</view>

  <scroll-view
    class="message-scroll"
    scroll-y
    scroll-with-animation
    scroll-into-view="{{scrollToViewId}}"
  >
    <view
      wx:for="{{messageList}}"
      wx:key="_viewId"
      id="{{item._viewId}}"
      class="message-row {{item.isSelf ? 'self' : 'other'}}"
    >
      <view class="bubble">
        <text class="content">{{item.content}}</text>
        <text class="time">{{item.displayTime}}</text>
      </view>
    </view>
    <view wx:if="{{!loading && messageList.length === 0}}" class="empty-tip">
      暂无消息，发一条开始聊天吧
    </view>
  </scroll-view>

  <view class="input-bar">
    <input
      class="msg-input"
      value="{{inputValue}}"
      placeholder="输入消息内容"
      bindinput="onInputChange"
      confirm-type="send"
      bindconfirm="onSendTap"
    />
    <button class="send-btn" loading="{{sending}}" bindtap="onSendTap">发送</button>
  </view>
</view>