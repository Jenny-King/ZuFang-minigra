<view class="container auth-page">
  <view class="card auth-card">
    <view class="title">登录</view>

    <button class="wechat-btn" loading="{{submitLoading}}" bindtap="onWechatLoginTap">
      微信一键登录
    </button>

    <view class="divider">或使用手机号登录</view>

    <view class="mode-tabs">
      <view class="mode-tab {{mode === 'code' ? 'active' : ''}}" data-mode="code" bindtap="onModeChange">验证码登录</view>
      <view class="mode-tab {{mode === 'password' ? 'active' : ''}}" data-mode="password" bindtap="onModeChange">密码登录</view>
    </view>

    <view class="form-item">
      <text class="label">手机号</text>
      <input
        class="input {{errors.phone ? 'input-error' : ''}}"
        type="number"
        placeholder="请输入手机号"
        value="{{phone}}"
        bindinput="onInputPhone"
      />
      <text wx:if="{{errors.phone}}" class="field-error">{{errors.phone}}</text>
    </view>

    <view class="form-item" wx:if="{{mode === 'code'}}">
      <text class="label">验证码</text>
      <view class="input-inline {{errors.code ? 'input-inline-error' : ''}}">
        <input
          class="input-inline__control"
          type="number"
          placeholder="请输入验证码"
          value="{{code}}"
          bindinput="onInputCode"
        />
        <button
          class="inline-text-btn {{(cdRunning || sendingCode) ? 'disabled' : ''}}"
          disabled="{{cdRunning || sendingCode}}"
          bindtap="onSendCodeTap"
        >
          {{sendingCode ? '发送中...' : (cdRunning ? cdSecs + 's后重发' : '获取验证码')}}
        </button>
      </view>
      <text wx:if="{{errors.code}}" class="field-error">{{errors.code}}</text>
    </view>

    <view class="form-item" wx:if="{{mode === 'password'}}">
      <text class="label">密码</text>
      <view class="password-row {{errors.password ? 'password-row-error' : ''}}">
        <input
          class="password-input"
          type="{{showPwd ? 'text' : 'password'}}"
          placeholder="请输入密码"
          value="{{password}}"
          bindinput="onInputPassword"
        />
        <view class="tap-area password-toggle" bindtap="onTogglePassword">
          <text class="password-toggle-text">{{showPwd ? "隐藏" : "显示"}}</text>
        </view>
      </view>
      <text wx:if="{{errors.password}}" class="field-error">{{errors.password}}</text>
    </view>

    <button class="submit-btn" loading="{{submitLoading}}" bindtap="onSubmitTap">登录</button>

    <view class="bottom-text">
      还没有账号？
      <text class="link" bindtap="onGoRegisterTap">去注册</text>
    </view>
    <view class="bottom-text">
      忘记密码？
      <text class="link" bindtap="onGoResetPasswordTap">去重置</text>
    </view>
  </view>
</view>
